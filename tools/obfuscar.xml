<?xml version="1.0" encoding="utf-8"?>
<Obfuscator>
  <Var name="InPath" value="." />
  <Var name="OutPath" value="..\obfuscate-output" />

  <!-- String encryption - all assemblies -->
  <Var name="HideStrings" value="true" />
  <!-- Control flow obfuscation - all -->
  <Var name="ControlFlowObfuscation" value="true" />
  <!-- Suppress disassembly -->
  <Var name="SuppressIldasm" value="true" />

  <!-- Domain layer: NO rename (EF Core entity mapping requires original type/member names) -->
  <Module file="$(InPath)\Tabsan.EduSphere.Domain.dll">
    <Var name="HidePrivateApi" value="true" />
    <Var name="OptimizeMethods" value="true" />
  </Module>

  <!-- Application layer: NO rename (services use DI, EF configs are here too) -->
  <Module file="$(InPath)\Tabsan.EduSphere.Application.dll">
    <Var name="HidePrivateApi" value="true" />
    <Var name="OptimizeMethods" value="true" />
  </Module>

  <!-- Infrastructure: NO rename (EF Core entity configurations + repositories) -->
  <Module file="$(InPath)\Tabsan.EduSphere.Infrastructure.dll">
    <Var name="HidePrivateApi" value="true" />
    <Var name="OptimizeMethods" value="true" />
  </Module>

  <Module file="$(InPath)\Tabsan.EduSphere.API.dll">
    <Var name="RenameFields" value="true" />
    <Var name="HidePrivateApi" value="true" />
    <Var name="OptimizeMethods" value="true" />
  </Module>

  <Module file="$(InPath)\Tabsan.EduSphere.Web.dll">
    <Var name="RenameFields" value="true" />
    <Var name="HidePrivateApi" value="true" />
    <Var name="OptimizeMethods" value="true" />
  </Module>

  <Module file="$(InPath)\Tabsan.EduSphere.BackgroundJobs.dll">
    <Var name="RenameFields" value="true" />
    <Var name="HidePrivateApi" value="true" />
    <Var name="OptimizeMethods" value="true" />
  </Module>

</Obfuscator>
