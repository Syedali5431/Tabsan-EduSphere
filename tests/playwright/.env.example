# ── EduSphere Playwright Test Environment ──
# Copy this file to .env and fill in your values.

# Base URLs
BASE_URL=http://localhost:5063
API_BASE_URL=http://localhost:5181

# Super Admin credentials (has access to everything)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=

# Admin credentials (institution-level)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Faculty credentials
FACULTY_USERNAME=faculty01@tabsan.edu
FACULTY_PASSWORD=

# Student credentials
STUDENT_USERNAME=student01@tabsan.edu
STUDENT_PASSWORD=

# Finance role credentials
FINANCE_USERNAME=finance01@tabsan.edu
FINANCE_PASSWORD=

# MFA test user (must have MFA enabled)
MFA_USERNAME=mfa-user@tabsan.edu
MFA_PASSWORD=
# Use a known TOTP secret encoded in Base32 for deterministic MFA tests
# Generate with: npx playwright test --grep @mfa-setup to set up
MFA_TOTP_SECRET=

# Test institution/department/course IDs (must exist in seeded data)
TEST_INSTITUTION_ID=
TEST_DEPARTMENT_ID=
TEST_COURSE_ID=
TEST_SEMESTER_ID=

# Test timeout overrides (milliseconds)
TEST_TIMEOUT=60000
EXPECT_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000

# Screenshot on failure
SCREENSHOT_ON_FAILURE=true

# Parallel workers (0 = auto)
WORKERS=2

# Retry count for flaky tests
RETRIES=1
