{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "NOT_SET_USE_ENVIRONMENT_OVERRIDE"
  },
  "InfrastructureTuning": {
    "AutoScaling": {
      "Enabled": true,
      "MinReplicas": 1,
      "MaxReplicas": 6
    },
    "HostLimits": {
      "ThreadPoolMinWorkerThreads": 96,
      "ThreadPoolMinCompletionPortThreads": 96
    },
    "NetworkStack": {
      "OutboundMaxConnectionsPerServer": 256,
      "OutboundConnectTimeoutSeconds": 10
    }
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere Background Jobs",
    "AppVersion": "1.0.0"
  },
  "Deployment": {
    "Mode": "SingleInstance",
    "CustomerCode": "",
    "CustomerName": "",
    "CustomerDomain": "",
    "Database": {
      "Name": "",
      "ConnectionString": ""
    },
    "Scaling": {
      "Enabled": true,
      "MinReplicas": 1,
      "MaxReplicas": 1
    },
    "TenantIsolation": {
      "Enabled": false,
      "Mode": "Shared",
      "TenantCode": "",
      "TenantName": "",
      "TenantDomain": "",
      "TenantDatabaseName": "",
      "ConfigPath": "",
      "IsolationStrategy": "SharedConfig"
    }
  }
}
