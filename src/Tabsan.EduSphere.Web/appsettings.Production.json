{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5063"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EduApi": {
    "BaseUrl": "http://localhost:5181"
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere Web",
    "AppVersion": "1.0.0",
    "WebBaseUrl": "http://localhost:5063"
  },
  "Deployment": {
    "Mode": "MultiInstance",
    "CustomerCode": "",
    "CustomerName": "",
    "CustomerDomain": "",
    "Database": {
      "Name": "",
      "ConnectionString": ""
    },
    "Scaling": {
      "Enabled": true,
      "MinReplicas": 2,
      "MaxReplicas": 4
    },
    "TenantIsolation": {
      "Enabled": true,
      "Mode": "Isolated",
      "TenantCode": "",
      "TenantName": "",
      "TenantDomain": "",
      "TenantDatabaseName": "",
      "ConfigPath": "",
      "IsolationStrategy": "FileOverlay"
    }
  },
  "ScaleOut": {
    "SharedDataProtectionKeyRingPath": "REPLACE_WITH_SHARED_NETWORK_PATH_OR_MOUNT"
  },
  "InfrastructureTuning": {
    "AutoScaling": {
      "Enabled": true,
      "MinReplicas": 3,
      "MaxReplicas": 16
    },
    "HostLimits": {
      "ThreadPoolMinWorkerThreads": 224,
      "ThreadPoolMinCompletionPortThreads": 224,
      "MaxConcurrentConnections": 30000,
      "MaxConcurrentUpgradedConnections": 15000
    },
    "NetworkStack": {
      "KeepAliveTimeoutSeconds": 120,
      "RequestHeadersTimeoutSeconds": 15,
      "Http2KeepAlivePingDelaySeconds": 20,
      "Http2KeepAlivePingTimeoutSeconds": 10,
      "Http2MaxStreamsPerConnection": 300,
      "OutboundMaxConnectionsPerServer": 768,
      "OutboundConnectTimeoutSeconds": 8
    }
  },
  "StaticAssetCaching": {
    "Enabled": true,
    "MaxAgeSeconds": 86400
  },
  "ReverseProxy": {
    "Enabled": true,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": [ "127.0.0.1" ]
  }
}
