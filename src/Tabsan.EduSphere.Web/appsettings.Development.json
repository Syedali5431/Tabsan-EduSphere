{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere Web",
    "AppVersion": "1.0.0",
    "WebBaseUrl": "http://localhost:5063"
  },
  "InfrastructureTuning": {
    "AutoScaling": {
      "Enabled": true,
      "MinReplicas": 1,
      "MaxReplicas": 3
    },
    "HostLimits": {
      "ThreadPoolMinWorkerThreads": 96,
      "ThreadPoolMinCompletionPortThreads": 96,
      "MaxConcurrentConnections": 5000,
      "MaxConcurrentUpgradedConnections": 2500
    },
    "NetworkStack": {
      "KeepAliveTimeoutSeconds": 120,
      "RequestHeadersTimeoutSeconds": 20,
      "Http2KeepAlivePingDelaySeconds": 30,
      "Http2KeepAlivePingTimeoutSeconds": 10,
      "Http2MaxStreamsPerConnection": 200,
      "OutboundMaxConnectionsPerServer": 160,
      "OutboundConnectTimeoutSeconds": 10
    }
  },
  "StaticAssetCaching": {
    "Enabled": true,
    "MaxAgeSeconds": 3600
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=Tabsan-EduSphere;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;Min Pool Size=5;Max Pool Size=200;Connect Timeout=30"
  },
  "EduApi": {
    "BaseUrl": "https://localhost:7229"
  }
}
