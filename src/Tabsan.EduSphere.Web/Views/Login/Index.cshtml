@{
    ViewData["Title"] = "Login";
    Layout = null; // standalone page — no sidebar
    var error      = ViewData["Error"] as string;
    var returnUrl  = ViewData["ReturnUrl"] as string;
    var mfaEnabled = (ViewData["MfaEnabled"] as bool?) == true;
    var ssoEnabled = (ViewData["SsoEnabled"] as bool?) == true;
    var ssoProvider = ViewData["SsoProvider"] as string;
    var ssoLoginUrl = ViewData["SsoLoginUrl"] as string;
    var mfaPrivilegedOnly = (ViewData["MfaPrivilegedOnly"] as bool?) == true;
    var riskEnabled = (ViewData["SessionRiskEnabled"] as bool?) == true;
    var riskBlocking = (ViewData["SessionRiskBlocking"] as bool?) == true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Tabsan EduSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background: #f0f2f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .login-card { width: 100%; max-width: 420px; }
        .brand-header { text-align: center; margin-bottom: 2rem; }
        .brand-mark { display: inline-flex; align-items: center; justify-content: center;
                      width: 56px; height: 56px; border-radius: 14px; background: #0d6efd;
                      color: #fff; font-size: 1.5rem; font-weight: 700; margin-bottom: .75rem; }
    </style>
</head>
<body>
    <div class="login-card px-3">
        <div class="brand-header">
            <div class="brand-mark">TE</div>
            <h1 class="h4 fw-bold mb-0">Tabsan EduSphere</h1>
            <p class="text-muted small">Campus Portal</p>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h5 mb-4">Sign in to your account</h2>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger py-2 small" role="alert">@error</div>
                }

                @if (ssoEnabled)
                {
                    <div class="alert alert-primary py-2 small" role="alert">
                        Single sign-on is enabled@(string.IsNullOrWhiteSpace(ssoProvider) ? "" : $" ({ssoProvider})").
                        @if (!string.IsNullOrWhiteSpace(ssoLoginUrl))
                        {
                            <span> Use your organization's SSO entry point or <a href="@ssoLoginUrl" class="alert-link">continue via SSO</a>.</span>
                        }
                    </div>
                }

                @if (riskEnabled)
                {
                    <div class="alert alert-warning py-2 small" role="alert">
                        Session risk monitoring is active@(riskBlocking ? " (high-risk sign-ins are blocked)." : ".")
                    </div>
                }

                <form method="post" asp-action="Index" asp-controller="Login" asp-route-returnUrl="@returnUrl" autocomplete="on">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="username" class="form-label fw-semibold">Username</label>
                        <input id="username" name="username" type="text" class="form-control"
                               placeholder="e.g. superadmin" value="@(ViewData["Username"] as string)" autocomplete="username" required />
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label fw-semibold">Password</label>
                        <input id="password" name="password" type="password" class="form-control"
                               placeholder="Your password" autocomplete="current-password" required />
                    </div>

                    @if (mfaEnabled)
                    {
                        <div class="mb-4">
                            <label for="mfaCode" class="form-label fw-semibold">MFA Code</label>
                            <input id="mfaCode" name="mfaCode" type="text" class="form-control"
                                   placeholder="6-digit code" inputmode="numeric" autocomplete="one-time-code" autofocus />
                            <div class="form-text">
                                Your deployment requires an additional verification code@(mfaPrivilegedOnly ? " for privileged roles." : ".")
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100">Sign In</button>
                </form>
            </div>
        </div>

        <p class="text-center text-muted small mt-3">
            &copy; @DateTime.Now.Year Tabsan EduSphere
        </p>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
