        "accreditation" => ("Settings Related", 6),
        "tenant_management" => ("Settings Related", 6),
        "campus_management" => ("Settings Related", 6),
        "notifications" => ("Settings Related", 6),
        "helpdesk" => ("Settings Related", 6),

        _ => ("General", 9)
    };

    static bool IsUniversityOnlyAction(string action) => action.ToLowerInvariant() switch
    {
        "degreeaudit" => true,
        "graduationeligibility" => true,
        "degreerules" => true,
        "graduationapply" => true,
        "graduationapplications" => true,
        "fyp" => true,
        _ => false
    };

    // ── Final-Touches Phase 5 Stage 5.4 — Theme persistence across all pages ──────────
    // Fetches current user theme from API on every request; falls back to session cache.
    // Sets data-theme on the <html> element so CSS variables apply site-wide.
    const string ThemeCacheKey = "CurrentThemeCache";
    var themeCacheKey = $"{ThemeCacheKey}:{sessionId?.UserName ?? "anonymous"}";
    var currentTheme = "";
    if (isConnected)
    {
        try
        {
            var freshTheme = await EduApi.GetCurrentThemeAsync(CancellationToken.None);
            currentTheme = freshTheme ?? "";
            Context.Session.SetString(themeCacheKey, currentTheme);
        }
        catch
        {
            currentTheme = Context.Session.GetString(themeCacheKey) ?? "";
        }
    }
    else
    {
        currentTheme = Context.Session.GetString(themeCacheKey) ?? "";
    }
}

<!DOCTYPE html>
<html lang="en" @(string.IsNullOrEmpty(currentTheme) ? "" : Html.Raw($"data-theme=\"{currentTheme}\""))>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tabsan EduSphere — Campus management portal for academics, attendance, assignments, and more." />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <title>@ViewData["Title"] - Tabsan EduSphere</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tabsan.EduSphere.Web.styles.css" asp-append-version="true" />
    @if (!string.IsNullOrEmpty(branding.FontFamily) || !string.IsNullOrEmpty(branding.FontSize))
    {
        <style>
            :root {
                @if (!string.IsNullOrEmpty(branding.FontFamily)) { <text>--portal-font-family: @branding.FontFamily;</text> }
                @if (!string.IsNullOrEmpty(branding.FontSize))   { <text>--portal-font-size: @branding.FontSize;</text> }
            }
            body {
                @if (!string.IsNullOrEmpty(branding.FontFamily)) { <text>font-family: var(--portal-font-family) !important;</text> }
                @if (!string.IsNullOrEmpty(branding.FontSize))   { <text>font-size: var(--portal-font-size) !important;</text> }
            }
        </style>
    }
</head>
<body>
    @if (requiresLoginRedirect)
    {
        <script>window.location.replace('/Login?returnUrl=@loginReturnUrl');</script>
        <noscript>
            <meta http-equiv="refresh" content="0;url=/Login?returnUrl=@loginReturnUrl" />
        </noscript>
    }

    <a href="#main-content" class="skip-to-main visually-hidden-focusable">Skip to main content</a>
    <div class="page-loader" data-page-loader aria-hidden="true">
        <div class="page-loader-spinner"></div>
        <div class="page-loader-copy">Loading workspace</div>
    </div>
    <div class="app-shell">
        <aside class="app-sidebar" role="complementary" aria-label="Application sidebar" data-app-sidebar>
            <div class="app-sidebar-topbar d-lg-none">
                <button type="button" class="sidebar-toggle sidebar-toggle-inline" data-sidebar-close aria-label="Close navigation">
                    <span></span><span></span><span></span>
                </button>
            </div>
            <div class="brand-link" role="group" aria-label="@branding.UniversityName branding">
                @if (!string.IsNullOrEmpty(branding.LogoImage))
                {
                    <img src="@branding.LogoImage" alt="@branding.UniversityName logo" class="brand-logo" />
                }
                else
                {
                    <span class="brand-mark" aria-hidden="true">@brandInitials</span>
                }
                <div class="brand-meta">
                    <div class="brand-name">@branding.UniversityName</div>
                    <div class="brand-subtitle">@branding.PortalSubtitle</div>
                    <span class="brand-tag">Institution Hub</span>
                </div>
            </div>

            <nav class="sidebar-nav" role="navigation" aria-label="Main navigation">
