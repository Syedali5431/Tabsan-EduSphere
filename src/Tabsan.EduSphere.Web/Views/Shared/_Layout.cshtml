        "timetableadmin" or "timetablestudent" or "timetableteacher" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M7 2v2H5a2 2 0 0 0-2 2v13a3 3 0 0 0 3 3h12a3 3 0 0 0 3-3V6a2 2 0 0 0-2-2h-2V2h-2v2H9V2H7Zm12 7H5v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9Z\" fill=\"currentColor\"/></svg>",
        "students" or "userimport" or "adminusers" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M16 11a4 4 0 1 0-3.999-4A4 4 0 0 0 16 11ZM8 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm8 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4ZM8 14c-.29 0-.62.02-.97.05C4.64 14.3 0 15.47 0 18v2h6v-2c0-1.51.8-2.82 2.29-3.8A8.7 8.7 0 0 0 8 14Z\" fill=\"currentColor\"/></svg>",
        "departments" or "programs" or "courses" or "prerequisites" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 3 1 9l11 6 9-4.91V17h2V9L12 3Zm0 14L5.5 13.45V17L12 21l6.5-4v-3.55L12 17Z\" fill=\"currentColor\"/></svg>",
        "assignments" or "quizzes" or "viewquizzes" or "results" or "gradebook" or "gradingconfig" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2ZM9 17H7v-2h2Zm0-4H7v-2h2Zm0-4H7V7h2Zm8 8h-6v-2h6Zm0-4h-6v-2h6Zm0-4h-6V7h6Z\" fill=\"currentColor\"/></svg>",
        "attendance" or "analytics" or "reportcenter" or "reportsettings" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M5 9.2h3V19H5V9.2Zm5.5-4.7h3V19h-3V4.5ZM16 12h3v7h-3v-7Z\" fill=\"currentColor\"/></svg>",
        "payments" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M21 5H3a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 4H3V7h18Zm-6 6H5v-2h10Z\" fill=\"currentColor\"/></svg>",
        "notifications" or "announcements" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Zm7-6V11a7 7 0 1 0-14 0v5l-2 2v1h18v-1l-2-2Z\" fill=\"currentColor\"/></svg>",
        "helpdesk" or "discussion" or "aichat" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H8l-4 4V6a2 2 0 0 1 2-2Z\" fill=\"currentColor\"/></svg>",
        "licenseupdate" or "themesettings" or "sidebarsettings" or "dashboardsettings" or "usersettings" or "institutionpolicy" or "modulecomposition" or "libraryconfig" or "accreditationtemplates" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"m19.14 12.94.04-.94-.04-.94 2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.48 7.48 0 0 0-1.63-.94L14.5 2.5a.5.5 0 0 0-.49-.4h-4.02a.5.5 0 0 0-.49.4l-.36 2.58c-.58.23-1.12.54-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.2 8.6a.5.5 0 0 0 .12.64l2.03 1.58-.04.94.04.94L2.32 14.28a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .6.22l2.39-.96c.5.4 1.05.72 1.63.94l.36 2.58a.5.5 0 0 0 .49.4h4.02a.5.5 0 0 0 .49-.4l.36-2.58c.58-.23 1.12-.54 1.63-.94l2.39.96a.5.5 0 0 0 .6-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58ZM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5Z\" fill=\"currentColor\"/></svg>",
        "twofactorsettings" => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 2 3 6v6c0 5 3.8 9.7 9 10 5.2-.3 9-5 9-10V6l-9-4Zm0 4a3 3 0 0 1 3 3v1h1a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1v-5a1 1 0 0 1 1-1h1V9a3 3 0 0 1 3-3Zm0 2a1 1 0 0 0-1 1v1h2V9a1 1 0 0 0-1-1Z\" fill=\"currentColor\"/></svg>",
        _ => "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"5\" fill=\"currentColor\"/></svg>"
    };

    var currentPath = Context.Request.Path.Value ?? string.Empty;
    bool IsActiveLink(string controller, string action) =>
        currentController.Equals(controller, StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals(action, StringComparison.OrdinalIgnoreCase);

    static (string Group, int SortOrder) ResolveGroup(string key) => key switch
    {
        "dashboard" => ("Overview", 1),

        "timetable_admin" => ("Faculty Related", 2),
        "timetable_teacher" => ("Faculty Related", 2),
        "assignments" => ("Faculty Related", 2),
        "enter_attendance" => ("Faculty Related", 2),
        "enter_results" => ("Faculty Related", 2),
        "gradebook"     => ("Faculty Related", 2),
        "rubric_manage" => ("Faculty Related", 2),
        "lms_manage"    => ("Faculty Related", 2),
        "course_material" => ("Faculty Related", 2),
        "discussion"    => ("Faculty Related", 2),
        "announcements" => ("Faculty Related", 2),

        "timetable_student" => ("Student Related", 3),
        "students" => ("Faculty Related", 2),
        "attendance" => ("Student Related", 3),
        "results" => ("Student Related", 3),
        "view_quizzes" => ("Student Related", 3),
        "quizzes" => ("Faculty Related", 2),
        "fyp" => ("Student Related", 3),
        "student_lifecycle" => ("Student Related", 3),
        "enrollments" => ("Student Related", 3),

        "program" => ("Academic Related", 4),
        "programs" => ("Academic Related", 4),
        "departments" => ("Academic Related", 4),
        "courses" => ("Academic Related", 4),
        "prerequisites" => ("Academic Related", 4),
        "degree_audit" => ("Academic Related", 4),
        "graduation_eligibility" => ("Academic Related", 4),
        "degree_rules" => ("Academic Related", 4),
        "graduation_apply" => ("Academic Related", 4),
        "graduation_applications" => ("Academic Related", 4),
        "generate_certificates" => ("Academic Related", 4),
        "grading_config" => ("Academic Related", 4),
        "study_plan" => ("Academic Related", 4),
        "result_calculation" => ("Academic Related", 4),

        "payments" => ("Financial Related", 5),

        "admin_users" => ("Settings Related", 6),
        "user_import" => ("Settings Related", 6),
        "buildings" => ("Settings Related", 6),
        "rooms" => ("Settings Related", 6),
        "analytics" => ("Settings Related", 6),
        "report_center" => ("Settings Related", 6),
        "user_settings" => ("Settings Related", 6),
        "report_settings" => ("Settings Related", 6),
        "sidebar_settings" => ("Settings Related", 6),
        "theme_settings" => ("Settings Related", 6),
        "license_update" => ("Settings Related", 6),
        "dashboard_settings" => ("Settings Related", 6),
        "institution_policy" => ("Settings Related", 6),
        "module_composition" => ("Settings Related", 6),
