@inject Tabsan.EduSphere.Web.Services.IEduApiClient EduApi
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var skipAuthCheck = currentController.Equals("Login", StringComparison.OrdinalIgnoreCase)
                     || currentController.Equals("Home", StringComparison.OrdinalIgnoreCase);

    // Avoid redirect-return from layout (it can break Razor rendering with "RenderBody has not been called").
    var requiresLoginRedirect = !skipAuthCheck && !EduApi.IsConnected();
    var loginReturnUrl = Uri.EscapeDataString(Context.Request.Path + Context.Request.QueryString);

    var principal   = User;
    var aspNetAuth  = principal?.Identity?.IsAuthenticated ?? false;

    // Prefer JWT claims decoded at connection-save time; fall back to ASP.NET identity.
    var sessionId   = EduApi.GetSessionIdentity();
    var isAdmin     = (sessionId?.IsAdmin ?? false) || (aspNetAuth && (principal!.IsInRole("Admin") || principal.IsInRole("SuperAdmin")));
    var isSuperAdmin = (sessionId?.IsSuperAdmin ?? false) || (aspNetAuth && principal!.IsInRole("SuperAdmin"));
    var isFaculty   = (sessionId?.IsFaculty ?? false) || (aspNetAuth && principal!.IsInRole("Faculty"));
    var isStudent   = (sessionId?.IsStudent ?? false) || (aspNetAuth && principal!.IsInRole("Student"));

    // Connected but no roles resolved yet: show all links (dev/integration convenience).
    var isConnected = EduApi.IsConnected();
    var noRoles     = isConnected && sessionId is null;
    var showAdminLinks      = isAdmin      || isSuperAdmin || noRoles;
    var showFacultyLinks    = isFaculty    || noRoles;
    var showStudentLinks    = isStudent    || noRoles;
    var showSuperAdminLinks = isSuperAdmin || noRoles;

    var studentSemesterNumber = 0;
    if (isConnected && isStudent)
    {
        try
        {
            studentSemesterNumber = (await EduApi.GetMyStudentProfileAsync(CancellationToken.None))?.CurrentSemesterNumber ?? 0;
        }
        catch
        {
            studentSemesterNumber = 0;
        }
    }
    var canStudentSeeFyp = !isStudent || studentSemesterNumber >= 8;

    // Display name for header
    var displayName = sessionId?.UserName ?? (aspNetAuth ? principal!.Identity!.Name : null) ?? "Guest";

    const string SidebarCacheKey = "VisibleSidebarMenusCache";

    // Resolve visible sidebar menu structure from API (role + status aware).
    var visibleMenus = new List<Tabsan.EduSphere.Web.Models.Portal.SidebarMenuItemWebModel>();
    if (isConnected)
    {
        try
        {
            visibleMenus = await EduApi.GetVisibleSidebarMenusForCurrentUserAsync(CancellationToken.None);
            if (visibleMenus.Count > 0)
            {
                Context.Session.SetString(SidebarCacheKey, System.Text.Json.JsonSerializer.Serialize(visibleMenus));
            }
            else
            {
                var cached = Context.Session.GetString(SidebarCacheKey);
                if (!string.IsNullOrWhiteSpace(cached))
                {
                    visibleMenus = System.Text.Json.JsonSerializer.Deserialize<List<Tabsan.EduSphere.Web.Models.Portal.SidebarMenuItemWebModel>>(cached) ?? new();
                }
            }
        }
        catch
        {
            var cached = Context.Session.GetString(SidebarCacheKey);
            if (!string.IsNullOrWhiteSpace(cached))
            {
                visibleMenus = System.Text.Json.JsonSerializer.Deserialize<List<Tabsan.EduSphere.Web.Models.Portal.SidebarMenuItemWebModel>>(cached) ?? new();
            }
        }
    }

    var useDynamicMenus = visibleMenus.Count > 0;
    var hasAiChatMenu = visibleMenus.Any(m =>
        string.Equals(m.Key, "ai_chat", StringComparison.OrdinalIgnoreCase)
        || m.SubMenus.Any(s => string.Equals(s.Key, "ai_chat", StringComparison.OrdinalIgnoreCase)));
    var hasAdminLikeDynamicMenu = visibleMenus.Any(m =>
        string.Equals(m.Key, "students", StringComparison.OrdinalIgnoreCase)
        || string.Equals(m.Key, "user_import", StringComparison.OrdinalIgnoreCase)
        || string.Equals(m.Key, "programs", StringComparison.OrdinalIgnoreCase)
        || string.Equals(m.Key, "departments", StringComparison.OrdinalIgnoreCase)
        || m.SubMenus.Any(s =>
            string.Equals(s.Key, "students", StringComparison.OrdinalIgnoreCase)
            || string.Equals(s.Key, "user_import", StringComparison.OrdinalIgnoreCase)
            || string.Equals(s.Key, "programs", StringComparison.OrdinalIgnoreCase)
            || string.Equals(s.Key, "departments", StringComparison.OrdinalIgnoreCase)));
    var showAiChatLauncher = isConnected && (!useDynamicMenus || hasAiChatMenu || showAdminLinks || hasAdminLikeDynamicMenu);

    // Load portal branding (university name, initials, subtitle, footer)
    const string BrandingCacheKey = "PortalBrandingCache";
    var branding = new Tabsan.EduSphere.Web.Models.Portal.PortalBrandingWebModel();
    if (isConnected)
    {
        try
        {
            var freshBranding = await EduApi.GetPortalBrandingAsync(CancellationToken.None);
            branding = freshBranding;
            Context.Session.SetString(BrandingCacheKey, System.Text.Json.JsonSerializer.Serialize(branding));
        }
        catch
        {
            var cachedBranding = Context.Session.GetString(BrandingCacheKey);
            if (!string.IsNullOrWhiteSpace(cachedBranding))
                branding = System.Text.Json.JsonSerializer.Deserialize<Tabsan.EduSphere.Web.Models.Portal.PortalBrandingWebModel>(cachedBranding) ?? branding;
        }
    }
    else
    {
        var cachedBranding = Context.Session.GetString(BrandingCacheKey);
        if (!string.IsNullOrWhiteSpace(cachedBranding))
            branding = System.Text.Json.JsonSerializer.Deserialize<Tabsan.EduSphere.Web.Models.Portal.PortalBrandingWebModel>(cachedBranding) ?? branding;
    }

    static (string Controller, string Action)? ResolveRoute(string key) => key switch
    {
        "dashboard"         => ("Portal", "Dashboard"),
        "timetable_admin"   => ("Portal", "TimetableAdmin"),
        "timetable_student" => ("Portal", "TimetableStudent"),
        "timetable_teacher" => ("Portal", "TimetableTeacher"),
        "buildings"         => ("Portal", "Buildings"),
        "rooms"             => ("Portal", "Rooms"),
        "report_settings"   => ("Portal", "ReportSettings"),
        "result_calculation" => ("Portal", "ResultCalculation"),
        "sidebar_settings"  => ("Portal", "SidebarSettings"),
        "license_update"    => ("Portal", "LicenseUpdate"),
        "theme_settings"    => ("Portal", "ThemeSettings"),
        "notifications"     => ("Portal", "Notifications"),
        "students"          => ("Portal", "Students"),
        "user_import"       => ("Portal", "UserImport"),
        "program"           => ("Portal", "Programs"),
        "departments"       => ("Portal", "Departments"),
        "programs"          => ("Portal", "Programs"),
        "admin_users"       => ("Portal", "AdminUsers"),
        "courses"           => ("Portal", "Courses"),
        "assignments"       => ("Portal", "Assignments"),
        "attendance"        => ("Portal", "Attendance"),
        "results"           => ("Portal", "Results"),
        "quizzes"           => ("Portal", "Quizzes"),
        "fyp"               => ("Portal", "Fyp"),
        "helpdesk"          => ("Portal", "Helpdesk"),
        "prerequisites"     => ("Portal", "Prerequisites"),
        "gradebook"         => ("Portal", "Gradebook"),
        "rubric_manage"     => ("Portal", "RubricManage"),
        "analytics"         => ("Portal", "Analytics"),
        "ai_chat"           => ("Portal", "AiChat"),
        "student_lifecycle" => ("Portal", "StudentLifecycle"),
        "payments"          => ("Portal", "Payments"),
        "enrollments"       => ("Portal", "Enrollments"),
        "report_center"     => ("Portal", "ReportCenter"),
        "dashboard_settings" => ("Portal", "DashboardSettings"),
        // Final-Touches Phase 17 Stage 17.1/17.2 — degree audit system sidebar links
        "degree_audit"            => ("Portal", "DegreeAudit"),
        "graduation_eligibility"  => ("Portal", "GraduationEligibility"),
        "degree_rules"            => ("Portal", "DegreeRules"),
        // Final-Touches Phase 18 Stage 18.1/18.2 — graduation workflow sidebar links
        "graduation_apply"        => ("Portal", "GraduationApply"),
        "graduation_applications" => ("Portal", "GraduationApplications"),
        // Final-Touches Phase 19 Stage 19.4
        "grading_config" => ("Portal", "GradingConfig"),
        // Final-Touches Phase 20 Stage 20.1/20.2/20.3/20.4 — LMS sidebar links
        "lms_manage"   => ("Portal", "LmsManage"),
        "discussion"   => ("Portal", "Discussion"),
        "announcements" => ("Portal", "Announcements"),
        // Final-Touches Phase 21 Stage 21.1/21.2 — Study Planner sidebar link
        "study_plan" => ("Portal", "StudyPlan"),
        // Final-Touches Phase 22 — External Integrations sidebar links
        "library_config" => ("Portal", "LibraryConfig"),
        "accreditation"  => ("Portal", "AccreditationTemplates"),
        // Phase 23 — Institution Policy
        "institution_policy" => ("Portal", "InstitutionPolicy"),
        // Phase 24 — Module Composition
        "module_composition" => ("Portal", "ModuleComposition"),
        _                    => null
    };

    static (string Group, int SortOrder) ResolveGroup(string key) => key switch
    {
        "dashboard" => ("Overview", 1),

        "timetable_admin" => ("Faculty Related", 2),
        "timetable_teacher" => ("Faculty Related", 2),
        "buildings" => ("Faculty Related", 2),
        "rooms" => ("Faculty Related", 2),
        "departments" => ("Faculty Related", 2),
        "program" => ("Faculty Related", 2),
        "programs" => ("Faculty Related", 2),
        "admin_users" => ("Faculty Related", 2),
        "courses" => ("Faculty Related", 2),
        "assignments" => ("Faculty Related", 2),
        "analytics" => ("Faculty Related", 2),
        "report_center" => ("Faculty Related", 2),
        "enrollments" => ("Faculty Related", 2),

        "timetable_student" => ("Student Related", 3),
        "students" => ("Student Related", 3),
        "user_import" => ("Faculty Related", 2),
        "attendance" => ("Student Related", 3),
        "results" => ("Student Related", 3),
        "quizzes" => ("Student Related", 3),
        "fyp" => ("Student Related", 3),
        "helpdesk" => ("Student Related", 3),
        "prerequisites" => ("Academic Related", 2),
        "gradebook"     => ("Faculty Related", 2),
        "rubric_manage" => ("Faculty Related", 2),
        "student_lifecycle" => ("Student Related", 3),

        "payments" => ("Finance Related", 4),

        // Final-Touches Phase 17 Stage 17.1/17.2 — degree audit groups
        "degree_audit"           => ("Student Related", 3),
        "graduation_eligibility" => ("Academic Related", 2),
        "degree_rules"           => ("Academic Related", 2),
        // Final-Touches Phase 18 Stage 18.1/18.2 — graduation workflow groups
        "graduation_apply"        => ("Student Related", 3),
        "graduation_applications" => ("Academic Related", 2),
        "grading_config" => ("Academic Related", 2),
        // Final-Touches Phase 20 Stage 20.1/20.2/20.3/20.4 — LMS groups
        "lms_manage"    => ("Academic Related", 2),
        "discussion"    => ("Academic Related", 2),
        "announcements" => ("Academic Related", 2),
        // Final-Touches Phase 21 Stage 21.1/21.2 — Study Planner group
        "study_plan" => ("Student Related", 3),
        // Final-Touches Phase 22 — External Integrations group
        "library_config" => ("Settings", 5),
        "accreditation"  => ("Settings", 5),
        // Phase 23 — Institution Policy
        "institution_policy" => ("Settings", 5),
        // Phase 24 — Module Composition
        "module_composition" => ("Settings", 5),

        "report_settings" => ("Settings", 5),
        "sidebar_settings" => ("Settings", 5),
        "theme_settings" => ("Settings", 5),
        "license_update" => ("Settings", 5),
        "result_calculation" => ("Settings", 5),
        "notifications"       => ("Settings", 5),
        "dashboard_settings"  => ("Settings", 5),

        _ => ("General", 9)
    };

    // ── Final-Touches Phase 5 Stage 5.4 — Theme persistence across all pages ──────────
    // Fetches current user theme from API on every request; falls back to session cache.
    // Sets data-theme on the <html> element so CSS variables apply site-wide.
    const string ThemeCacheKey = "CurrentThemeCache";
    var currentTheme = "";
    if (isConnected)
    {
        try
        {
            var freshTheme = await EduApi.GetCurrentThemeAsync(CancellationToken.None);
            currentTheme = freshTheme ?? "";
            Context.Session.SetString(ThemeCacheKey, currentTheme);
        }
        catch
        {
            currentTheme = Context.Session.GetString(ThemeCacheKey) ?? "";
        }
    }
    else
    {
        currentTheme = Context.Session.GetString(ThemeCacheKey) ?? "";
    }
}

<!DOCTYPE html>
<html lang="en" @(string.IsNullOrEmpty(currentTheme) ? "" : Html.Raw($"data-theme=\"{currentTheme}\""))>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tabsan EduSphere — Campus management portal for academics, attendance, assignments, and more." />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <title>@ViewData["Title"] - Tabsan EduSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tabsan.EduSphere.Web.styles.css" asp-append-version="true" />
    @if (!string.IsNullOrEmpty(branding.FontFamily) || !string.IsNullOrEmpty(branding.FontSize))
    {
        <style>
            :root {
                @if (!string.IsNullOrEmpty(branding.FontFamily)) { <text>--portal-font-family: @branding.FontFamily;</text> }
                @if (!string.IsNullOrEmpty(branding.FontSize))   { <text>--portal-font-size: @branding.FontSize;</text> }
            }
            body {
                @if (!string.IsNullOrEmpty(branding.FontFamily)) { <text>font-family: var(--portal-font-family) !important;</text> }
                @if (!string.IsNullOrEmpty(branding.FontSize))   { <text>font-size: var(--portal-font-size) !important;</text> }
            }
        </style>
    }
</head>
<body>
    @if (requiresLoginRedirect)
    {
        <script>window.location.replace('/Login?returnUrl=@loginReturnUrl');</script>
        <noscript>
            <meta http-equiv="refresh" content="0;url=/Login?returnUrl=@loginReturnUrl" />
        </noscript>
    }

    <a href="#main-content" class="skip-to-main visually-hidden-focusable">Skip to main content</a>
    <div class="app-shell">
        <aside class="app-sidebar" role="complementary" aria-label="Application sidebar">
            <div class="brand-link" role="group" aria-label="@branding.UniversityName branding">
                @if (!string.IsNullOrEmpty(branding.LogoImage))
                {
                    <img src="@branding.LogoImage" alt="@branding.UniversityName logo" class="brand-logo" style="height:40px;width:40px;object-fit:contain;border-radius:6px;" />
                }
                else
                {
                    <span class="brand-mark"><i class="bi bi-image"></i></span>
                }
                <div>
                    <div class="brand-name">@branding.UniversityName</div>
                    <div class="brand-subtitle">@branding.PortalSubtitle</div>
                </div>
            </div>

            <nav class="sidebar-nav" role="navigation" aria-label="Main navigation">
                @if (useDynamicMenus)
                {
                    var groupedLinks = new List<(string Group, int GroupSort, int ItemSort, string Name, string Controller, string Action)>();

                    foreach (var top in visibleMenus.OrderBy(m => m.DisplayOrder))
                    {
                        var subMenus = top.SubMenus.OrderBy(s => s.DisplayOrder).ToList();

                        if (subMenus.Count > 0)
                        {
                            foreach (var sub in subMenus)
                            {
                                if (sub.Key.Equals("ai_chat", StringComparison.OrdinalIgnoreCase))
                                {
                                    continue;
                                }

                                if (isStudent && !canStudentSeeFyp && sub.Key.Equals("fyp", StringComparison.OrdinalIgnoreCase))
                                {
                                    continue;
                                }

                                var subRoute = ResolveRoute(sub.Key);
                                if (subRoute is null) { continue; }
                                var subGroup = ResolveGroup(sub.Key);
                                groupedLinks.Add((subGroup.Group, subGroup.SortOrder, (top.DisplayOrder * 100) + sub.DisplayOrder, sub.Name, subRoute.Value.Controller, subRoute.Value.Action));
                            }
                        }
                        else
                        {
                            if (top.Key.Equals("ai_chat", StringComparison.OrdinalIgnoreCase))
                            {
                                continue;
                            }

                            if (isStudent && !canStudentSeeFyp && top.Key.Equals("fyp", StringComparison.OrdinalIgnoreCase))
                            {
                                continue;
                            }

                            var topRoute = ResolveRoute(top.Key);
                            if (topRoute is null) { continue; }
                            var topGroup = ResolveGroup(top.Key);
                            groupedLinks.Add((topGroup.Group, topGroup.SortOrder, top.DisplayOrder * 100, top.Name, topRoute.Value.Controller, topRoute.Value.Action));
                        }
                    }

                    var hasStudentsLink = groupedLinks.Any(l =>
                        l.Controller.Equals("Portal", StringComparison.OrdinalIgnoreCase)
                        && l.Action.Equals("Students", StringComparison.OrdinalIgnoreCase));

                    var hasProgramsLink = groupedLinks.Any(l =>
                        l.Controller.Equals("Portal", StringComparison.OrdinalIgnoreCase)
                        && l.Action.Equals("Programs", StringComparison.OrdinalIgnoreCase));
                    if ((showAdminLinks || hasStudentsLink) && !hasProgramsLink)
                    {
                        groupedLinks.Add(("Faculty Related", 2, 2500, "Programs", "Portal", "Programs"));
                    }

                    var hasUserImportLink = groupedLinks.Any(l =>
                        l.Controller.Equals("Portal", StringComparison.OrdinalIgnoreCase)
                        && l.Action.Equals("UserImport", StringComparison.OrdinalIgnoreCase));
                    if ((showAdminLinks || hasStudentsLink) && !hasUserImportLink)
                    {
                        groupedLinks.Add(("Faculty Related", 2, 2510, "User Import", "Portal", "UserImport"));
                    }

                    if (isSuperAdmin)
                    {
                        var superAdminFallbackLinks = new[]
                        {
                            ("Faculty Related", 2, 2600, "Report Center", "Portal", "ReportCenter"),
                            ("Faculty Related", 2, 2610, "Analytics", "Portal", "Analytics"),
                            ("Academic Related", 2, 2620, "Degree Audit", "Portal", "DegreeAudit"),
                            ("Academic Related", 2, 2630, "Graduation Eligibility", "Portal", "GraduationEligibility"),
                            ("Academic Related", 2, 2640, "Degree Rules", "Portal", "DegreeRules"),
                            ("Academic Related", 2, 2650, "Graduation Apply", "Portal", "GraduationApply"),
                            ("Academic Related", 2, 2660, "Graduation Applications", "Portal", "GraduationApplications"),
                            ("Academic Related", 2, 2670, "Grading Config", "Portal", "GradingConfig"),
                            ("Academic Related", 2, 2680, "LMS Manage", "Portal", "LmsManage"),
                            ("Academic Related", 2, 2690, "Discussion", "Portal", "Discussion"),
                            ("Academic Related", 2, 2700, "Announcements", "Portal", "Announcements"),
                            ("Student Related", 3, 2710, "Study Plan", "Portal", "StudyPlan"),
                            ("Settings", 5, 2720, "Report Settings", "Portal", "ReportSettings"),
                            ("Settings", 5, 2730, "Sidebar Settings", "Portal", "SidebarSettings"),
                            ("Settings", 5, 2740, "Theme Settings", "Portal", "ThemeSettings"),
                            ("Settings", 5, 2750, "License Update", "Portal", "LicenseUpdate"),
                            ("Settings", 5, 2760, "Dashboard Settings", "Portal", "DashboardSettings"),
                            ("Settings", 5, 2770, "Institution Policy", "Portal", "InstitutionPolicy"),
                            ("Settings", 5, 2780, "Module Composition", "Portal", "ModuleComposition"),
                            ("Settings", 5, 2790, "Library Config", "Portal", "LibraryConfig"),
                            ("Settings", 5, 2800, "Accreditation", "Portal", "AccreditationTemplates")
                        };

                        foreach (var link in superAdminFallbackLinks)
                        {
                            var exists = groupedLinks.Any(l =>
                                l.Controller.Equals(link.Item5, StringComparison.OrdinalIgnoreCase)
                                && l.Action.Equals(link.Item6, StringComparison.OrdinalIgnoreCase));
                            if (!exists)
                            {
                                groupedLinks.Add(link);
                            }
                        }
                    }

                    foreach (var group in groupedLinks
                        .OrderBy(l => l.GroupSort)
                        .ThenBy(l => l.ItemSort)
                        .GroupBy(l => l.Group))
                    {
                        <div class="menu-label">@group.Key</div>
                        foreach (var link in group)
                        {
                            <a class="menu-link" asp-controller="@link.Controller" asp-action="@link.Action">@link.Name</a>
                        }
                    }
                }
                else
                {
                    <div class="menu-label">Overview</div>
                    <a class="menu-link" asp-controller="Portal" asp-action="Dashboard">Dashboard</a>

                    <div class="menu-label">Timetable</div>
                    @if (showAdminLinks)
                    {
                        <a class="menu-link" asp-controller="Portal" asp-action="TimetableAdmin">Manage Timetables</a>
                    }

                    @if (showStudentLinks)
                    {
                        <a class="menu-link" asp-controller="Portal" asp-action="TimetableStudent">Student Timetable</a>
                    }

                    @if (showFacultyLinks)
                    {
                        <a class="menu-link" asp-controller="Portal" asp-action="TimetableTeacher">Teacher Timetable</a>
                    }

                    @if (showAdminLinks)
                    {
                        <div class="menu-label">Lookups</div>
                        <a class="menu-link" asp-controller="Portal" asp-action="Buildings">Buildings</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="Rooms">Rooms</a>
                    }

                    <div class="menu-label">Notifications</div>
                    <a class="menu-link" asp-controller="Portal" asp-action="Notifications">Inbox</a>

                    @if (showAdminLinks || showFacultyLinks)
                    {
                        <div class="menu-label">Academic Management</div>
                        @if (showAdminLinks)
                        {
                            <a class="menu-link" asp-controller="Portal" asp-action="Students">Students</a>
                            <a class="menu-link" asp-controller="Portal" asp-action="UserImport">User Import</a>
                            <a class="menu-link" asp-controller="Portal" asp-action="Departments">Departments</a>
                            <a class="menu-link" asp-controller="Portal" asp-action="Programs">Programs</a>
                        }
                        <a class="menu-link" asp-controller="Portal" asp-action="Courses">Courses</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="Enrollments">Enrollments</a>
                    }

                    <div class="menu-label">Learning</div>
                    <a class="menu-link" asp-controller="Portal" asp-action="Assignments">Assignments</a>
                    <a class="menu-link" asp-controller="Portal" asp-action="Attendance">Attendance</a>
                    <a class="menu-link" asp-controller="Portal" asp-action="Results">Results</a>
                    <a class="menu-link" asp-controller="Portal" asp-action="Quizzes">Quizzes</a>
                    @if (canStudentSeeFyp)
                    {
                        <a class="menu-link" asp-controller="Portal" asp-action="Fyp">FYP</a>
                    }
                    <a class="menu-link" asp-controller="Portal" asp-action="Helpdesk">Helpdesk</a>

                    @if (showAdminLinks)
                    {
                        <a class="menu-link" asp-controller="Portal" asp-action="Prerequisites">Prerequisites</a>
                    }

                    @* Final-Touches Phase 16 Stage 16.1 — Gradebook sidebar link (Faculty/Admin) *@
                    @if (showFacultyLinks || showAdminLinks)
                    {
                        <a class="menu-link" asp-controller="Portal" asp-action="Gradebook">Gradebook</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="RubricManage">Rubric Management</a>
                    }

                    @if (showAdminLinks || showFacultyLinks)
                    {
                        <div class="menu-label">Admin Tools</div>
                        <a class="menu-link" asp-controller="Portal" asp-action="Analytics">Analytics</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="ReportCenter">Report Center</a>
                        @if (showAdminLinks)
                        {
                            <a class="menu-link" asp-controller="Portal" asp-action="ResultCalculation">Result Calculation</a>
                            <a class="menu-link" asp-controller="Portal" asp-action="StudentLifecycle">Student Lifecycle</a>
                            <a class="menu-link" asp-controller="Portal" asp-action="Payments">Payments</a>
                        }
                    }

                    @if (showSuperAdminLinks)
                    {
                        <div class="menu-label">System Settings</div>
                        <a class="menu-link" asp-controller="Portal" asp-action="ReportSettings">Report Settings</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="SidebarSettings">Sidebar Settings</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="LicenseUpdate">License Update</a>
                        <a class="menu-link" asp-controller="Portal" asp-action="ThemeSettings">Theme Settings</a>
                    }
                }

                <div class="menu-label">General</div>
                <a class="menu-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </nav>
        </aside>

        <section class="app-main">
            <header class="app-header" role="banner">
                <h1 class="page-title">@ViewData["Title"]</h1>

                @* Phase 13 — Global Search bar (visible only when connected) *@
                @if (isConnected)
                {
                    <div class="global-search-wrapper position-relative me-3" style="min-width:260px;">
                        <form asp-controller="Portal" asp-action="Search" method="get" autocomplete="off" class="d-flex" role="search">
                            <div class="input-group input-group-sm">
                                <input id="globalSearchInput" name="q" type="search"
                                       class="form-control" placeholder="Search…"
                                       aria-label="Global search" minlength="2" />
                                <button class="btn btn-outline-secondary" type="submit" aria-label="Search">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </form>
                        <ul id="searchTypeahead"
                            class="dropdown-menu w-100 py-1 shadow-sm"
                            style="display:none; position:absolute; top:100%; left:0; z-index:1050;">
                        </ul>
                    </div>
                }

                <div class="auth-chip d-flex align-items-center gap-2">
                    <span>
                        @displayName
                        @if (sessionId?.Roles.Count > 0)
                        {
                            <span class="badge bg-secondary ms-1">@string.Join(", ", sessionId.Roles)</span>
                        }
                    </span>
                    @if (isConnected)
                    {
                        <form method="post" asp-controller="Login" asp-action="Logout" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Sign Out</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Login" asp-action="Index" class="btn btn-sm btn-primary">Sign In</a>
                    }
                </div>
            </header>

            <main class="app-content" id="main-content" tabindex="-1">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>@branding.FooterText</span>
                @if (!string.IsNullOrWhiteSpace(branding.PrivacyPolicyContent))
                {
                    <span class="ms-3"><a asp-controller="Home" asp-action="Privacy" class="text-muted small">Privacy Policy</a></span>
                }
                else if (!string.IsNullOrEmpty(branding.PrivacyPolicyUrl))
                {
                    <span class="ms-3"><a href="@branding.PrivacyPolicyUrl" target="_blank" rel="noopener noreferrer" class="text-muted small">Privacy Policy</a></span>
                }
            </footer>
        </section>

        @if (showAiChatLauncher)
        {
            <a class="ai-chat-launcher"
               asp-controller="Portal"
               asp-action="AiChat"
               aria-label="Open AI chat"
               title="Open AI chat">
                <span class="ai-chat-launcher-dot" aria-hidden="true">AI</span>
                <span class="ai-chat-launcher-text">Chat</span>
            </a>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Phase 13 — Typeahead for global search bar *@
    <script>
    (function () {
        document.addEventListener('DOMContentLoaded', function () {
            var input     = document.getElementById('globalSearchInput');
            var dropdown  = document.getElementById('searchTypeahead');
            if (!input || !dropdown) return;

            var timer = null;

            input.addEventListener('input', function () {
                clearTimeout(timer);
                var q = input.value.trim();
                if (q.length < 2) { dropdown.style.display = 'none'; return; }
                timer = setTimeout(function () { fetchSuggestions(q); }, 300);
            });

            document.addEventListener('click', function (e) {
                if (!input.contains(e.target) && !dropdown.contains(e.target))
                    dropdown.style.display = 'none';
            });

            function fetchSuggestions(q) {
                var url = '/Portal/SearchTypeahead?q=' + encodeURIComponent(q);
                fetch(url, { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (items) { renderDropdown(items); })
                    .catch(function () { dropdown.style.display = 'none'; });
            }

            function renderDropdown(items) {
                dropdown.innerHTML = '';
                if (!items || items.length === 0) { dropdown.style.display = 'none'; return; }
                items.forEach(function (item) {
                    var li  = document.createElement('li');
                    var a   = document.createElement('a');
                    a.className = 'dropdown-item py-1';
                    a.href = item.url || '#';
                    a.innerHTML =
                        '<span class="badge bg-secondary me-1 text-uppercase" style="font-size:.65rem">' +
                        escHtml(item.type) + '</span>' +
                        '<strong>' + escHtml(item.label) + '</strong>' +
                        (item.subLabel ? ' <small class="text-muted">' + escHtml(item.subLabel) + '</small>' : '');
                    li.appendChild(a);
                    dropdown.appendChild(li);
                });
                // "See all" link
                var li = document.createElement('li');
                li.innerHTML = '<hr class="dropdown-divider my-1">';
                dropdown.appendChild(li);
                var li2 = document.createElement('li');
                var a2  = document.createElement('a');
                a2.className = 'dropdown-item small text-primary';
                a2.href = '/Portal/Search?q=' + encodeURIComponent(input.value.trim());
                a2.textContent = 'See all results…';
                li2.appendChild(a2);
                dropdown.appendChild(li2);
                dropdown.style.display = 'block';
            }

            function escHtml(s) {
                if (!s) return '';
                return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }
        });
    }());
    </script>
</body>
</html>
