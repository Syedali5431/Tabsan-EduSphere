                {
                    <div class="global-search-wrapper position-relative me-3">
                        <form asp-controller="Portal" asp-action="Search" method="get" autocomplete="off" class="d-flex" role="search">
                            <div class="input-group input-group-sm search-pill">
                                <span class="input-group-text"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 4a6 6 0 1 0 3.874 10.582l4.272 4.272 1.414-1.414-4.272-4.272A6 6 0 0 0 10 4Zm0 2a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" fill="currentColor"/></svg></span>
                                <input id="globalSearchInput" name="q" type="search"
                                       class="form-control" placeholder="Search…"
                                       aria-label="Global search" minlength="2" />
                                <button class="btn btn-outline-secondary" type="submit" aria-label="Search">
                                    Go
                                </button>
                            </div>
                        </form>
                        <ul id="searchTypeahead"
                            class="dropdown-menu w-100 py-1 shadow-sm"
                            style="display:none; position:absolute; top:100%; left:0; z-index:1050;">
                        </ul>
                    </div>
                }

                <div class="header-meta">
                    @if (isConnected)
                    {
                        <a class="header-chip header-chip-notification" asp-controller="Portal" asp-action="Notifications" aria-label="Open notifications">
                            <span class="header-chip-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Zm7-6V11a7 7 0 1 0-14 0v5l-2 2v1h18v-1l-2-2Z" fill="currentColor"/></svg></span>
                            <span class="header-chip-copy">Notifications</span>
                            <span class="header-chip-dot" aria-hidden="true"></span>
                        </a>
                    }
                    else
                    {
                        <div class="header-chip header-chip-notification">
                            <span class="header-chip-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Zm7-6V11a7 7 0 1 0-14 0v5l-2 2v1h18v-1l-2-2Z" fill="currentColor"/></svg></span>
                            <span class="header-chip-copy">Live portal</span>
                        </div>
                    }

                    @if (isConnected)
                    {
                        <details class="profile-menu">
                            <summary class="auth-chip" aria-label="Open profile menu">
                                <div class="auth-avatar">@displayInitial</div>
                                <div class="auth-chip-copy">
                                    <span class="auth-name">@displayName</span>
                                    @if (sessionId?.Roles.Count > 0)
                                    {
                                        <span class="auth-role">@string.Join(" / ", sessionId.Roles)</span>
                                    }
                                    else
                                    {
                                        <span class="auth-role">Guest session</span>
                                    }
                                </div>
                                <span class="auth-chevron" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 10l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                            </summary>
                            <div class="profile-menu-panel">
                                <div class="profile-menu-role">@((sessionId?.Roles.Count > 0) ? string.Join(" / ", sessionId.Roles) : "Connected user")</div>
                                @if (isSuperAdmin)
                                {
                                    <a asp-controller="Portal" asp-action="Dashboard" class="profile-menu-link">Open Dashboard</a>
                                }
                                <a asp-controller="Portal" asp-action="Notifications" class="profile-menu-link">View Notifications</a>
                                <a asp-controller="Portal" asp-action="TwoFactorSettings" class="profile-menu-link">Two-Factor Authentication</a>
                                @if (isSuperAdmin)
                                {
                                    <a asp-controller="Portal" asp-action="ThemeSettings" class="profile-menu-link">Theme Settings</a>
                                }
                                <form method="post" asp-controller="Login" asp-action="Logout" class="profile-menu-signout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Sign Out</button>
                                </form>
                            </div>
                        </details>
                    }
                    else
                    {
                        <a asp-controller="Login" asp-action="Index" class="btn btn-sm btn-primary">Sign In</a>
                    }
                </div>
            </header>

            <main class="app-content" id="main-content" tabindex="-1">
                <div class="toast-stack" data-toast-stack aria-live="polite" aria-atomic="true"></div>
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>@branding.FooterText</span>
                @if (!string.IsNullOrWhiteSpace(branding.PrivacyPolicyContent))
                {
                    <span class="ms-3"><a asp-controller="Home" asp-action="Privacy" class="text-muted small">Privacy Policy</a></span>
                }
                else if (!string.IsNullOrEmpty(branding.PrivacyPolicyUrl))
                {
                    <span class="ms-3"><a href="@branding.PrivacyPolicyUrl" target="_blank" rel="noopener noreferrer" class="text-muted small">Privacy Policy</a></span>
                }
            </footer>
        </section>

        @if (showAiChatLauncher)
        {
            <div class="ai-chat-widget"
                 data-ai-chat-widget
                 data-load-url="@Url.Action("AiChatWidgetState", "Portal")"
                 data-send-url="@Url.Action("AiChatWidgetSend", "Portal")">
                <button type="button" class="ai-chat-backdrop" data-ai-chat-backdrop aria-label="Close AI assistant"></button>

                @await Html.PartialAsync("ChatPanel")
                @await Html.PartialAsync("FloatingChatButton")
            </div>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Phase 13 — Typeahead for global search bar *@
    <script>
    (function () {
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.alert').forEach(function (alertEl) {
                if (alertEl.classList.contains('alert-dismissible')) return;
                if (alertEl.querySelector('.btn-close[data-bs-dismiss="alert"], .btn-close[data-bs-dismiss]')) return;

                alertEl.classList.add('alert-dismissible', 'fade', 'show');
                if (!alertEl.getAttribute('role')) {
                    alertEl.setAttribute('role', 'alert');
                }

                var closeBtn = document.createElement('button');
                closeBtn.type = 'button';
                closeBtn.className = 'btn-close';
                closeBtn.setAttribute('data-bs-dismiss', 'alert');
                closeBtn.setAttribute('aria-label', 'Close');
                alertEl.appendChild(closeBtn);
            });

            var sidebar = document.querySelector('[data-app-sidebar]');
            var sidebarToggle = document.querySelector('[data-sidebar-toggle]');
            var sidebarClose = document.querySelector('[data-sidebar-close]');

            function setSidebar(open) {
                document.body.classList.toggle('sidebar-open', open);
            }

            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function () { setSidebar(true); });
            }

            if (sidebarClose) {
                sidebarClose.addEventListener('click', function () { setSidebar(false); });
            }

            document.addEventListener('click', function (e) {
                if (!document.body.classList.contains('sidebar-open')) return;
                if (!sidebar || sidebar.contains(e.target) || (sidebarToggle && sidebarToggle.contains(e.target))) return;
                setSidebar(false);
            });

            var input     = document.getElementById('globalSearchInput');
            var dropdown  = document.getElementById('searchTypeahead');
            if (!input || !dropdown) return;

            var timer = null;

            input.addEventListener('input', function () {
                clearTimeout(timer);
                var q = input.value.trim();
                if (q.length < 2) { dropdown.style.display = 'none'; return; }
                timer = setTimeout(function () { fetchSuggestions(q); }, 300);
            });

            document.addEventListener('click', function (e) {
                if (!input.contains(e.target) && !dropdown.contains(e.target))
                    dropdown.style.display = 'none';
            });

            function fetchSuggestions(q) {
                var url = '/Portal/SearchTypeahead?q=' + encodeURIComponent(q);
                fetch(url, { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (items) { renderDropdown(items); })
                    .catch(function () { dropdown.style.display = 'none'; });
            }

            function renderDropdown(items) {
                dropdown.innerHTML = '';
                if (!items || items.length === 0) { dropdown.style.display = 'none'; return; }
                items.forEach(function (item) {
                    var li  = document.createElement('li');
                    var a   = document.createElement('a');
                    a.className = 'dropdown-item py-1';
                    a.href = item.url || '#';
                    a.innerHTML =
                        '<span class="badge bg-secondary me-1 text-uppercase" style="font-size:.65rem">' +
                        escHtml(item.type) + '</span>' +
                        '<strong>' + escHtml(item.label) + '</strong>' +
                        (item.subLabel ? ' <small class="text-muted">' + escHtml(item.subLabel) + '</small>' : '');
                    li.appendChild(a);
                    dropdown.appendChild(li);
                });
                // "See all" link
                var li = document.createElement('li');
                li.innerHTML = '<hr class="dropdown-divider my-1">';
                dropdown.appendChild(li);
                var li2 = document.createElement('li');
                var a2  = document.createElement('a');
                a2.className = 'dropdown-item small text-primary';
                a2.href = '/Portal/Search?q=' + encodeURIComponent(input.value.trim());
                a2.textContent = 'See all results…';
                li2.appendChild(a2);
                dropdown.appendChild(li2);
                dropdown.style.display = 'block';
            }

            function escHtml(s) {
                if (!s) return '';
                return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }
        });
    }());
    </script>
</body>
</html>
