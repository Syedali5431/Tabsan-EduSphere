@if ((User.IsInRole("Admin") || User.IsInRole("SuperAdmin")) && Model.PendingModificationRequests.Count > 0)
{
    <div class="page-section-card card border-0 shadow-sm mt-3">
        <div class="card-body">
            <h3 class="h6">Pending Result Modification Requests (@Model.PendingModificationRequests.Count)</h3>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Request</th>
                            <th>Reason</th>
                            <th>Proposed Data</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model.PendingModificationRequests)
                        {
                            <tr>
                                <td>@req.Id<br /><small class="text-muted">@req.CreatedAt.ToLocalTime()</small></td>
                                <td>@req.Reason</td>
                                <td>@FormatProposedData(req.ProposedData)</td>
                                <td>
                                    <form asp-action="ApproveResultModificationRequest" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@req.Id" />
                                        <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                        <input type="hidden" name="notes" value="Approved from results page" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Approve</button>
                                    </form>
                                    <form asp-action="RejectResultModificationRequest" method="post" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@req.Id" />
                                        <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                        <input type="hidden" name="notes" value="Rejected from results page" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
<script src="~/js/cascading-filters.js" asp-append-version="true"></script>
<script>
// Toggle the Promote checkbox row so it is only visible when Result Type = "Final".
// Promotion after Midterm / Quiz / Assignment results is not a supported workflow.
document.getElementById('resultType_select')?.addEventListener('change', function () {
    var row = document.getElementById('promote_row');
    if (row) row.classList.toggle('d-none', this.value !== 'Final');
});
document.getElementById('correctResultModal')?.addEventListener('show.bs.modal', function (e) {
    var btn = e.relatedTarget;
    document.getElementById('correctResult_studentProfileId').value = btn.dataset.studentid;
    document.getElementById('correctResult_resultType').value = btn.dataset.resulttype || 'Final';
    document.getElementById('correctResult_marksObtained').value = btn.dataset.marksobtained || '';
    document.getElementById('correctResult_maxMarks').value = btn.dataset.maxmarks || '';
});
document.getElementById('requestResultModificationModal')?.addEventListener('show.bs.modal', function (e) {
    var btn = e.relatedTarget;
    document.getElementById('modifyResult_resultId').value = btn.dataset.resultid;
    document.getElementById('modifyResult_studentProfileId').value = btn.dataset.studentid;
    document.getElementById('modifyResult_resultType').value = btn.dataset.resulttype || 'Final';
    document.getElementById('modifyResult_marksObtained').value = btn.dataset.marksobtained || '';
    document.getElementById('modifyResult_maxMarks').value = btn.dataset.maxmarks || '';
});
document.getElementById('requestResultRecheckModal')?.addEventListener('show.bs.modal', function (e) {
    var btn = e.relatedTarget;
    document.getElementById('recheck_resultId').value = btn.dataset.resultid;
    document.getElementById('recheck_offeringId').value = btn.dataset.offeringid;
    document.getElementById('recheck_resultType').value = btn.dataset.resulttype || '';
    document.getElementById('recheck_courseName').value = btn.dataset.coursename || '';
});
</script>
}
