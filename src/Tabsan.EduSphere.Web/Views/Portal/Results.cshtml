@model Tabsan.EduSphere.Web.Models.Portal.ResultsPageModel
@{ ViewData["Title"] = "Results"; }
@{
    var semesterLabels = Model.SemesterOptions
        .Select((s, index) => new { s.Name, Label = (index + 1).ToString() })
        .ToDictionary(x => x.Name, x => x.Label, StringComparer.OrdinalIgnoreCase);

    string GetSemesterLabel(string? semesterName)
    {
        if (string.IsNullOrWhiteSpace(semesterName))
        {
            return "";
        }

        return semesterLabels.TryGetValue(semesterName, out var label)
            ? label
            : semesterName;
    }
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.Offerings.Count > 0)
    {
        <div class="page-section-card card border-0 shadow-sm mb-3">
            <div class="card-body">
                <div class="section-head mb-3">
                    <div>
                        <span class="section-kicker">Result controls</span>
                        <h2 class="h5 mb-1">Filter results by semester and offering</h2>
                        <p class="text-muted mb-0">Switch context quickly to review outcomes and publish pending records.</p>
                    </div>
                </div>
                <form method="get" asp-action="Results" class="row g-2 align-items-end filter-toolbar">
                    @if (User.IsInRole("Student") && Model.SemesterOptions.Count > 0)
                    {
                        <div class="col-md-4">
                            <label class="form-label">Select Semester</label>
                            <select name="semesterName" class="form-select" onchange="this.form.submit()">
                                <option value="">All Semesters</option>
                                @foreach (var s in Model.SemesterOptions)
                                {
                                    <option value="@s.Name" selected="@(string.Equals(Model.SelectedSemesterName, s.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@GetSemesterLabel(s.Name)</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-5">
                        <label class="form-label">Select Course Offering</label>
                        <select name="offeringId" class="form-select" onchange="this.form.submit()">
                            <option value="">My Results (all)</option>
                            @foreach (var o in Model.Offerings)
                            {
                                <option value="@o.Id" selected="@(Model.SelectedOfferingId == o.Id ? "selected" : null)">@o.Name</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (Model.Cgpa.HasValue)
    {
        <div class="alert alert-primary page-section-card">
            <strong>Overall CGPA:</strong> @Model.Cgpa.Value.ToString("0.00")
        </div>
    }

    <div class="page-section-card card border-0 shadow-sm">
        <div class="card-body">
            <div class="section-head mb-3">
                <h2 class="h5 mb-0">Results <span class="badge bg-secondary ms-1">@Model.Results.Count</span></h2>
                @if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#enterResultModal">
                            + Enter Result
                        </button>
                        <form asp-action="PublishAllResults" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                            <button type="submit" class="btn btn-sm btn-success"
                                    onclick="return confirm('Publish all draft results for this offering?')">
                                Publish All
                            </button>
                        </form>
                    </div>
                }
            </div>

            @if (Model.Results.Count == 0)
            {
                <div class="empty-state-card">
                    <h3>No results found</h3>
                    <p class="text-muted mb-0">There are no matching results for the current filter selection.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Course</th>
                                <th>Student</th>
                                <th>Semester</th>
                                <th>Marks</th>
                                <th>Grade</th>
                                <th>Published</th>
                                @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                {
                                    <th>Promote</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Results)
                            {
                                <tr>
                                    <td>@r.CourseCode — @r.CourseName</td>
                                    <td>@(string.IsNullOrWhiteSpace(r.StudentName) ? "—" : $"{r.StudentName} ({r.RegistrationNumber})")</td>
                                    <td>@GetSemesterLabel(r.SemesterName)</td>
                                    <td>@(r.MarksObtained.HasValue ? $"{r.MarksObtained}/{r.TotalMarks}" : "–")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(r.LetterGrade))
                                        {
                                            <span class="badge stat-pill bg-primary">@r.LetterGrade</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge stat-pill @(r.IsPublished ? "bg-success" : "bg-secondary")">
                                            @(r.IsPublished ? "Yes" : "Pending")
                                        </span>
                                    </td>
                                    @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                    {
                                        <td>
                                            @* Only render the Promote button when a valid StudentProfileId is present.
                                               Rows without a profile ID (e.g., anonymous/test entries) skip this cell. *@
                                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                            {
                                                <button type="button" class="btn btn-xs btn-outline-secondary btn-sm"
                                                        data-bs-toggle="modal" data-bs-target="#correctResultModal"
                                                        data-studentid="@r.StudentProfileId" data-resulttype="@r.ResultType"
                                                        data-marksobtained="@(r.MarksObtained ?? 0)" data-maxmarks="@r.TotalMarks">
                                                    Correct
                                                </button>
                                            }
                                            @if (r.StudentProfileId != Guid.Empty)
                                            {
                                                <form asp-action="PromoteStudentFromResult" method="post" class="d-inline"
                                                      onsubmit="return confirm('Promote @r.StudentName to next semester?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="studentProfileId" value="@r.StudentProfileId" />
                                                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                    <button type="submit" class="btn btn-xs btn-outline-primary btn-sm">Promote ↑</button>
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* ── Enter Result Modal ──────────────────────────────────────────────────── *@
@if (Model.SelectedOfferingId.HasValue && Model.Roster.Count > 0)
{
    <div class="modal fade" id="enterResultModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="CreateResult" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Enter Result</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Student <span class="text-danger">*</span></label>
                            <select name="studentProfileId" class="form-select" required>
                                <option value="">Select student…</option>
                                @foreach (var s in Model.Roster)
                                {
                                    <option value="@s.Id">@s.StudentName (@s.RegistrationNumber)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Result Type <span class="text-danger">*</span></label>
                            <select id="resultType_select" name="resultType" class="form-select" required>
                                <option value="Midterm">Midterm</option>
                                <option value="Final">Final</option>
                                <option value="Quiz">Quiz</option>
                                <option value="Assignment">Assignment</option>
                            </select>
                        </div>
                        <div class="row g-2">
                            <div class="col">
                                <label class="form-label">Marks Obtained <span class="text-danger">*</span></label>
                                <input name="marksObtained" type="number" step="0.5" min="0" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label">Max Marks <span class="text-danger">*</span></label>
                                <input name="maxMarks" type="number" step="0.5" min="1" class="form-control" required />
                            </div>
                        </div>
                        @* Promote checkbox — hidden by default; shown by the JS below only when
                           Result Type is "Final". Promotion is only meaningful after a final exam. *@
                        <div id="promote_row" class="mt-3 d-none">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="promote" value="true" id="promoteCheck" />
                                <label class="form-check-label" for="promoteCheck">
                                    Promote student to next semester after saving
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
{
    <div class="modal fade" id="correctResultModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="CorrectResult" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="correctResult_studentProfileId" name="studentProfileId" />
                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                <input type="hidden" id="correctResult_resultType" name="resultType" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Correct Result</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-2">
                            <div class="col">
                                <label class="form-label">New Marks Obtained <span class="text-danger">*</span></label>
                                <input id="correctResult_marksObtained" name="newMarksObtained" type="number" step="0.5" min="0" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label">New Max Marks <span class="text-danger">*</span></label>
                                <input id="correctResult_maxMarks" name="newMaxMarks" type="number" step="0.5" min="1" class="form-control" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Correction</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
// Toggle the Promote checkbox row so it is only visible when Result Type = "Final".
// Promotion after Midterm / Quiz / Assignment results is not a supported workflow.
document.getElementById('resultType_select')?.addEventListener('change', function () {
    var row = document.getElementById('promote_row');
    if (row) row.classList.toggle('d-none', this.value !== 'Final');
});
document.getElementById('correctResultModal')?.addEventListener('show.bs.modal', function (e) {
    var btn = e.relatedTarget;
    document.getElementById('correctResult_studentProfileId').value = btn.dataset.studentid;
    document.getElementById('correctResult_resultType').value = btn.dataset.resulttype || 'Final';
    document.getElementById('correctResult_marksObtained').value = btn.dataset.marksobtained || '';
    document.getElementById('correctResult_maxMarks').value = btn.dataset.maxmarks || '';
});
</script>
}
