@model Tabsan.EduSphere.Web.Models.Portal.ResultsPageModel
@{ ViewData["Title"] = "Results"; }
@{
    var currentAction = (ViewData["ResultsAction"] as string) ?? (ViewContext.RouteData.Values["action"]?.ToString() ?? "Results");
    var canDownloadTemplate = Model.SelectedOfferingId.HasValue;
    var periodLabel = string.IsNullOrWhiteSpace(Model.PeriodLabel) ? "Semester" : Model.PeriodLabel;
    var semesterLabels = Model.SemesterOptions
        .Select((s, index) => new { s.Name, Label = (index + 1).ToString() })
        .ToDictionary(x => x.Name, x => x.Label, StringComparer.OrdinalIgnoreCase);

    string GetSemesterLabel(string? semesterName)
    {
        if (string.IsNullOrWhiteSpace(semesterName))
        {
            return "";
        }

        return semesterLabels.TryGetValue(semesterName, out var label)
            ? label
            : semesterName;
    }

    string NormalizeProposedDataLabel(string key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return string.Empty;
        }

        var normalized = key.Replace("-", " ", StringComparison.Ordinal)
            .Replace("_", " ", StringComparison.Ordinal)
            .Trim();

        normalized = System.Text.RegularExpressions.Regex.Replace(normalized, "([a-z])([A-Z])", "$1 $2");

        if (string.IsNullOrEmpty(normalized))
        {
            return string.Empty;
        }

        return char.ToUpperInvariant(normalized[0]) + normalized[1..];
    }

    string FormatProposedData(string? proposedData)
    {
        if (string.IsNullOrWhiteSpace(proposedData))
        {
            return "-";
        }

        static List<string> BuildFormattedParts(System.Text.Json.JsonElement element, Func<string, string> normalizeLabel)
        {
            var parts = new List<string>();
            if (element.ValueKind != System.Text.Json.JsonValueKind.Object)
            {
                return parts;
            }

            foreach (var property in element.EnumerateObject())
            {
                var label = normalizeLabel(property.Name);
                var value = property.Value.ValueKind == System.Text.Json.JsonValueKind.String
                    ? property.Value.GetString() ?? string.Empty
                    : property.Value.ToString();

                value = value.Replace("-", " ", StringComparison.Ordinal)
                    .Replace("_", " ", StringComparison.Ordinal)
                    .Trim();

                if (!string.IsNullOrWhiteSpace(label) && !string.IsNullOrWhiteSpace(value))
                {
                    parts.Add($"{label}: {value}");
                }
            }

            return parts;
        }

        try
        {
            using var json = System.Text.Json.JsonDocument.Parse(proposedData);
            var formattedParts = BuildFormattedParts(json.RootElement, NormalizeProposedDataLabel);
            if (formattedParts.Count == 0 && json.RootElement.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                var nestedJson = json.RootElement.GetString();
                if (!string.IsNullOrWhiteSpace(nestedJson))
                {
                    using var nested = System.Text.Json.JsonDocument.Parse(nestedJson);
                    formattedParts = BuildFormattedParts(nested.RootElement, NormalizeProposedDataLabel);
                }
            }

            if (formattedParts.Count > 0)
            {
                return string.Join(" | ", formattedParts);
            }
        }
        catch
        {
            try
            {
                var trimmed = proposedData.Trim();
                if (trimmed.Length > 1 && trimmed[0] == '"' && trimmed[^1] == '"')
                {
                    var unwrapped = System.Text.Json.JsonSerializer.Deserialize<string>(trimmed);
                    if (!string.IsNullOrWhiteSpace(unwrapped))
                    {
                        using var nested = System.Text.Json.JsonDocument.Parse(unwrapped);
                        var formattedParts = BuildFormattedParts(nested.RootElement, NormalizeProposedDataLabel);
                        if (formattedParts.Count > 0)
                        {
                            return string.Join(" | ", formattedParts);
                        }
                    }
                }
            }
            catch
            {
                // Keep original value if ProposedData is not valid JSON.
            }
        }

        return proposedData;
    }
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (Model.MessageDetails.Count > 0)
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Details</div>
        <ul class="mb-0">
            @foreach (var detail in Model.MessageDetails)
            {
                <li>@detail</li>
            }
        </ul>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="page-section-card card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="section-head mb-3">
                <div>
                    <span class="section-kicker">Result controls</span>
                    <h2 class="h5 mb-1">Filter results by scoped academic context</h2>
                    <p class="text-muted mb-0">Required filters must be selected before write actions are enabled.</p>
                </div>
            </div>
            <form method="get" asp-action="@currentAction" class="row g-2 align-items-end filter-toolbar">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-2">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id)">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id)">@c.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Institute</label>
                            @if (Model.AvailableInstitutionTypes?.Count > 1)
                            {
                                <select id="institutionType" name="institutionType" class="form-select"
                                        data-cascade="institution" onchange="this.form.submit()">
                                    <option value="">All</option>
                                    @foreach (var it in Model.AvailableInstitutionTypes)
                                    {
                                        <option value="@it.Value" selected="@(Model.SelectedInstitutionType == it.Value ? "selected" : null)">@it.Label</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <select class="form-select" disabled><option>@(Model.AvailableInstitutionTypes?.FirstOrDefault()?.Label ?? "All")</option></select>
                            }
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    }

                    @if (!User.IsInRole("Student"))
                    {
                        <div class="col-md-2">
                            <label class="form-label">Department <span class="text-danger">*</span></label>
                            <select id="departmentId" name="departmentId" class="form-select" data-cascade="department" onchange="this.form.submit()">
                                <option value="">Select department</option>
                                @foreach (var d in Model.Departments)
                                {
                                    <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id)">@d.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Program/Course <span class="text-danger">*</span></label>
                            <select name="courseId" class="form-select" onchange="this.form.submit()">
                                <option value="">Select course</option>
                                @foreach (var c in Model.Courses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCourseId == c.Id)">@c.Name</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-md-3">
                        <label class="form-label">@periodLabel</label>
                        <select name="semesterName" class="form-select" onchange="this.form.submit()">
                            <option value="">All @periodLabel</option>
                            @foreach (var s in Model.SemesterOptions)
                            {
                                <option value="@s.Name" selected="@(string.Equals(Model.SelectedSemesterName, s.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@GetSemesterLabel(s.Name)</option>
                            }
                        </select>
                    </div>

                    @if (!User.IsInRole("Student"))
                    {
                        <div class="col-md-3">
                            <label class="form-label">Subject <span class="text-danger">*</span></label>
                            <select name="subjectOfferingId" class="form-select" onchange="this.form.submit()">
                                <option value="">Select subject</option>
                                @foreach (var s in Model.Subjects)
                                {
                                    <option value="@s.Id" selected="@(Model.SelectedSubjectOfferingId == s.Id)">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Exam Type <span class="text-danger">*</span></label>
                            <select name="examType" class="form-select" onchange="this.form.submit()">
                                <option value="">Select exam type</option>
                                @foreach (var e in Model.ExamTypeOptions)
                                {
                                    <option value="@e.Name" selected="@(string.Equals(Model.SelectedExamType, e.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@e.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Assessment Component <span class="text-danger">*</span></label>
                            <select name="assessmentComponent" class="form-select" onchange="this.form.submit()">
                                <option value="">Select component</option>
                                @foreach (var a in Model.AssessmentComponentOptions)
                                {
                                    <option value="@a.Name" selected="@(string.Equals(Model.SelectedAssessmentComponent, a.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@a.Name</option>
                                }
                            </select>
                        </div>

                        <input type="hidden" name="offeringId" value="@Model.SelectedSubjectOfferingId" />

                        <div class="col-md-3">
                            <label class="form-label">Student (optional)</label>
                            <select name="studentId" class="form-select" onchange="this.form.submit()">
                                <option value="">All students</option>
                                @foreach (var r in Model.Roster)
                                {
                                    <option value="@r.Id" selected="@(Model.SelectedStudentId == r.Id)">@r.StudentName (@r.RegistrationNumber)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Section</label>
                            <input name="section" value="@Model.SelectedSection" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Batch</label>
                            <input name="batch" value="@Model.SelectedBatch" class="form-control" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-3">
                            <label class="form-label">Course</label>
                            <select name="courseId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Courses</option>
                                @foreach (var c in Model.Courses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCourseId == c.Id ? "selected" : null)">@c.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Subject</label>
                            <select name="subjectOfferingId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Subjects</option>
                                @foreach (var s in Model.Subjects)
                                {
                                    <option value="@s.Id" selected="@(Model.SelectedSubjectOfferingId == s.Id ? "selected" : null)">@s.Name</option>
                                }
                            </select>
                        </div>
                        <input type="hidden" name="offeringId" value="@Model.SelectedSubjectOfferingId" />
                    }

                    @if (!User.IsInRole("Student"))
                    {
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-outline-secondary w-100">Apply</button>
                        </div>
                    }
            </form>
        </div>
    </div>

    @if (Model.Cgpa.HasValue)
    {
        <div class="alert alert-primary page-section-card">
            <strong>Overall CGPA:</strong> @Model.Cgpa.Value.ToString("0.00")
        </div>
    }

    <div class="page-section-card card border-0 shadow-sm">
        <div class="card-body">
            <div class="section-head mb-3">
                <h2 class="h5 mb-0">Results <span class="badge bg-secondary ms-1">@Model.Results.Count</span></h2>
                @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                {
                    <div class="responsive-action-group">
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#enterResultModal" disabled="@(!Model.CanWriteResults)" title="@(!Model.CanWriteResults ? Model.SaveResultDisabledReason : null)">
                            + Enter Result
                        </button>
                        <form asp-action="DownloadResultCsvTemplate" method="get" class="d-inline">
                            <input type="hidden" name="entryPoint" value="@currentAction" />
                            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                            <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                            <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                            <input type="hidden" name="subjectOfferingId" value="@Model.SelectedSubjectOfferingId" />
                            <input type="hidden" name="examType" value="@Model.SelectedExamType" />
                            <input type="hidden" name="assessmentComponent" value="@Model.SelectedAssessmentComponent" />
                            <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                            <input type="hidden" name="section" value="@Model.SelectedSection" />
                            <input type="hidden" name="batch" value="@Model.SelectedBatch" />
                            <button type="submit"
                                    class="btn btn-sm btn-outline-secondary"
                                    disabled="@(!canDownloadTemplate)"
                                    title="@(!canDownloadTemplate ? Model.SaveResultDisabledReason : null)">
                                Get Template
                            </button>
                        </form>
                        <form asp-action="ImportResultCsv" method="post" enctype="multipart/form-data" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="entryPoint" value="@currentAction" />
                            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                            <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                            <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                            <input type="hidden" name="subjectOfferingId" value="@Model.SelectedSubjectOfferingId" />
                            <input type="hidden" name="examType" value="@Model.SelectedExamType" />
                            <input type="hidden" name="assessmentComponent" value="@Model.SelectedAssessmentComponent" />
                            <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                            <input type="hidden" name="section" value="@Model.SelectedSection" />
                            <input type="hidden" name="batch" value="@Model.SelectedBatch" />
                            <input type="file" name="csvFile" accept=".csv" class="form-control form-control-sm d-inline-block" style="width: 190px;" />
                            <label class="form-check-label ms-1 me-1">
                                <input type="checkbox" name="strictMode" value="true" class="form-check-input" /> strict
                            </label>
                            <button type="submit" class="btn btn-sm btn-outline-primary" disabled="@(!Model.CanWriteResults)" title="@(!Model.CanWriteResults ? Model.SaveResultDisabledReason : null)">Import Results</button>
                        </form>
                        @if (!string.IsNullOrWhiteSpace(Model.ImportReportToken))
                        {
                            <form asp-action="DownloadResultImportReport" method="get" class="d-inline">
                                <input type="hidden" name="reportToken" value="@Model.ImportReportToken" />
                                <input type="hidden" name="entryPoint" value="@currentAction" />
                                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                <input type="hidden" name="subjectOfferingId" value="@Model.SelectedSubjectOfferingId" />
                                <input type="hidden" name="examType" value="@Model.SelectedExamType" />
                                <input type="hidden" name="assessmentComponent" value="@Model.SelectedAssessmentComponent" />
                                <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                                <input type="hidden" name="section" value="@Model.SelectedSection" />
                                <input type="hidden" name="batch" value="@Model.SelectedBatch" />
                                <button type="submit" class="btn btn-sm btn-outline-info">Import Report</button>
                            </form>
                        }
                        <form asp-action="PublishAllResults" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="entryPoint" value="@currentAction" />
                            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                            <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                            <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                            <input type="hidden" name="subjectOfferingId" value="@Model.SelectedSubjectOfferingId" />
                            <input type="hidden" name="examType" value="@Model.SelectedExamType" />
                            <input type="hidden" name="assessmentComponent" value="@Model.SelectedAssessmentComponent" />
                            <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                            <input type="hidden" name="section" value="@Model.SelectedSection" />
                            <input type="hidden" name="batch" value="@Model.SelectedBatch" />
                            <button type="submit" class="btn btn-sm btn-success"
                                    onclick="return confirm('Publish all draft results for this offering?')"
                                    disabled="@(!Model.CanPublishResults)"
                                    title="@(!Model.CanPublishResults ? Model.PublishResultDisabledReason : null)">
                                Publish All
                            </button>
                        </form>
                    </div>
                    <div class="text-muted small mt-1">
                        Template CSV includes 2 example rows for format guidance; those example rows are skipped during import. Import report links are one-time use and expire after 2 hours.
                    </div>
                    @if (!Model.CanPublishResults && Model.CanWriteResults)
                    {
                        <div class="text-muted small mt-1">Publishing is approval-gated and available to Admin/SuperAdmin roles only.</div>
                    }
                }
            </div>

            @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                        <h3 class="h6 mb-0">Result Entry Grid</h3>
                        @if (!Model.CanWriteResults)
                        {
                            <span class="badge bg-warning text-dark">Guidance state</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Editable state</span>
                        }
                    </div>
                    <p class="text-muted small mb-2">
                        @if (!Model.CanWriteResults)
                        {
                            @Model.SaveResultDisabledReason
                        }
                        else
                        {
                            @:Required filters are complete. Use this editable table to prepare row values before saving through Enter Result or CSV import.
                        }
                    </p>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Student ID</th>
                                    <th>Student Name</th>
                                    <th>Marks Obtained</th>
                                    <th>Max Marks</th>
                                    <th>Grade</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Roster.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-muted">No roster rows available for the current selection.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var row in Model.Roster.Take(10))
                                    {
                                        <tr>
                                            <td>@row.RegistrationNumber</td>
                                            <td>@row.StudentName</td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" min="0" step="0.5" placeholder="0" disabled="@(!Model.CanWriteResults)" />
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm" min="1" step="0.5" placeholder="100" disabled="@(!Model.CanWriteResults)" />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" maxlength="10" placeholder="A" disabled="@(!Model.CanWriteResults)" />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm" maxlength="120" placeholder="Optional note" disabled="@(!Model.CanWriteResults)" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (Model.Results.Count == 0)
            {
                <div class="empty-state-card">
                    <h3>No results found</h3>
                    <p class="text-muted mb-0">There are no matching results for the current filter selection.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Course</th>
                                <th>Student</th>
                                <th>@periodLabel</th>
                                <th>Marks</th>
                                <th>Grade</th>
                                <th>Published</th>
                                @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                {
                                    <th>Actions</th>
                                }
                                @if (User.IsInRole("Student"))
                                {
                                    <th>Re-check</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Results)
                            {
                                <tr>
                                    <td>@r.CourseCode — @r.CourseName</td>
                                    <td>@(string.IsNullOrWhiteSpace(r.StudentName) ? "—" : $"{r.StudentName} ({r.RegistrationNumber})")</td>
                                    <td>@GetSemesterLabel(r.SemesterName)</td>
                                    <td>@(r.MarksObtained.HasValue ? $"{r.MarksObtained}/{r.TotalMarks}" : "–")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(r.LetterGrade))
                                        {
                                            <span class="badge stat-pill bg-primary">@r.LetterGrade</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge stat-pill @(r.IsPublished ? "bg-success" : "bg-secondary")">
                                            @(r.IsPublished ? "Yes" : "Pending")
                                        </span>
                                    </td>
                                    @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                    {
                                        <td>
                                            @* Only render the Promote button when a valid StudentProfileId is present.
                                               Rows without a profile ID (e.g., anonymous/test entries) skip this cell. *@
                                            @if (User.IsInRole("Faculty"))
                                            {
                                                <button type="button" class="btn btn-xs btn-outline-warning btn-sm"
                                                        data-bs-toggle="modal" data-bs-target="#requestResultModificationModal"
                                                        data-resultid="@r.Id" data-studentid="@r.StudentProfileId" data-resulttype="@r.ResultType"
                                                        data-marksobtained="@(r.MarksObtained ?? 0)" data-maxmarks="@r.TotalMarks">
                                                    Request Modify
                                                </button>
                                            }
                                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                            {
                                                <button type="button" class="btn btn-xs btn-outline-secondary btn-sm"
                                                        data-bs-toggle="modal" data-bs-target="#correctResultModal"
                                                        data-studentid="@r.StudentProfileId" data-resulttype="@r.ResultType"
                                                        data-marksobtained="@(r.MarksObtained ?? 0)" data-maxmarks="@r.TotalMarks">
                                                    Update Result
                                                </button>
                                            }
                                            @if (r.StudentProfileId != Guid.Empty)
                                            {
                                                <form asp-action="PromoteStudentFromResult" method="post" class="d-inline"
                                                      onsubmit="return confirm('Promote @r.StudentName to next @periodLabel.ToLowerInvariant()?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="entryPoint" value="@currentAction" />
                                                    <input type="hidden" name="studentProfileId" value="@r.StudentProfileId" />
                                                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                    <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                    <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                                    <input type="hidden" name="subjectOfferingId" value="@Model.SelectedSubjectOfferingId" />
                                                    <input type="hidden" name="examType" value="@Model.SelectedExamType" />
                                                    <input type="hidden" name="assessmentComponent" value="@Model.SelectedAssessmentComponent" />
                                                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                                                    <input type="hidden" name="section" value="@Model.SelectedSection" />
                                                    <input type="hidden" name="batch" value="@Model.SelectedBatch" />
                                                    <button type="submit" class="btn btn-xs btn-outline-primary btn-sm">Promote ↑</button>
                                                </form>
                                            }
                                        </td>
                                    }
                                    @if (User.IsInRole("Student"))
                                    {
                                        <td>
                                            <button type="button" class="btn btn-xs btn-outline-info btn-sm"
                                                    data-bs-toggle="modal" data-bs-target="#requestResultRecheckModal"
                                                    data-resultid="@r.Id"
                                                    data-offeringid="@r.CourseOfferingId"
                                                    data-resulttype="@r.ResultType"
                                                    data-coursename="@($"{r.CourseCode} - {r.CourseName}")">
                                                Request Re-check
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* ── Enter Result Modal ──────────────────────────────────────────────────── *@
@if (Model.SelectedOfferingId.HasValue && Model.Roster.Count > 0)
{
    <div class="modal fade" id="enterResultModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="CreateResult" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="entryPoint" value="@currentAction" />
                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                <input type="hidden" name="subjectOfferingId" value="@Model.SelectedSubjectOfferingId" />
                <input type="hidden" name="examType" value="@Model.SelectedExamType" />
                <input type="hidden" name="assessmentComponent" value="@Model.SelectedAssessmentComponent" />
                <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                <input type="hidden" name="section" value="@Model.SelectedSection" />
                <input type="hidden" name="batch" value="@Model.SelectedBatch" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Enter Result</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Student <span class="text-danger">*</span></label>
                            <select name="studentProfileId" class="form-select" required>
                                <option value="">Select student…</option>
                                @foreach (var s in Model.Roster)
                                {
                                    <option value="@s.Id">@s.StudentName (@s.RegistrationNumber)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Result Type <span class="text-danger">*</span></label>
                            <select id="resultType_select" name="resultType" class="form-select" required>
                                <option value="Midterm">Midterm</option>
                                <option value="Final">Final</option>
                                <option value="Quiz">Quiz</option>
                                <option value="Assignment">Assignment</option>
                            </select>
                        </div>
                        <div class="row g-2">
                            <div class="col">
                                <label class="form-label">Marks Obtained <span class="text-danger">*</span></label>
                                <input name="marksObtained" type="number" step="0.5" min="0" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label">Max Marks <span class="text-danger">*</span></label>
                                <input name="maxMarks" type="number" step="0.5" min="1" class="form-control" required />
                            </div>
                        </div>
                        @* Promote checkbox — hidden by default; shown by the JS below only when
                           Result Type is "Final". Promotion is only meaningful after a final exam. *@
                        <div id="promote_row" class="mt-3 d-none">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="promote" value="true" id="promoteCheck" />
                                <label class="form-check-label" for="promoteCheck">
                                    Promote student to next @periodLabel.ToLowerInvariant() after saving
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

