@model Tabsan.EduSphere.Web.Models.Portal.ReportGpaPageModel
@{
    ViewData["Title"] = "GPA & CGPA Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ReportCenter" asp-controller="Portal" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h2 class="mb-0"><i class="bi bi-graph-up me-2"></i>GPA &amp; CGPA Report</h2>
            <small class="text-muted">Cumulative and current semester GPA per student</small>
        </div>
    </div>

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning"><i class="bi bi-wifi-off me-2"></i>Not connected to API.</div>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger">@Model.Message</div>
        }

        <form method="get" class="card shadow-sm border-0 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Institute</label>
                        <select name="institutionType" class="form-select form-select-sm">
                            @if (!Model.InstitutionType.HasValue && Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="" selected>All Institutes</option>
                            }
                            else if (Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="">All Institutes</option>
                            }
                            @foreach (var institution in Model.AvailableInstitutionTypes)
                            {
                                <option value="@institution.Value" selected="@(Model.InstitutionType == institution.Value)">@institution.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Department</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Program</label>
                        <select name="programId" class="form-select form-select-sm">
                            <option value="">All Programs</option>
                            @foreach (var p in Model.Programs)
                            {
                                <option value="@p.Id" selected="@(Model.ProgramId == p.Id)">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
                    </div>
                    @if (Model.Report is not null)
                    {
                        <div class="col-md-1">
                                     <a href="@Url.Action("ExportGpaReport", "Portal", new { departmentId = Model.DepartmentId, programId = Model.ProgramId, institutionType = Model.InstitutionType })"
                                         class="btn btn-success btn-sm w-100" title="Export Excel"><i class="bi bi-download me-1"></i><span>Excel</span></a>
                        </div>
                    }
                </div>
            </div>
        </form>

        @if (Model.Report is not null)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small">
                    @Model.Report.TotalStudents student(s) &mdash;
                    Average CGPA: <strong>@Model.Report.AverageCgpa.ToString("F2")</strong> &mdash;
                    generated @Model.Report.GeneratedAt.ToString("dd MMM yyyy, HH:mm")
                </span>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Reg. No.</th>
                                    <th>Student</th>
                                    <th>Program</th>
                                    <th>Department</th>
                                    <th class="text-center">Semester</th>
                                    <th class="text-center">Sem GPA</th>
                                    <th class="text-center">CGPA</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.Report.Rows)
                                {
                                    <tr>
                                        <td>@r.RegistrationNumber</td>
                                        <td>@r.StudentName</td>
                                        <td>@r.ProgramName</td>
                                        <td>@r.DepartmentName</td>
                                        <td class="text-center">@r.CurrentSemester</td>
                                        <td class="text-center">@r.CurrentSemesterGpa.ToString("F2")</td>
                                        <td class="text-center"><strong>@r.Cgpa.ToString("F2")</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="6" class="text-end fw-semibold">Average CGPA</td>
                                    <td class="text-center fw-bold">@Model.Report.AverageCgpa.ToString("F2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary"><i class="bi bi-info-circle me-2"></i>Select filters above and click Filter to generate the report.</div>
        }
    }
</div>
