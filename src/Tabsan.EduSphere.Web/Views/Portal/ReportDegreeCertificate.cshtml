@model Tabsan.EduSphere.Web.Models.Portal.ReportDegreeCertificatePageModel
@{
    ViewData["Title"] = "Degree Certificate";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ReportCenter" asp-controller="Portal" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h2 class="mb-0"><i class="bi bi-award me-2"></i>Degree Certificate</h2>
            <small class="text-muted">Generate a formal degree certificate for graduated students</small>
        </div>
    </div>

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning"><i class="bi bi-wifi-off me-2"></i>Not connected to API.</div>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>@Model.Message</div>
        }

        <form method="get" class="card shadow-sm border-0 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-8">
                        <label class="form-label small mb-1">Graduated Student</label>
                        <select name="studentProfileId" class="form-select form-select-sm">
                            <option value="">Select a graduated student…</option>
                            @foreach (var s in Model.Students)
                            {
                                <option value="@s.Id" selected="@(Model.StudentProfileId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search me-1"></i>Select Student</button>
                    </div>
                </div>
            </div>
        </form>

        @if (Model.StudentProfileId.HasValue)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-award-fill text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="mb-3">Degree Certificate Ready</h4>
                    <p class="text-muted mb-4">
                        A formal university degree certificate will be generated as a PDF.<br />
                        The certificate includes the university seal, student name, degree title, CGPA, and official signatures.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="@Url.Action("ExportDegreeCertificatePdf", "Portal", new { studentProfileId = Model.StudentProfileId })"
                           class="btn btn-danger btn-lg px-4">
                            <i class="bi bi-filetype-pdf me-2"></i>Generate &amp; Download Certificate (PDF)
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Certificate Preview</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>University:</strong> Tabsan University</p>
                            <p><strong>Faculty:</strong> Faculty of Information Technology</p>
                            <p><strong>Degree Level:</strong> Bachelor</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Format:</strong> A4 Landscape</p>
                            <p><strong>Styling:</strong> Formal university degree with seal, signatures, gold accents</p>
                            <p><strong>Includes:</strong> Student name, degree title, CGPA, duration, FYP title, certificate number</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-check" style="font-size: 3rem;"></i>
                <p class="mt-3">Select a graduated student above to generate their degree certificate.</p>
            </div>
        }
    }
</div>
