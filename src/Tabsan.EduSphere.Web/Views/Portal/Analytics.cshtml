                if (!el) return;

                var performance = snapshot ? prop(snapshot, 'performance', 'Performance', null) : null;
                var students = prop(performance, 'students', 'Students', []) || [];
                var grouped = {};

                students.forEach(function (student) {
                    var dept = prop(student, 'department', 'Department', 'Unspecified');
                    grouped[dept] = (grouped[dept] || 0) + 1;
                });

                var labels = Object.keys(grouped).slice(0, 10);
                var values = labels.map(function (key) { return grouped[key]; });

                destroyChart(charts.departmentCounts);

                if (!labels.length) {

                    clearChartCanvas(el, 'No department distribution data available.');
                    charts.departmentCounts = null;
                    return;
                }

                charts.departmentCounts = new Chart(el, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Students',
                            data: values,
                            backgroundColor: labels.map(function (_, idx) { return palette(idx, 0.45); }),
                            borderColor: labels.map(function (_, idx) { return palette(idx, 1); }),
                            borderWidth: 1,
                            categoryPercentage: 0.55,
                            barPercentage: 0.7,
                            maxBarThickness: 20
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: true, position: 'bottom', labels: { padding: 16, usePointStyle: true } } },
                        scales: { y: { beginAtZero: true } }
                    }
                });


            }

            function renderCourseTrend(snapshot) {
                var el = document.getElementById('courseTrendChart');
                if (!el) return;

                var assignmentReport = snapshot ? prop(snapshot, 'assignments', 'Assignments', null) : null;
                var assignmentRows = prop(assignmentReport, 'assignments', 'Assignments', []) || [];
                var grouped = {};

                assignmentRows.forEach(function (row) {
                    var course = prop(row, 'courseName', 'CourseName', 'Unspecified');
                    var avg = Number(prop(row, 'averageMarks', 'AverageMarks', 0)) || 0;
                    if (!grouped[course]) {
                        grouped[course] = { sum: 0, count: 0 };
                    }
                    grouped[course].sum += avg;
                    grouped[course].count += 1;
                });

                var labels = Object.keys(grouped).slice(0, 10);
                var values = labels.map(function (key) {
                    var cell = grouped[key];
                    return cell.count > 0 ? Number((cell.sum / cell.count).toFixed(2)) : 0;
                });

                destroyChart(charts.courseTrend);

                if (!labels.length) {

                    clearChartCanvas(el, 'No course trend data available.');
                    charts.courseTrend = null;
                    return;
                }

                charts.courseTrend = new Chart(el, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Avg Assignment Marks',
                            data: values,
                            fill: false,
                            tension: 0.3,
                            backgroundColor: 'rgba(220, 53, 69, 0.2)',
                            borderColor: 'rgba(220, 53, 69, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: true, position: 'bottom', labels: { padding: 16, usePointStyle: true } } },
                        scales: { y: { beginAtZero: true, max: 100 } }
                    }
                });


            }

            function renderSemesterTrend(snapshot) {
                var el = document.getElementById('semesterTrendChart');
                if (!el) return;

                var performance = snapshot ? prop(snapshot, 'performance', 'Performance', null) : null;
                var attendance = snapshot ? prop(snapshot, 'attendance', 'Attendance', null) : null;
                var students = prop(performance, 'students', 'Students', []) || [];
                var attendanceRows = prop(attendance, 'rows', 'Rows', []) || [];

                var marksBySemester = {};
                students.forEach(function (student) {
                    var sem = Number(prop(student, 'currentSemester', 'CurrentSemester', 0)) || 0;
                    if (sem <= 0) return;
                    if (!marksBySemester[sem]) {
                        marksBySemester[sem] = { sum: 0, count: 0 };
                    }
                    marksBySemester[sem].sum += Number(prop(student, 'averageMarks', 'AverageMarks', 0)) || 0;
                    marksBySemester[sem].count += 1;
                });

                var attendanceBySemester = {};
                attendanceRows.forEach(function (row) {
                    var courseName = prop(row, 'courseName', 'CourseName', '');
                    var match = /sem(?:ester)?\s*(\d+)/i.exec(courseName);
                    var sem = match ? Number(match[1]) : 0;
                    if (sem <= 0) return;
                    if (!attendanceBySemester[sem]) {
                        attendanceBySemester[sem] = { sum: 0, count: 0 };
                    }
                    attendanceBySemester[sem].sum += Number(prop(row, 'attendancePercentage', 'AttendancePercentage', 0)) || 0;
                    attendanceBySemester[sem].count += 1;
                });

                var semesterSet = {};
                Object.keys(marksBySemester).forEach(function (k) { semesterSet[k] = true; });
                Object.keys(attendanceBySemester).forEach(function (k) { semesterSet[k] = true; });
                var semesters = Object.keys(semesterSet)
                    .map(function (k) { return Number(k); })
                    .filter(function (n) { return n > 0; })
                    .sort(function (a, b) { return a - b; });

                destroyChart(charts.semesterTrend);

                if (!semesters.length) {

                    clearChartCanvas(el, 'No semester trend data available.');
                    charts.semesterTrend = null;
                    return;
                }

                var labels = semesters.map(function (s) { return 'Sem ' + s; });
                var avgMarks = semesters.map(function (s) {
                    var cell = marksBySemester[s];
                    return cell && cell.count > 0 ? Number((cell.sum / cell.count).toFixed(2)) : null;
                });
                var avgAttendance = semesters.map(function (s) {
                    var cell = attendanceBySemester[s];
                    return cell && cell.count > 0 ? Number((cell.sum / cell.count).toFixed(2)) : null;
                });

                charts.semesterTrend = new Chart(el, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Avg Marks',
                                data: avgMarks,
                                fill: false,
                                tension: 0.25,
                                backgroundColor: 'rgba(13, 110, 253, 0.2)',
                                borderColor: 'rgba(13, 110, 253, 1)',
                                borderWidth: 2,
                                spanGaps: true
                            },
                            {
                                label: 'Avg Attendance',
                                data: avgAttendance,
                                fill: false,
                                tension: 0.25,
                                backgroundColor: 'rgba(25, 135, 84, 0.2)',
                                borderColor: 'rgba(25, 135, 84, 1)',
                                borderWidth: 2,
                                spanGaps: true
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: true, position: 'bottom', labels: { padding: 16, usePointStyle: true } } },
                        scales: { y: { beginAtZero: true, max: 100 } }
                    }
                });


            }

            function applySnapshot(snapshot) {
                showMessage(snapshot && snapshot.message ? snapshot.message : '');
                var isFinanceOnly = !!prop(snapshot, 'isFinanceOnly', 'IsFinanceOnly', false);

                var selectedInstitutionType = prop(snapshot, 'selectedInstitutionType', 'SelectedInstitutionType', null);
                var selectedTenantId = prop(snapshot, 'selectedTenantId', 'SelectedTenantId', null);
                var selectedCampusId = prop(snapshot, 'selectedCampusId', 'SelectedCampusId', null);
                var selectedDepartmentId = prop(snapshot, 'selectedDepartmentId', 'SelectedDepartmentId', null);
                var selectedCourseId = prop(snapshot, 'selectedCourseId', 'SelectedCourseId', null);
                var selectedSemesterId = prop(snapshot, 'selectedSemesterId', 'SelectedSemesterId', null);

                setSelectOptions(tenantSelect, prop(snapshot, 'tenants', 'Tenants', []), selectedTenantId, 'All Tenants');
                setSelectOptions(campusSelect, prop(snapshot, 'campuses', 'Campuses', []), selectedCampusId, 'All Campuses');

                if (institutionSelect) {
                    institutionSelect.value = selectedInstitutionType !== null && selectedInstitutionType !== undefined
                        ? String(selectedInstitutionType)
                        : '';
                }

                setSelectOptions(departmentSelect, prop(snapshot, 'departments', 'Departments', []), selectedDepartmentId, 'All Departments');
                setSelectOptions(courseSelect, prop(snapshot, 'courses', 'Courses', []), selectedCourseId, 'All Courses');
                setSelectOptions(semesterSelect, prop(snapshot, 'semesters', 'Semesters', []), selectedSemesterId, 'All Semesters');

                renderSummaryCards(prop(snapshot, 'cards', 'Cards', []));
                renderPaymentStatus(snapshot);

                if (!isFinanceOnly) {
                    renderOverview(snapshot);
                    renderPerformance(snapshot);
                    renderAttendance(snapshot);
                    renderAssignments(snapshot);
                    renderStudentDistribution(snapshot);
                    renderDepartmentCounts(snapshot);
                    renderCourseTrend(snapshot);
                    renderSemesterTrend(snapshot);
                }
            }

            function buildSnapshotQuery() {
                var query = new URLSearchParams();
                if (tenantSelect && tenantSelect.value) query.set('tenantId', tenantSelect.value);
                if (campusSelect && campusSelect.value) query.set('campusId', campusSelect.value);
                if (institutionSelect && institutionSelect.value) query.set('institutionType', institutionSelect.value);
                if (departmentSelect && departmentSelect.value) query.set('departmentId', departmentSelect.value);
                if (courseSelect && courseSelect.value) query.set('courseId', courseSelect.value);
                if (semesterSelect && semesterSelect.value) query.set('semesterId', semesterSelect.value);
                return query;
            }

            async function refreshSnapshot() {
                var currentRequest = ++activeRequestId;
                setLoading(true);

                try {
                    var response = await fetch(snapshotUrl + '?' + buildSnapshotQuery().toString(), {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error('Unable to load analytics snapshot.');
                    }

                    var snapshot = await response.json();
                    if (currentRequest !== activeRequestId) {
                        return;
                    }

                    if (!snapshot || snapshot.success === false) {
                        showMessage(snapshot && snapshot.message ? snapshot.message : 'Unable to load analytics data.');
                        return;
                    }

                    applySnapshot(snapshot);
                } catch (error) {
                    if (currentRequest !== activeRequestId) {
                        return;
                    }

                    showMessage(error && error.message ? error.message : 'Unable to load analytics data.');
                } finally {
                    if (currentRequest === activeRequestId) {
                        setLoading(false);
                    }
                }
            }

            applySnapshot(initialSnapshot);
        })();
    </script>
}
