@* Plan D Phase 1 Stage 1.1 — Chart.js integration and sample chart rendering *@
@model Tabsan.EduSphere.Web.Models.Portal.AnalyticsPageModel
@{ ViewData["Title"] = "Analytics"; }

<div id="analyticsMessage" class="alert alert-info @(string.IsNullOrWhiteSpace(Model.Message) ? "d-none" : string.Empty)">@Model.Message</div>

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Analytics" method="get" class="row g-3 align-items-end" id="analyticsFilterForm">
                <div class="col-md-3">
                    <label class="form-label">Institution</label>
                    <select class="form-select" name="institutionType" id="analyticsInstitutionType">
                        @if (!Model.SelectedInstitutionType.HasValue)
                        {
                            <option value="" selected>All Institutions</option>
                        }
                        else
                        {
                            <option value="">All Institutions</option>
                        }

                        @if (Model.SelectedInstitutionType == 0)
                        {
                            <option value="0" selected>University</option>
                        }
                        else
                        {
                            <option value="0">University</option>
                        }

                        @if (Model.SelectedInstitutionType == 1)
                        {
                            <option value="1" selected>School</option>
                        }
                        else
                        {
                            <option value="1">School</option>
                        }

                        @if (Model.SelectedInstitutionType == 2)
                        {
                            <option value="2" selected>College</option>
                        }
                        else
                        {
                            <option value="2">College</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Department</label>
                    <select class="form-select" name="departmentId" id="analyticsDepartmentId">
                        <option value="">All Departments</option>
                        @foreach (var d in Model.Departments)
                        {
                            if (Model.SelectedDepartmentId == d.Id)
                            {
                                <option value="@d.Id" selected>@d.Name</option>
                            }
                            else
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Course</label>
                    <select class="form-select" name="courseId" id="analyticsCourseId">
                        <option value="">All Courses</option>
                        @foreach (var c in Model.Courses)
                        {
                            if (Model.SelectedCourseId == c.Id)
                            {
                                <option value="@c.Id" selected>@c.Name</option>
                            }
                            else
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Semester</label>
                    <select class="form-select" name="semesterId" id="analyticsSemesterId">
                        <option value="">All Semesters</option>
                        @foreach (var s in Model.Semesters)
                        {
                            if (Model.SelectedSemesterId == s.Id)
                            {
                                <option value="@s.Id" selected>@s.Name</option>
                            }
                            else
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 d-flex gap-2 justify-content-end">
                    <button type="submit" class="btn btn-primary">Apply Filters</button>
                    <a asp-action="Analytics" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="analytics-dashboard">
        <div class="row g-3 mb-4" id="analyticsSummaryCards">
            @foreach (var card in Model.Cards)
            {
                <div class="col-12 col-sm-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-muted small text-uppercase fw-semibold mb-1">@card.Icon @card.Label</div>
                            <div class="display-6 fw-bold @card.ColorClass">@card.Value</div>
                            @if (!string.IsNullOrWhiteSpace(card.SubText))
                            {
                                <div class="text-muted small mt-1">@card.SubText</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-bold d-flex align-items-center">
                <i class="bi bi-bar-chart me-2"></i>
                Analytics Overview
            </div>
            <div class="card-body">
                <div id="overviewLegend" class="d-flex flex-wrap gap-2 mb-3"></div>
                <canvas id="sampleChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="accordion" id="analyticsAccordion">

        @* Performance accordion *@
        @if (Model.Performance is not null)
        {
            <div class="accordion-item border-0 shadow-sm mb-3">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapsePerf">
                        <i class="bi bi-bar-chart-line me-2"></i>
                        Performance — @Model.Performance.DepartmentName
                        <span class="badge bg-primary ms-2">Avg @Model.Performance.AverageMarks.ToString("F1")%</span>
                    </button>
                </h2>
                <div id="collapsePerf" class="accordion-collapse collapse show" data-bs-parent="#analyticsAccordion">
                    <div class="accordion-body p-0">
                        @if (Model.Performance.Students.Count == 0)
                        {
                            <p class="text-muted p-3 mb-0">No student data available.</p>
                        }
                        else
                        {
                            <div class="p-3 border-bottom bg-light-subtle">
                                <div id="performanceLegend" class="d-flex flex-wrap gap-2 mb-3"></div>
                                <canvas id="performanceChart" height="120"></canvas>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Reg No.</th>
                                            <th>Name</th>
                                            <th>Semester</th>
                                            <th class="text-end">Avg Marks</th>
                                            <th class="text-end">Assignments</th>
                                            <th class="text-end">Submitted</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var s in Model.Performance.Students)
                                        {
                                            <tr>
                                                <td class="font-monospace small">@s.RegistrationNumber</td>
                                                <td>@s.FullName</td>
                                                <td>Sem @s.CurrentSemester</td>
                                                <td class="text-end fw-semibold">@s.AverageMarks.ToString("F1")%</td>
                                                <td class="text-end">@s.TotalAssignments</td>
                                                <td class="text-end">@s.SubmittedAssignments</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* Attendance accordion *@
        @if (Model.Attendance is not null)
        {
            <div class="accordion-item border-0 shadow-sm mb-3">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapseAtt">
                        <i class="bi bi-calendar-check me-2"></i>
                        Attendance — @Model.Attendance.DepartmentName
                        <span class="badge bg-success ms-2">@Model.Attendance.OverallAttendancePercentage.ToString("F1")% overall</span>
                    </button>
                </h2>
                <div id="collapseAtt" class="accordion-collapse collapse" data-bs-parent="#analyticsAccordion">
                    <div class="accordion-body p-0">
                        @if (Model.Attendance.Rows.Count == 0)
                        {
                            <p class="text-muted p-3 mb-0">No attendance data available.</p>
                        }
                        else
                        {
                            <div class="p-3 border-bottom bg-light-subtle">
                                <div id="attendanceLegend" class="d-flex flex-wrap gap-2 mb-3"></div>
                                <canvas id="attendanceChart" height="120"></canvas>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Student</th>
                                            <th>Course</th>
                                            <th class="text-end">Total Classes</th>
                                            <th class="text-end">Attended</th>
                                            <th class="text-end">Percentage</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in Model.Attendance.Rows)
                                        {
                                            var pct   = r.AttendancePercentage;
                                            var badge = pct >= 75 ? "text-success" : pct >= 50 ? "text-warning" : "text-danger";
                                            <tr>
                                                <td>@r.FullName</td>
                                                <td class="small text-muted">@r.CourseName</td>
                                                <td class="text-end">@r.TotalClasses</td>
                                                <td class="text-end">@r.AttendedClasses</td>
                                                <td class="text-end fw-semibold @badge">@pct.ToString("F1")%</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* Assignments accordion *@
        @if (Model.Assignments is not null)
        {
            <div class="accordion-item border-0 shadow-sm mb-3">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapseAssign">
                        <i class="bi bi-clipboard-check me-2"></i>
                        Assignments — @Model.Assignments.DepartmentName
                        <span class="badge bg-warning text-dark ms-2">@Model.Assignments.Assignments.Count assignments</span>
                    </button>
                </h2>
                <div id="collapseAssign" class="accordion-collapse collapse" data-bs-parent="#analyticsAccordion">
                    <div class="accordion-body p-0">
                        @if (Model.Assignments.Assignments.Count == 0)
                        {
                            <p class="text-muted p-3 mb-0">No assignment data available.</p>
                        }
                        else
                        {
                            <div class="p-3 border-bottom bg-light-subtle">
                                <div id="assignmentLegend" class="d-flex flex-wrap gap-2 mb-3"></div>
                                <canvas id="assignmentChart" height="120"></canvas>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Title</th>
                                            <th>Course</th>
                                            <th class="text-end">Students</th>
                                            <th class="text-end">Submitted</th>
                                            <th class="text-end">Graded</th>
                                            <th class="text-end">Avg Marks</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var a in Model.Assignments.Assignments)
                                        {
                                            <tr>
                                                <td>@a.Title</td>
                                                <td class="small text-muted">@a.CourseName</td>
                                                <td class="text-end">@a.TotalStudents</td>
                                                <td class="text-end">@a.Submissions</td>
                                                <td class="text-end">@a.Graded</td>
                                                <td class="text-end fw-semibold">@a.AverageMarks.ToString("F1")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

    </div>

    @if (Model.Performance is null && Model.Attendance is null && Model.Assignments is null)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <div class="fs-1 mb-2"><i class="bi bi-bar-chart"></i></div>
                <p>No analytics data available.</p>
            </div>
        </div>
    }
}

@if (Model.IsConnected)
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            var snapshotUrl = '@Url.Action("AnalyticsSnapshot", "Portal")';
            var filterForm = document.getElementById('analyticsFilterForm');
            var institutionSelect = document.getElementById('analyticsInstitutionType');
            var departmentSelect = document.getElementById('analyticsDepartmentId');
            var courseSelect = document.getElementById('analyticsCourseId');
            var semesterSelect = document.getElementById('analyticsSemesterId');
            var messageEl = document.getElementById('analyticsMessage');
            var summaryCardsEl = document.getElementById('analyticsSummaryCards');
            var submitButton = filterForm ? filterForm.querySelector('button[type="submit"]') : null;
            var activeRequestId = 0;
            var charts = {
                overview: null,
                performance: null,
                attendance: null,
                assignments: null
            };

            var initialSnapshot = {
                success: true,
                message: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Message)),
                selectedInstitutionType: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SelectedInstitutionType)),
                selectedDepartmentId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SelectedDepartmentId)),
                selectedCourseId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SelectedCourseId)),
                selectedSemesterId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SelectedSemesterId)),
                departments: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Departments)),
                courses: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Courses)),
                semesters: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Semesters)),
                cards: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Cards)),
                performance: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Performance)),
                attendance: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Attendance)),
                assignments: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Assignments))
            };

            function prop(obj, camelName, pascalName, defaultValue) {
                if (!obj) return defaultValue;
                if (Object.prototype.hasOwnProperty.call(obj, camelName)) return obj[camelName];
                if (Object.prototype.hasOwnProperty.call(obj, pascalName)) return obj[pascalName];
                return defaultValue;
            }

            function setLoading(isLoading) {
                [institutionSelect, departmentSelect, courseSelect, semesterSelect, submitButton].forEach(function (el) {
                    if (el) el.disabled = isLoading;
                });
            }

            function showMessage(message) {
                if (!messageEl) return;
                if (!message) {
                    messageEl.classList.add('d-none');
                    messageEl.textContent = '';
                    return;
                }

                messageEl.textContent = message;
                messageEl.classList.remove('d-none');
            }

            function clearSelectValue(selectEl) {
                if (selectEl) {
                    selectEl.value = '';
                }
            }

            function setSelectOptions(selectEl, options, selectedValue, emptyLabel) {
                if (!selectEl) return;
                var normalizedSelected = selectedValue ? String(selectedValue) : '';
                selectEl.innerHTML = '';

                var emptyOption = document.createElement('option');
                emptyOption.value = '';
                emptyOption.textContent = emptyLabel;
                if (!normalizedSelected) {
                    emptyOption.selected = true;
                }
                selectEl.appendChild(emptyOption);

                (options || []).forEach(function (item) {
                    var id = String(prop(item, 'id', 'Id', ''));
                    if (!id) return;
                    var name = prop(item, 'name', 'Name', id);
                    var option = document.createElement('option');
                    option.value = id;
                    option.textContent = name;
                    if (normalizedSelected && normalizedSelected === id) {
                        option.selected = true;
                    }
                    selectEl.appendChild(option);
                });
            }

            function renderSummaryCards(cards) {
                if (!summaryCardsEl) return;
                summaryCardsEl.innerHTML = '';
                (cards || []).forEach(function (card) {
                    var col = document.createElement('div');
                    col.className = 'col-12 col-sm-6 col-xl-4';

                    var cardWrap = document.createElement('div');
                    cardWrap.className = 'card border-0 shadow-sm h-100';

                    var cardBody = document.createElement('div');
                    cardBody.className = 'card-body';

                    var label = document.createElement('div');
                    label.className = 'text-muted small text-uppercase fw-semibold mb-1';
                    label.textContent = (prop(card, 'icon', 'Icon', '') + ' ' + prop(card, 'label', 'Label', '')).trim();

                    var value = document.createElement('div');
                    value.className = 'display-6 fw-bold ' + prop(card, 'colorClass', 'ColorClass', 'text-primary');
                    value.textContent = prop(card, 'value', 'Value', '0');

                    cardBody.appendChild(label);
                    cardBody.appendChild(value);

                    var subTextValue = prop(card, 'subText', 'SubText', null);
                    if (subTextValue) {
                        var subText = document.createElement('div');
                        subText.className = 'text-muted small mt-1';
                        subText.textContent = subTextValue;
                        cardBody.appendChild(subText);
                    }

                    cardWrap.appendChild(cardBody);
                    col.appendChild(cardWrap);
                    summaryCardsEl.appendChild(col);
                });
            }

            function destroyChart(chart) {
                if (chart && typeof chart.destroy === 'function') {
                    chart.destroy();
                }
            }

            if (institutionSelect && filterForm) {
                institutionSelect.addEventListener('change', function () {
                    clearSelectValue(departmentSelect);
                    clearSelectValue(courseSelect);
                    clearSelectValue(semesterSelect);
                    refreshSnapshot();
                });
            }

            if (departmentSelect && filterForm) {
                departmentSelect.addEventListener('change', function () {
                    clearSelectValue(courseSelect);
                    clearSelectValue(semesterSelect);
                    refreshSnapshot();
                });
            }

            if (courseSelect && filterForm) {
                courseSelect.addEventListener('change', function () {
                    clearSelectValue(semesterSelect);
                    refreshSnapshot();
                });
            }

            if (semesterSelect && filterForm) {
                semesterSelect.addEventListener('change', function () {
                    refreshSnapshot();
                });
            }

            if (filterForm) {
                filterForm.addEventListener('submit', function (event) {
                    event.preventDefault();
                    refreshSnapshot();
                });
            }

            function legendColor(dataset, idx) {
                if (Array.isArray(dataset.backgroundColor)) {
                    return dataset.backgroundColor[Math.min(idx, dataset.backgroundColor.length - 1)] || '#6c757d';
                }
                return dataset.borderColor || dataset.backgroundColor || '#6c757d';
            }

            function buildClickableLegend(containerId, chart) {
                var container = document.getElementById(containerId);
                if (!container || !chart || !chart.data || !chart.data.datasets) return;

                container.innerHTML = '';

                chart.data.datasets.forEach(function (dataset, datasetIndex) {
                    var item = document.createElement('button');
                    item.type = 'button';
                    item.className = 'btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-2';

                    var swatch = document.createElement('span');
                    swatch.style.width = '10px';
                    swatch.style.height = '10px';
                    swatch.style.borderRadius = '999px';
                    swatch.style.backgroundColor = legendColor(dataset, datasetIndex);
                    swatch.style.display = 'inline-block';

                    var text = document.createElement('span');
                    text.textContent = dataset.label || ('Series ' + (datasetIndex + 1));

                    item.appendChild(swatch);
                    item.appendChild(text);

                    var updateState = function () {
                        var hidden = !chart.isDatasetVisible(datasetIndex);
                        item.classList.toggle('opacity-50', hidden);
                        item.classList.toggle('text-decoration-line-through', hidden);
                    };

                    item.addEventListener('click', function () {
                        var currentlyVisible = chart.isDatasetVisible(datasetIndex);
                        chart.setDatasetVisibility(datasetIndex, !currentlyVisible);
                        chart.update();
                        updateState();
                    });

                    updateState();
                    container.appendChild(item);
                });
            }

            function renderOverview(snapshot) {
                var el = document.getElementById('sampleChart');
                if (!el) return;

                var performance = snapshot ? prop(snapshot, 'performance', 'Performance', null) : null;
                var attendance = snapshot ? prop(snapshot, 'attendance', 'Attendance', null) : null;
                var assignments = snapshot ? prop(snapshot, 'assignments', 'Assignments', null) : null;

                var overviewLabels = ['Avg Marks', 'Attendance', 'Assignments', 'Students'];
                var overviewValues = [
                    Number(prop(performance, 'averageMarks', 'AverageMarks', 0)) || 0,
                    Number(prop(attendance, 'overallAttendancePercentage', 'OverallAttendancePercentage', 0)) || 0,
                    Number((prop(assignments, 'assignments', 'Assignments', []) || []).length) || 0,
                    Number(prop(performance, 'totalStudents', 'TotalStudents', 0)) || 0
                ];

                destroyChart(charts.overview);

                charts.overview = new Chart(el, {
                    type: 'bar',
                    data: {
                        labels: overviewLabels,
                        datasets: [{
                            label: 'Snapshot Metrics',
                            data: overviewValues,
                            backgroundColor: [
                                'rgba(54, 162, 235, 0.7)',
                                'rgba(255, 206, 86, 0.7)',
                                'rgba(75, 192, 192, 0.7)',
                                'rgba(255, 99, 132, 0.7)'
                            ],
                            borderColor: [
                                'rgba(54, 162, 235, 1)',
                                'rgba(255, 206, 86, 1)',
                                'rgba(75, 192, 192, 1)',
                                'rgba(255, 99, 132, 1)'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true } }
                    }
                });

                buildClickableLegend('overviewLegend', charts.overview);
            }

            function renderPerformance(snapshot) {
                var el = document.getElementById('performanceChart');
                if (!el) return;
                var performance = snapshot ? prop(snapshot, 'performance', 'Performance', null) : null;
                var students = prop(performance, 'students', 'Students', []) || [];
                var labels = students.slice(0, 10).map(function (s) { return prop(s, 'fullName', 'FullName', ''); });
                var values = students.slice(0, 10).map(function (s) { return Number(prop(s, 'averageMarks', 'AverageMarks', 0)) || 0; });
                if (!labels.length) return;

                destroyChart(charts.performance);
                charts.performance = new Chart(el, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Average Marks (%)',
                            data: values,
                            backgroundColor: 'rgba(13, 110, 253, 0.35)',
                            borderColor: 'rgba(13, 110, 253, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true, max: 100 } },
                        plugins: { legend: { display: false } }
                    }
                });

                buildClickableLegend('performanceLegend', charts.performance);
            }

            function renderAttendance(snapshot) {
                var el = document.getElementById('attendanceChart');
                if (!el) return;
                var attendance = snapshot ? prop(snapshot, 'attendance', 'Attendance', null) : null;
                var rows = prop(attendance, 'rows', 'Rows', []) || [];
                var labels = rows.slice(0, 10).map(function (r) { return prop(r, 'fullName', 'FullName', ''); });
                var values = rows.slice(0, 10).map(function (r) { return Number(prop(r, 'attendancePercentage', 'AttendancePercentage', 0)) || 0; });
                if (!labels.length) return;

                destroyChart(charts.attendance);
                charts.attendance = new Chart(el, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Attendance (%)',
                            data: values,
                            fill: true,
                            tension: 0.25,
                            backgroundColor: 'rgba(25, 135, 84, 0.2)',
                            borderColor: 'rgba(25, 135, 84, 1)',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, max: 100 } }
                    }
                });

                buildClickableLegend('attendanceLegend', charts.attendance);
            }

            function renderAssignments(snapshot) {
                var el = document.getElementById('assignmentChart');
                if (!el) return;
                var assignmentReport = snapshot ? prop(snapshot, 'assignments', 'Assignments', null) : null;
                var assignments = prop(assignmentReport, 'assignments', 'Assignments', []) || [];
                var labels = assignments.slice(0, 8).map(function (a) { return prop(a, 'title', 'Title', ''); });
                var submitted = assignments.slice(0, 8).map(function (a) { return Number(prop(a, 'submissions', 'Submissions', 0)) || 0; });
                var graded = assignments.slice(0, 8).map(function (a) { return Number(prop(a, 'graded', 'Graded', 0)) || 0; });
                if (!labels.length) return;

                destroyChart(charts.assignments);
                charts.assignments = new Chart(el, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Submitted',
                                data: submitted,
                                backgroundColor: 'rgba(255, 193, 7, 0.45)',
                                borderColor: 'rgba(255, 193, 7, 1)',
                                borderWidth: 1
                            },
                            {
                                label: 'Graded',
                                data: graded,
                                backgroundColor: 'rgba(13, 202, 240, 0.45)',
                                borderColor: 'rgba(13, 202, 240, 1)',
                                borderWidth: 1
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } }
                    }
                });

                buildClickableLegend('assignmentLegend', charts.assignments);
            }

            function applySnapshot(snapshot) {
                showMessage(snapshot && snapshot.message ? snapshot.message : '');

                var selectedInstitutionType = prop(snapshot, 'selectedInstitutionType', 'SelectedInstitutionType', null);
                var selectedDepartmentId = prop(snapshot, 'selectedDepartmentId', 'SelectedDepartmentId', null);
                var selectedCourseId = prop(snapshot, 'selectedCourseId', 'SelectedCourseId', null);
                var selectedSemesterId = prop(snapshot, 'selectedSemesterId', 'SelectedSemesterId', null);

                if (institutionSelect) {
                    institutionSelect.value = selectedInstitutionType !== null && selectedInstitutionType !== undefined
                        ? String(selectedInstitutionType)
                        : '';
                }

                setSelectOptions(departmentSelect, prop(snapshot, 'departments', 'Departments', []), selectedDepartmentId, 'All Departments');
                setSelectOptions(courseSelect, prop(snapshot, 'courses', 'Courses', []), selectedCourseId, 'All Courses');
                setSelectOptions(semesterSelect, prop(snapshot, 'semesters', 'Semesters', []), selectedSemesterId, 'All Semesters');

                renderSummaryCards(prop(snapshot, 'cards', 'Cards', []));
                renderOverview(snapshot);
                renderPerformance(snapshot);
                renderAttendance(snapshot);
                renderAssignments(snapshot);
            }

            function buildSnapshotQuery() {
                var query = new URLSearchParams();
                if (institutionSelect && institutionSelect.value) query.set('institutionType', institutionSelect.value);
                if (departmentSelect && departmentSelect.value) query.set('departmentId', departmentSelect.value);
                if (courseSelect && courseSelect.value) query.set('courseId', courseSelect.value);
                if (semesterSelect && semesterSelect.value) query.set('semesterId', semesterSelect.value);
                return query;
            }

            async function refreshSnapshot() {
                var currentRequest = ++activeRequestId;
                setLoading(true);

                try {
                    var response = await fetch(snapshotUrl + '?' + buildSnapshotQuery().toString(), {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error('Unable to load analytics snapshot.');
                    }

                    var snapshot = await response.json();
                    if (currentRequest !== activeRequestId) {
                        return;
                    }

                    if (!snapshot || snapshot.success === false) {
                        showMessage(snapshot && snapshot.message ? snapshot.message : 'Unable to load analytics data.');
                        return;
                    }

                    applySnapshot(snapshot);
                } catch (error) {
                    if (currentRequest !== activeRequestId) {
                        return;
                    }

                    showMessage(error && error.message ? error.message : 'Unable to load analytics data.');
                } finally {
                    if (currentRequest === activeRequestId) {
                        setLoading(false);
                    }
                }
            }

            applySnapshot(initialSnapshot);
        })();
    </script>
}
