            function renderStudentDistribution(snapshot) {
                var el = document.getElementById('studentDistributionChart');
                if (!el) return;

                var performance = snapshot ? prop(snapshot, 'performance', 'Performance', null) : null;
                var students = prop(performance, 'students', 'Students', []) || [];
                var grouped = {};

                students.forEach(function (student) {
                    var semester = Number(prop(student, 'currentSemester', 'CurrentSemester', 0)) || 0;
                    if (semester <= 0) return;
                    var key = 'Sem ' + semester;
                    grouped[key] = (grouped[key] || 0) + 1;
                });

                var labels = Object.keys(grouped).sort(function (a, b) {
                    return Number(a.replace('Sem ', '')) - Number(b.replace('Sem ', ''));
                });
                var values = labels.map(function (key) { return grouped[key]; });

                destroyChart(charts.studentDistribution);

                if (!labels.length) {

                    clearChartCanvas(el, 'No student distribution data available.');
                    charts.studentDistribution = null;
                    return;
                }

                charts.studentDistribution = new Chart(el, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Students',
                            data: values,
                            backgroundColor: labels.map(function (_, idx) { return palette(idx, 0.72); }),
                            borderColor: labels.map(function (_, idx) { return palette(idx, 1); }),
                            borderWidth: 2,
                            hoverBorderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        cutout: '55%',
                        radius: '75%',
                        layout: {
                            padding: 24
                        },
                        plugins: {
                            legend: { display: true, position: 'bottom', labels: { padding: 16, usePointStyle: true } },
                            tooltip: {
                                padding: 12,
                                cornerRadius: 6
                            }
                        }
                    }
                });


            }

            function renderPaymentStatus(snapshot) {
                var el = document.getElementById('paymentStatusChart');
                if (!el) return;

                var paymentStatus = snapshot ? prop(snapshot, 'paymentStatus', 'PaymentStatus', null) : null;
                var slices = prop(paymentStatus, 'slices', 'Slices', []) || [];

                var labels = [];
                var values = [];

                slices.forEach(function (slice) {
                    var label = prop(slice, 'status', 'Status', '');
                    var count = Number(prop(slice, 'count', 'Count', 0)) || 0;
                    if (!label) return;
                    labels.push(label);
                    values.push(count);
                });

                if (!labels.length) {
                    var paid = Number(prop(paymentStatus, 'paidCount', 'PaidCount', 0)) || 0;
                    var unpaid = Number(prop(paymentStatus, 'unpaidCount', 'UnpaidCount', 0)) || 0;
                    labels = ['Paid', 'Unpaid'];
                    values = [paid, unpaid];
                }

                destroyChart(charts.paymentStatus);

                if (!values.some(function (v) { return v > 0; })) {

                    clearChartCanvas(el, 'No payment status data available.');
                    charts.paymentStatus = null;
                    return;
                }

                charts.paymentStatus = new Chart(el, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Receipts',
                            data: values,
                            backgroundColor: labels.map(function (_, idx) { return palette(idx, 0.72); }),
                            borderColor: labels.map(function (_, idx) { return palette(idx, 1); }),
                            borderWidth: 2,
                            hoverBorderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        cutout: '55%',
                        radius: '75%',
