@model Tabsan.EduSphere.Web.Models.Portal.PaymentsPageModel
@{ ViewData["Title"] = "Payment Receipts"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info alert-dismissible fade show">@Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    var canManagePayments = Model.Identity?.IsSuperAdmin == true || Model.Identity?.IsAdmin == true || Model.Identity?.IsFinance == true;
    var isStudent = Model.Identity?.IsStudent == true;
    var hasStudentOptions = Model.Students.Count > 0;

    @* ── Admin: Create Receipt Form ──────────────────────────────────── *@
    @if (canManagePayments && hasStudentOptions)
    {
        <div class="page-section-card card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">Create Fee Receipt</div>
            <div class="card-body">
                <form method="post" asp-action="CreatePayment">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Student</label>
                            <select name="StudentProfileId" class="form-select" required>
                                <option value="">— Select Student —</option>
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id">@s.FullName (@s.RegistrationNumber)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Amount</label>
                            <input name="Amount" type="number" step="0.01" min="0.01" class="form-control" placeholder="e.g. 5000" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Receipt No</label>
                            <input name="ReceiptNo" type="text" class="form-control" placeholder="e.g. RCPT-2026-0001" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Description</label>
                            <input name="Description" type="text" class="form-control" placeholder="e.g. Semester 1 Tuition" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Due Date</label>
                            <input name="DueDate" type="date" class="form-control"
                                   value="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-12 d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary w-100">Create</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
    else if (canManagePayments)
    {
        <div class="alert alert-warning mb-3">
            No students available in the current scope. Change tenant/campus filters or verify student seed data.
        </div>
    }

    @* ── Filter by Student (Admin) ───────────────────────────────────── *@
    @if (canManagePayments)
    {
        <div class="page-section-card card border-0 shadow-sm mb-3">
            <div class="card-body py-2">
                <form method="get" asp-action="Payments" class="row g-2 align-items-end filter-toolbar">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-3">
                            <label class="form-label mb-1">Tenant</label>
                            <select name="tenantId" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var tenant in Model.Tenants)
                                {
                                    <option value="@tenant.Id" selected="@(Model.SelectedTenantId == tenant.Id)">@tenant.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label mb-1">Campus</label>
                            <select name="campusId" class="form-select form-select-sm" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var campus in Model.Campuses)
                                {
                                    <option value="@campus.Id" selected="@(Model.SelectedCampusId == campus.Id)">@campus.Name</option>
                                }
                            </select>
                        </div>
                    }
                    @if (Model.AvailableInstitutionTypes.Count > 0)
                    {
                        <div class="col-md-3">
                            <label class="form-label mb-1">Institution</label>
                            <select name="institutionType" class="form-select form-select-sm" onchange="this.form.submit()">
                                @foreach (var institutionOption in Model.AvailableInstitutionTypes)
                                {
                                    <option value="@institutionOption.Value" selected="@(Model.SelectedInstitutionType == institutionOption.Value)">@institutionOption.Label</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-5">
                        <label class="form-label mb-1">Filter by Student</label>
                        <select name="studentId" class="form-select form-select-sm" onchange="this.form.submit()" disabled="@(!hasStudentOptions)">
                            <option value="">All Students</option>
                            @foreach (var s in Model.Students)
                            {
                                <option value="@s.Id" selected="@(Model.SelectedStudentId == s.Id)">
                                    @s.FullName (@s.RegistrationNumber)
                                </option>
                            }
                        </select>
                    </div>
                    @if (Model.SelectedStudentId.HasValue)
                    {
                        <div class="col-auto">
                            <a asp-action="Payments" asp-route-tenantId="@Model.SelectedTenantId" asp-route-campusId="@Model.SelectedCampusId" asp-route-institutionType="@Model.SelectedInstitutionType" class="btn btn-sm btn-outline-secondary">Clear Filter</a>
                        </div>
                    }
                </form>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-action="ExportPaymentsCsvTemplate" class="btn btn-sm btn-outline-primary">Export Template</a>
                    <form method="post" asp-action="ImportPaymentsCsv" enctype="multipart/form-data" class="d-flex flex-wrap align-items-center gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                        <input type="hidden" name="page" value="@Model.Page" />
                        <input type="file" name="csvFile" class="form-control form-control-sm" accept=".csv,text/csv" required />
                        <button type="submit" class="btn btn-sm btn-outline-success">Import CSV</button>
                    </form>
                </div>
            </div>
        </div>
    }

    @* ── Receipts Table ──────────────────────────────────────────────── *@
    <div class="page-section-card card border-0 shadow-sm">
        <div class="card-body">
            <div class="section-head mb-3">
                <div>
                    <span class="section-kicker">Finance receipts</span>
                    <h2 class="h5 mb-1">
                        @(canManagePayments ? "All Receipts" : "My Receipts")
                        <span class="badge bg-secondary ms-1">@Model.Payments.Count</span>
                    </h2>
                    <p class="text-muted mb-0">Track payment status, confirmations, and proof submissions.</p>
                </div>
            </div>

            @if (Model.Payments.Count == 0)
            {
                <div class="empty-state-card">
                    <h3>No payment receipts found</h3>
                    <p class="text-muted mb-0">Receipts will appear here once payment requests are created.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                @if (canManagePayments) { <th>Student</th> }
                                <th>Receipt No</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th>Confirmed</th>
                                <th>Last Updated</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Payments)
                            {
                                var badgeCls = r.Status switch
                                {
                                    "Paid"      => "bg-success",
                                    "Pending"   => "bg-warning text-dark",
                                    "Submitted" => "bg-info text-dark",
                                    "Cancelled" => "bg-secondary",
                                    _           => "bg-secondary"
                                };
                                <tr>
                                    @if (canManagePayments)
                                    {
                                        <td>
                                            <div class="fw-semibold">@r.StudentName</div>
                                            <small class="text-muted">@r.RegistrationNumber</small>
                                        </td>
                                    }
                                    <td class="fw-semibold">@r.ReceiptNo</td>
                                    <td>
                                        @r.FeeType
                                        @if (!string.IsNullOrWhiteSpace(r.ProofOfPaymentPath))
                                        {
                                            <br /><small class="text-muted">Proof: @r.ProofOfPaymentPath</small>
                                        }
                                    </td>
                                    <td class="fw-semibold">@r.Amount.ToString("N2")</td>
                                    <td>@r.DueDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge stat-pill @badgeCls">@r.Status</span></td>
                                    <td>@(r.PaidDate?.ToString("dd MMM yyyy") ?? "–")</td>
                                    <td>@(r.UpdatedAt?.ToString("dd MMM yyyy HH:mm") ?? "–")</td>
                                    <td>
                                        @* Admin actions: Confirm (Pending/Submitted) or Cancel (not Paid/Cancelled) *@
                                        @if (canManagePayments)
                                        {
                                            @if (r.Status is "Pending" or "Submitted")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary me-1 mb-1"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#edit-@r.Id">
                                                    Edit
                                                </button>
                                            }
                                            @if (r.Status is "Pending" or "Submitted")
                                            {
                                                <form method="post" asp-action="ConfirmPayment" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="receiptId" value="@r.Id" />
                                                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                    <input type="hidden" name="page" value="@Model.Page" />
                                                    <button type="submit" class="btn btn-sm btn-success me-1"
                                                            onclick="return confirm('Mark this receipt as Paid?')">
                                                        Confirm Paid
                                                    </button>
                                                </form>
                                            }
                                            @if (r.Status is not ("Paid" or "Cancelled"))
                                            {
                                                <form method="post" asp-action="CancelPayment" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="receiptId" value="@r.Id" />
                                                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                    <input type="hidden" name="page" value="@Model.Page" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            onclick="return confirm('Cancel this receipt?')">
                                                        Cancel
                                                    </button>
                                                </form>
                                            }
                                            @if (r.Status is "Pending" or "Submitted")
                                            {
                                                <div class="collapse mt-2" id="edit-@r.Id">
                                                    <form method="post" asp-action="UpdatePayment" class="card card-body p-3">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="receiptId" value="@r.Id" />
                                                        <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                        <input type="hidden" name="page" value="@Model.Page" />
                                                        <div class="row g-2">
                                                            <div class="col-md-4">
                                                                <label class="form-label small mb-1">Amount</label>
                                                                <input type="number" step="0.01" min="0" name="amount" class="form-control form-control-sm" value="@r.Amount" required />
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label small mb-1">Receipt No</label>
                                                                <input type="text" name="receiptNo" class="form-control form-control-sm" value="@r.ReceiptNo" required />
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label small mb-1">Due Date</label>
                                                                <input type="date" name="dueDate" class="form-control form-control-sm" value="@r.DueDate.ToString("yyyy-MM-dd")" required />
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label small mb-1">Notes</label>
                                                                <input type="text" name="notes" class="form-control form-control-sm" value="@r.Notes" />
                                                            </div>
                                                            <div class="col-12">
                                                                <label class="form-label small mb-1">Description</label>
                                                                <input type="text" name="description" class="form-control form-control-sm" value="@r.FeeType" required />
                                                            </div>
                                                        </div>
                                                        <div class="mt-3 d-flex gap-2">
                                                            <button type="submit" class="btn btn-sm btn-primary">Save Changes</button>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#edit-@r.Id">Close</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            }
                                        }
                                        @* Student action: Submit proof when Pending *@
                                        @if (isStudent && r.Status == "Pending")
                                        {
                                            <button type="button" class="btn btn-sm btn-primary"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#proof-@r.Id">
                                                Submit Proof
                                            </button>
                                            <div class="collapse mt-2" id="proof-@r.Id">
                                                <form method="post" asp-action="SubmitProof">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="receiptId" value="@r.Id" />
                                                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                    <input type="hidden" name="page" value="@Model.Page" />
                                                    <div class="input-group input-group-sm">
                                                        <input type="text" name="proofNote" class="form-control"
                                                               placeholder="Transaction ID or reference note" required />
                                                        <button type="submit" class="btn btn-success">Submit</button>
                                                    </div>
                                                </form>
                                            </div>
                                        }
                                        @if (r.Status is "Paid" or "Cancelled")
                                        {
                                            <span class="text-muted small">–</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3 responsive-pagination">
                    <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : null)"
                       href="@Url.Action("Payments", "Portal", new { studentId = Model.SelectedStudentId, tenantId = Model.SelectedTenantId, campusId = Model.SelectedCampusId, institutionType = Model.SelectedInstitutionType, page = Model.Page - 1 })">
                        Previous
                    </a>
                    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
                    <a class="btn btn-sm btn-outline-secondary @(Model.Page >= Model.TotalPages ? "disabled" : null)"
                       href="@Url.Action("Payments", "Portal", new { studentId = Model.SelectedStudentId, tenantId = Model.SelectedTenantId, campusId = Model.SelectedCampusId, institutionType = Model.SelectedInstitutionType, page = Model.Page + 1 })">
                        Next
                    </a>
                </div>
            }
        </div>
    </div>
}
