@* Final-Touches Phase 18 Stage 18.1 — graduation applications list for staff *@
@model GraduationApplicationsPageModel
@{
    ViewBag.Title = "Graduation Applications";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = User.IsInRole("Admin");
    var isSuperAdmin = User.IsInRole("SuperAdmin");
}

<div class="container-fluid">
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-mortarboard me-2"></i>Graduation Applications</h2>
    </div>

    @* Filters *@
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        @foreach (var s in new[] { "Draft", "PendingFaculty", "PendingAdmin", "PendingFinalApproval", "Approved", "Rejected" })
                        {
                            <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                        }
                    </select>
                </div>
                @if (Model.Departments.Any())
                {
                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.DepartmentFilter == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-auto">
                    <button type="submit" class="btn btn-outline-primary"><i class="bi bi-filter me-1"></i>Filter</button>
                    <a href="@Url.Action("GraduationApplications", "Portal")" class="btn btn-outline-secondary ms-2">Clear</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Applications.Any())
    {
        <div class="alert alert-info">No applications found.</div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Student</th>
                            <th>Reg. Number</th>
                            <th>Program</th>
                            <th>Status</th>
                            <th>Submitted</th>
                            <th>Certificate</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            <tr>
                                <td>@app.StudentName</td>
                                <td>@app.RegistrationNumber</td>
                                <td>@app.ProgramName</td>
                                <td>
                                    <span class="badge @(app.Status == "Approved" ? "bg-success" : app.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                        @app.Status
                                    </span>
                                </td>
                                <td>@app.SubmittedAt?.ToString("dd MMM yyyy")</td>
                                <td>@(app.HasCertificate ? "Yes" : "—")</td>
                                <td>
                                    <a href="@Url.Action("GraduationApplicationDetail", "Portal", new { id = app.Id })" class="btn btn-sm btn-outline-primary">View</a>
                                    @{
                                        var canQuickApprove = (isAdmin && app.Status == "PendingAdmin")
                                            || (isSuperAdmin && (app.Status == "PendingAdmin" || app.Status == "PendingFinalApproval"));
                                    }
                                    @if (canQuickApprove)
                                    {
                                        <form method="post"
                                              asp-action="GraduationApprove"
                                              asp-controller="Portal"
                                              asp-route-id="@app.Id"
                                              class="d-inline ms-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="action" value="approve" />
                                            <input type="hidden" name="note" value="Approved from applications list." />
                                            <button type="submit"
                                                    class="btn btn-sm btn-success"
                                                    onclick="return confirm('Approve this graduation application?');">
                                                Approve
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : null)"
                       href="@Url.Action("GraduationApplications", "Portal", new { status = Model.StatusFilter, departmentId = Model.DepartmentFilter, page = Model.Page - 1 })">
                        Previous
                    </a>
                    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
                    <a class="btn btn-sm btn-outline-secondary @(Model.Page >= Model.TotalPages ? "disabled" : null)"
                       href="@Url.Action("GraduationApplications", "Portal", new { status = Model.StatusFilter, departmentId = Model.DepartmentFilter, page = Model.Page + 1 })">
                        Next
                    </a>
                </div>
            }
        </div>
    }
</div>
