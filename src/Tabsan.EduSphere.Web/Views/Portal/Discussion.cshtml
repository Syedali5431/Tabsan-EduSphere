@model Tabsan.EduSphere.Web.Models.Portal.DiscussionPageModel
@{
    ViewData["Title"]     = "Discussion";
    ViewData["PageTitle"] = "Discussion Forum";
    ViewData["ActivePage"] = "discussion";
}

@* Final-Touches Phase 20 Stage 20.3 — discussion forum listing page *@

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">API is not available.</div>
    return;
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.SuccessMessage <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @Model.ErrorMessage <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header"><strong>Start a New Thread</strong></div>
    <div class="card-body">
        <form asp-action="CreateDiscussionThread" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="offeringId" value="@Model.OfferingId" />
            <div class="input-group">
                <input name="title" class="form-control" placeholder="Thread title..." required />
                <button type="submit" class="btn btn-primary">Post</button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Threads.Any())
{
    <div class="alert alert-info">No threads yet. Be the first to start a discussion!</div>
}
else
{
    <div class="list-group">
        @foreach (var thread in Model.Threads)
        {
            <div class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        @if (thread.IsPinned) { <span class="badge bg-warning text-dark me-1">Pinned</span> }
                        @if (thread.IsSolved) { <span class="badge bg-success me-1">Resolved</span> }
                        @if (thread.IsClosed) { <span class="badge bg-secondary me-1">Closed</span> }
                        <a asp-action="DiscussionThreadDetail"
                           asp-route-threadId="@thread.Id"
                           asp-route-offeringId="@Model.OfferingId"
                           class="text-decoration-none fw-semibold">@thread.Title</a>
                    </div>
                    <small class="text-muted">@thread.CreatedAt.ToString("MMM dd, yyyy")</small>
                </div>
                <div class="d-flex justify-content-between mt-1">
                    <small class="text-muted">
                        by @thread.AuthorName &nbsp;·&nbsp; @thread.ReplyCount replies
                        @if (!string.IsNullOrWhiteSpace(thread.TicketNumber))
                        {
                            <text>&nbsp;·&nbsp; Ticket: @thread.TicketNumber</text>
                        }
                    </small>
                    @if (Model.CanModerate)
                    {
                        <form asp-action="DeleteDiscussionThread" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this thread?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="threadId" value="@thread.Id" />
                            <input type="hidden" name="offeringId" value="@Model.OfferingId" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
