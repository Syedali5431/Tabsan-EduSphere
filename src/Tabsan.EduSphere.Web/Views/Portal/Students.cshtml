@model Tabsan.EduSphere.Web.Models.Portal.StudentsPageModel
@{ ViewData["Title"] = "Students"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-danger">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <section class="page-section-card card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="section-head mb-3">
                <div>
                    <span class="section-kicker">Student directory</span>
                    <h2 class="h5 mb-1">Filter and manage students</h2>
                    <p class="text-muted mb-0">Narrow by department and review student lifecycle status in one view.</p>
                </div>
            </div>
            <form method="get" asp-action="Students" class="row g-2 align-items-end filter-toolbar">
                <div class="col-md-4">
                    <label class="form-label">Filter by Department</label>
                    <select name="departmentId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Departments</option>
                        @foreach (var d in Model.Departments)
                        {
                            <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </section>

    <section class="page-section-card card border-0 shadow-sm">
        <div class="card-body">
            <div class="section-head mb-3">
                <h2 class="h5 mb-0">Student List
                    <span class="badge bg-secondary ms-2">@Model.Students.Count</span>
                </h2>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createStudentModal">
                        Add Student
                    </button>
                }
            </div>

            @if (Model.Students.Count == 0)
            {
                <div class="empty-state-card">
                    <h3>No students found</h3>
                    <p class="text-muted mb-0">Try selecting a different department or add your first student record.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Reg. No.</th>
                                <th>Full Name</th>
                                <th>Department</th>
                                <th>Program</th>
                                <th>Level</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Students)
                            {
                                <tr>
                                    <td><code>@s.RegistrationNumber</code></td>
                                    <td>@s.FullName</td>
                                    <td>@s.DepartmentName</td>
                                    <td>@s.ProgramName</td>
                                    <td>@s.SemesterNumber</td>
                                    <td>
                                        <span class="badge stat-pill @(s.Status == "Active" ? "bg-success" : s.Status == "Graduated" ? "bg-primary" : "bg-secondary")">
                                            @s.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
}

<!-- Create Student Modal -->
<div class="modal fade" id="createStudentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createStudentForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Registration Number</label>
                        <input type="text" name="registrationNumber" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Program</label>
                        <select name="programId" class="form-select" required>
                            <option value="">Select a program</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select" required>
                            <option value="">Select a department</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Admission Date</label>
                        <input type="date" name="admissionDate" class="form-control" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Student</button>
                </div>
            </form>
        </div>
    </div>
</div>
