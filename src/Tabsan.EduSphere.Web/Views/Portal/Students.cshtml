@model Tabsan.EduSphere.Web.Models.Portal.StudentsPageModel
@{ ViewData["Title"] = "Students"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-danger">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <section class="page-section-card card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="section-head mb-3">
                <div>
                    <span class="section-kicker">Student directory</span>
                    <h2 class="h5 mb-1">Filter and view students</h2>
                    <p class="text-muted mb-0">Narrow by department and review student lifecycle status in one view.</p>
                </div>
            </div>
            <form method="get" asp-action="Students" class="row g-2 align-items-end filter-toolbar">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-2">
                            <label class="form-label">Institute</label>
                            @if (Model.AvailableInstitutionTypes?.Count > 1)
                            {
                                <select name="institutionType" class="form-select" onchange="this.form.submit()">
                                    <option value="">All</option>
                                    @foreach (var it in Model.AvailableInstitutionTypes)
                                    {
                                        <option value="@it.Value" selected="@(Model.SelectedInstitutionType == it.Value ? "selected" : null)">@it.Label</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <select class="form-select" disabled><option>@(Model.AvailableInstitutionTypes?.FirstOrDefault()?.Label ?? "All")</option></select>
                            }
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id)">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id)">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <div class="col-md-2">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id)">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                <div class="col-md-4">
                    <label class="form-label">Department</label>
                    <select name="departmentId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Departments</option>
                        @foreach (var d in Model.Departments)
                        {
                            <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </section>

    <section class="page-section-card card border-0 shadow-sm">
        <div class="card-body">
            <div class="section-head mb-3">
                <h2 class="h5 mb-0">Student List
                    <span class="badge bg-secondary ms-2">@Model.Students.Count</span>
                </h2>
            </div>

            @if (Model.Students.Count == 0)
            {
                <div class="empty-state-card">
                    <h3>No students found</h3>
                    <p class="text-muted mb-0">Try selecting a different department.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Reg. No.</th>
                                <th>Full Name</th>
                                <th>Department</th>
                                <th>Program</th>
                                <th>Level</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Students)
                            {
                                <tr>
                                    <td><code>@s.RegistrationNumber</code></td>
                                    <td>@s.FullName</td>
                                    <td>@s.DepartmentName</td>
                                    <td>@s.ProgramName</td>
                                    <td>@s.SemesterNumber</td>
                                    <td>
                                        <span class="badge stat-pill @(s.Status == "Active" ? "bg-success" : s.Status == "Graduated" ? "bg-primary" : "bg-secondary")">
                                            @s.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
}
