@model Tabsan.EduSphere.Web.Models.Portal.AssignmentsPageModel
@{ ViewData["Title"] = "Assignments"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.Identity?.IsSuperAdmin == true)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-action="Assignments" class="row g-2 align-items-end">
                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                    <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                    <div class="col-md-3">
                        <label class="form-label">Tenant</label>
                        <select name="tenantId" class="form-select" onchange="this.form.submit()">
                            <option value="">All tenants</option>
                            @foreach (var t in Model.Tenants)
                            {
                                <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name (@t.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Campus</label>
                        <select name="campusId" class="form-select" onchange="this.form.submit()">
                            <option value="">All campuses</option>
                            @foreach (var c in Model.Campuses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label d-block">&nbsp;</label>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="includeInactive" name="includeInactive" value="true" @(Model.IncludeInactive ? "checked" : null) onchange="this.form.submit()" />
                            <label class="form-check-label" for="includeInactive">Show inactive assignments</label>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (Model.CourseOfferings.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-action="Assignments" class="row g-2 align-items-end">
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    <input type="hidden" name="includeInactive" value="@Model.IncludeInactive" />
                    @if (User.IsInRole("Student") && Model.SemesterOptions.Count > 0)
                    {
                        <div class="col-md-4">
                            <label class="form-label">Select Semester</label>
                            <select name="semesterName" class="form-select" onchange="this.form.submit()">
                                <option value="">All Semesters</option>
                                @foreach (var s in Model.SemesterOptions)
                                {
                                    <option value="@s.Name" selected="@(string.Equals(Model.SelectedSemesterName, s.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@s.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-5">
                        <label class="form-label">Select Course Offering</label>
                        <select name="offeringId" class="form-select" onchange="this.form.submit()">
                            <option value="">Choose an offering…</option>
                            @foreach (var o in Model.CourseOfferings)
                            {
                                <option value="@o.Id" selected="@(Model.SelectedOfferingId == o.Id ? "selected" : null)">@o.Name</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Assignments <span class="badge bg-secondary ms-1">@Model.Assignments.Count</span></h2>
                @if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                {
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createAssignmentModal">
                        + Create Assignment
                    </button>
                }
            </div>

            @if (Model.Assignments.Count == 0)
            {
                <p class="text-muted">No assignments found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Title</th>
                                <th>Course</th>
                                <th>Due Date</th>
                                <th>Marks</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.Assignments)
                            {
                                <tr class="@(Model.SelectedAssignmentId == a.Id ? "table-primary" : "")">
                                    <td>
                                        @if (Model.SelectedOfferingId.HasValue)
                                        {
                                            <a asp-action="Assignments"
                                                              asp-route-semesterName="@Model.SelectedSemesterName"
                                               asp-route-offeringId="@Model.SelectedOfferingId"
                                               asp-route-selectedAssignmentId="@a.Id">@a.Title</a>
                                        }
                                        else { @a.Title }
                                    </td>
                                    <td>@a.CourseOfferingTitle</td>
                                    <td>@(a.DueDate?.ToString("dd MMM yyyy") ?? "–")</td>
                                    <td>
                                        @(a.MarksAwarded.HasValue ? $"{a.MarksAwarded}/{a.TotalMarks}" : $"– / {a.TotalMarks}")
                                    </td>
                                    <td>
                                        @if (!a.IsActive)
                                        {
                                            <span class="badge bg-danger me-1">Inactive</span>
                                        }
                                        @if (a.IsSubmitted)
                                        {
                                            <span class="badge bg-success">Submitted</span>
                                        }
                                        else if (a.IsPublished)
                                        {
                                            <span class="badge bg-primary">Open</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Draft</span>
                                        }
                                    </td>
                                    <td class="text-end" style="white-space:nowrap">
                                        @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                        {
                                            @if (!a.IsPublished)
                                            {
                                                <button type="button" class="btn btn-xs btn-outline-secondary btn-sm"
                                                        data-bs-toggle="modal" data-bs-target="#editAssignmentModal"
                                                        data-id="@a.Id" data-title="@a.Title" data-description="@a.Description"
                                                        data-duedate="@(a.DueDate?.ToString("yyyy-MM-ddTHH:mm") ?? string.Empty)" data-maxmarks="@a.TotalMarks">
                                                    Edit
                                                </button>
                                                <form asp-action="PublishAssignment" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@a.Id" />
                                                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <button type="submit" class="btn btn-xs btn-outline-success btn-sm">Publish</button>
                                                </form>
                                            }
                                            <form asp-action="SetAssignmentActive" method="post" class="d-inline"
                                                  onsubmit="return confirm('@(a.IsActive ? "Deactivate" : "Activate") this assignment?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@a.Id" />
                                                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <input type="hidden" name="includeInactive" value="true" />
                                                <input type="hidden" name="activate" value="@(!a.IsActive)" />
                                                @if (a.IsActive)
                                                {
                                                    <button type="submit" class="btn btn-xs btn-outline-danger btn-sm">Deactivate</button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-xs btn-outline-success btn-sm">Activate</button>
                                                }
                                            </form>
                                        }
                                        else if (User.IsInRole("Student"))
                                        {
                                            @if (!a.IsSubmitted && a.IsPublished)
                                            {
                                                <button type="button" class="btn btn-xs btn-outline-primary btn-sm"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#submitAssignmentModal"
                                                        data-assignmentid="@a.Id"
                                                        data-assignmenttitle="@a.Title">
                                                    Submit
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (Model.Submissions.Count > 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h3 class="h5 mb-3">Submissions
                    <span class="badge bg-secondary ms-1">@Model.Submissions.Count</span>
                </h3>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Reg. No.</th>
                                <th>Submitted At</th>
                                <th>Marks</th>
                                <th>Feedback</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Submissions)
                            {
                                <tr>
                                    <td>@s.StudentName</td>
                                    <td><code>@s.RegistrationNumber</code></td>
                                    <td>@s.SubmittedAt.ToString("dd MMM yyyy, HH:mm")</td>
                                    <td>
                                        @(s.MarksAwarded.HasValue ? s.MarksAwarded.ToString() : "–")
                                    </td>
                                    <td class="small text-muted">@s.FeedbackFromFaculty</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#gradeModal"
                                                data-assignmentid="@Model.SelectedAssignmentId"
                                                data-studentid="@s.Id"
                                                data-marks="@(s.MarksAwarded ?? 0)"
                                                data-feedback="@s.FeedbackFromFaculty">
                                            Grade
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@* ── Create Assignment Modal ─────────────────────────────────────────────── *@
<div class="modal fade" id="createAssignmentModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateAssignment" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Assignment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input name="title" class="form-control" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Due Date <span class="text-danger">*</span></label>
                        <input name="dueDate" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Max Marks <span class="text-danger">*</span></label>
                        <input name="maxMarks" type="number" step="0.5" min="1" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
{
    <div class="modal fade" id="editAssignmentModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="UpdateAssignment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit_assignmentId" name="id" />
                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Assignment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input id="edit_assignmentTitle" name="title" class="form-control" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea id="edit_assignmentDescription" name="description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Due Date <span class="text-danger">*</span></label>
                            <input id="edit_assignmentDueDate" name="dueDate" type="datetime-local" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Marks <span class="text-danger">*</span></label>
                            <input id="edit_assignmentMaxMarks" name="maxMarks" type="number" step="0.5" min="1" class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@* ── Grade Submission Modal ───────────────────────────────────────────────── *@
<div class="modal fade" id="gradeModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="GradeSubmission" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="grade_assignmentId" name="assignmentId" />
            <input type="hidden" id="grade_studentProfileId" name="studentProfileId" />
            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Grade Submission</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Marks Awarded <span class="text-danger">*</span></label>
                        <input id="grade_marks" name="marksAwarded" type="number" step="0.5" min="0" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Feedback</label>
                        <textarea id="grade_feedback" name="feedback" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Grade</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (User.IsInRole("Student"))
{
    <div class="modal fade" id="submitAssignmentModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="SubmitAssignment" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" id="submit_assignmentId" name="assignmentId" />
                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Submit Assignment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted mb-3" id="submit_assignmentTitle"></p>
                        <div class="mb-3">
                            <label class="form-label">Upload File</label>
                            <input type="file" class="form-control" name="submissionFile" />
                            <div class="form-text">Accepted: any document your faculty expects.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes / Text Submission</label>
                            <textarea class="form-control" name="textContent" rows="4" placeholder="Optional notes, summary, or submission text"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit for Review</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<script>
document.getElementById('gradeModal')?.addEventListener('show.bs.modal', function (e) {
    var btn = e.relatedTarget;
    document.getElementById('grade_assignmentId').value  = btn.dataset.assignmentid;
    document.getElementById('grade_studentProfileId').value = btn.dataset.studentid;
    document.getElementById('grade_marks').value    = btn.dataset.marks;
    document.getElementById('grade_feedback').value = btn.dataset.feedback ?? '';
});

document.getElementById('submitAssignmentModal')?.addEventListener('show.bs.modal', function (e) {
    var btn = e.relatedTarget;
    document.getElementById('submit_assignmentId').value = btn.dataset.assignmentid;
    document.getElementById('submit_assignmentTitle').textContent = btn.dataset.assignmenttitle || '';
});
</script>
}
