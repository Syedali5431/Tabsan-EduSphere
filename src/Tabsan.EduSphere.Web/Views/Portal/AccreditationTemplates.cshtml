@model Tabsan.EduSphere.Web.Models.Portal.AccreditationTemplatesPageModel
@{
    ViewData["Title"] = "Accreditation Templates";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">
        API connection is not configured. Please set it on <a asp-action="Dashboard">Dashboard</a>.
    </div>
}
else
{
    <div class="row g-3">
        <!-- Template list -->
        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0"><i class="bi bi-file-earmark-text me-2"></i>Accreditation Templates</h2>
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
                            <i class="bi bi-plus-lg me-1"></i>New Template
                        </button>
                    </div>
                    @if (!Model.Templates.Any())
                    {
                        <p class="text-muted">No templates defined yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle small">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Format</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in Model.Templates)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@t.Name</strong>
                                                @if (!string.IsNullOrWhiteSpace(t.Description))
                                                {
                                                    <br /><span class="text-muted">@t.Description</span>
                                                }
                                            </td>
                                            <td><span class="badge bg-secondary">@t.Format</span></td>
                                            <td>
                                                @if (t.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">Inactive</span>
                                                }
                                            </td>
                                            <td>@t.CreatedAt.ToString("dd MMM yyyy")</td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="DownloadAccreditationTemplate" asp-route-id="@t.Id"
                                                       class="btn btn-outline-secondary btn-sm d-flex align-items-center mb-1"
                                                       title="Download Template JSON"
                                                       style="min-width: 120px; justify-content: center;">
                                                        <i class="bi bi-filetype-json me-1"></i> Template
                                                    </a>
                                                    <a asp-action="DownloadAccreditationReport" asp-route-id="@t.Id"
                                                       class="btn btn-success btn-sm d-flex align-items-center mb-1"
                                                       title="Download Accreditation Report"
                                                       style="min-width: 120px; justify-content: center;">
                                                        <i class="bi bi-download me-1"></i> Download
                                                    </a>
                                                    <button class="btn btn-primary btn-sm edit-btn d-flex align-items-center mb-1"
                                                            data-id="@t.Id"
                                                            data-name="@t.Name"
                                                            data-description="@t.Description"
                                                            data-format="@t.Format"
                                                            data-mappings="@t.FieldMappingsJson"
                                                            data-active="@t.IsActive.ToString().ToLower()"
                                                            data-bs-toggle="modal" data-bs-target="#editModal"
                                                            title="Edit Accreditation Template"
                                                            style="min-width: 100px; justify-content: center;">
                                                        <i class="bi bi-pencil me-1"></i> Edit
                                                    </button>
                                                    <form asp-action="DeleteAccreditationTemplate" method="post"
                                                          class="d-inline-block mb-1"
                                                          onsubmit="return confirm('Delete this template?')">
                                                        <input type="hidden" name="id" value="@t.Id" />
                                                        <button type="submit" class="btn btn-danger btn-sm d-flex align-items-center"
                                                                title="Delete Accreditation Template"
                                                                style="min-width: 100px; justify-content: center;">
                                                            <i class="bi bi-trash me-1"></i> Delete
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Info panel -->
        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h3 class="h6 fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>About Report Templates</h3>
                    <p class="small text-muted">
                        Accreditation templates define the structure of institutional reports submitted to
                        government bodies or accrediting agencies.
                    </p>
                    <ul class="small text-muted mb-0">
                        <li><strong>Format:</strong> CSV for spreadsheet submission; TXT for plain-text regulatory forms.</li>
                        <li><strong>Field Mappings:</strong> JSON array of section keys to include, e.g. <code>["enrollment","results","faculty"]</code>.</li>
                        <li><strong>Template Download:</strong> Use the <span class="badge bg-light text-dark border"><i class="bi bi-filetype-json"></i> Template</span> button to export template settings as JSON.</li>
                        <li><strong>Template Upload:</strong> Upload a previously exported JSON file to create a new template quickly.</li>
                        <li><strong>Download:</strong> Click the <span class="badge bg-success"><i class="bi bi-download"></i> Download</span> button to generate and download the report instantly. If the download fails, you will see an error message.</li>
                    </ul>

                    <hr class="my-3" />

                    <form id="accreditationTemplateUploadForm" asp-action="UploadAccreditationTemplate" method="post" enctype="multipart/form-data">
                        <label class="form-label fw-semibold small">Upload Template JSON</label>
                        <div class="input-group input-group-sm">
                            <input id="accreditationTemplateFileInput" type="file" name="templateFile" class="form-control" accept=".json,application/json" required />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-upload me-1"></i>Upload
                            </button>
                        </div>
                        <div class="form-text">Accepted format: .json (max 1 MB).</div>
                        <div id="accreditationTemplateUploadValidation" class="invalid-feedback d-block d-none"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Modal -->
    <div class="modal fade" id="createModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="CreateAccreditationTemplate" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="createModalLabel">New Accreditation Template</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" class="form-control" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" name="Description" class="form-control" maxlength="500" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Format <span class="text-danger">*</span></label>
                            <select name="Format" class="form-select" required>
                                <option value="CSV">CSV</option>
                                <option value="PDF">TXT/PDF</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Field Mappings (JSON)</label>
                            <textarea name="FieldMappingsJson" class="form-control font-monospace" rows="3"
                                      placeholder='["enrollment","results","faculty","students"]'></textarea>
                            <div class="form-text">JSON array of section keys. Leave blank to include all sections.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Template</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="UpdateAccreditationTemplate" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editModalLabel">Edit Template</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="Id" id="editId" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" id="editName" class="form-control" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <input type="text" name="Description" id="editDescription" class="form-control" maxlength="500" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Format <span class="text-danger">*</span></label>
                            <select name="Format" id="editFormat" class="form-select" required>
                                <option value="CSV">CSV</option>
                                <option value="PDF">TXT/PDF</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Field Mappings (JSON)</label>
                            <textarea name="FieldMappingsJson" id="editMappings" class="form-control font-monospace" rows="3"></textarea>
                        </div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" name="IsActive" id="editIsActive" class="form-check-input" value="true" />
                            <input type="hidden" name="IsActive" value="false" />
                            <label class="form-check-label" for="editIsActive">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.edit-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('editId').value          = btn.dataset.id;
                document.getElementById('editName').value        = btn.dataset.name || '';
                document.getElementById('editDescription').value = btn.dataset.description || '';
                document.getElementById('editFormat').value      = btn.dataset.format || 'CSV';
                document.getElementById('editMappings').value    = btn.dataset.mappings || '';
                document.getElementById('editIsActive').checked  = btn.dataset.active === 'true';
            });
        });

        const uploadForm = document.getElementById('accreditationTemplateUploadForm');
        const uploadInput = document.getElementById('accreditationTemplateFileInput');
        const uploadFeedback = document.getElementById('accreditationTemplateUploadValidation');

        if (uploadForm && uploadInput && uploadFeedback) {
            let bypassValidation = false;

            const hideValidation = () => {
                uploadFeedback.textContent = '';
                uploadFeedback.classList.add('d-none');
                uploadInput.classList.remove('is-invalid');
            };

            const showValidation = (message) => {
                uploadFeedback.textContent = message;
                uploadFeedback.classList.remove('d-none');
                uploadInput.classList.add('is-invalid');
            };

            uploadInput.addEventListener('change', hideValidation);

            uploadForm.addEventListener('submit', async (event) => {
                if (bypassValidation) {
                    bypassValidation = false;
                    return;
                }

                event.preventDefault();
                hideValidation();

                const file = uploadInput.files && uploadInput.files.length > 0 ? uploadInput.files[0] : null;
                if (!file) {
                    showValidation('Please select a JSON file.');
                    return;
                }

                if (!file.name.toLowerCase().endsWith('.json')) {
                    showValidation('Only .json template files are supported.');
                    return;
                }

                if (file.size > 1048576) {
                    showValidation('Template file is too large. Maximum size is 1 MB.');
                    return;
                }

                try {
                    const text = await file.text();
                    const parsed = JSON.parse(text);
                    const payload = parsed && typeof parsed === 'object' && parsed.template
                        ? parsed.template
                        : parsed;

                    if (!payload || typeof payload !== 'object') {
                        showValidation('Invalid template JSON structure.');
                        return;
                    }

                    const name = typeof payload.name === 'string' ? payload.name.trim() : '';
                    if (!name) {
                        showValidation('Template JSON must include a non-empty Name value.');
                        return;
                    }

                    const formatRaw = typeof payload.format === 'string' ? payload.format.trim().toUpperCase() : 'CSV';
                    if (formatRaw !== 'CSV' && formatRaw !== 'PDF') {
                        showValidation('Template format must be CSV or PDF.');
                        return;
                    }
                } catch {
                    showValidation('Invalid JSON file. Please upload a valid accreditation template export.');
                    return;
                }

                bypassValidation = true;
                uploadForm.submit();
            });
        }
    </script>
}
