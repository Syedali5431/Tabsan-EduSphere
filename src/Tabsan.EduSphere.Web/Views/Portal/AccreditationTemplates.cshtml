@model Tabsan.EduSphere.Web.Models.Portal.AccreditationTemplatesPageModel
@{
    ViewData["Title"] = "Accreditation Templates";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3"><i class="bi bi-download me-2"></i>Download Simple Template</h2>
                <p class="text-muted small mb-3">
                    Download a simple text template file and edit it as needed.
                </p>
                <a asp-action="DownloadAccreditationTemplate" class="btn btn-primary">
                    <i class="bi bi-file-earmark-arrow-down me-1"></i>Download Template
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3"><i class="bi bi-upload me-2"></i>Upload Template</h2>
                <p class="text-muted small mb-3">
                    Upload a plain .txt or .csv file. No JSON needed.
                </p>

                <form id="accreditationTemplateUploadForm" asp-action="UploadAccreditationTemplate" method="post" enctype="multipart/form-data">
                    <div class="input-group">
                        <input id="accreditationTemplateFileInput" type="file" name="templateFile" class="form-control" accept=".txt,.csv,text/plain,text/csv" required />
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-upload me-1"></i>Upload
                        </button>
                    </div>
                    <div class="form-text">Accepted formats: .txt or .csv (max 1 MB).</div>
                    <div id="accreditationTemplateUploadValidation" class="invalid-feedback d-block d-none"></div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const uploadForm = document.getElementById('accreditationTemplateUploadForm');
        const uploadInput = document.getElementById('accreditationTemplateFileInput');
        const uploadFeedback = document.getElementById('accreditationTemplateUploadValidation');

        if (uploadForm && uploadInput && uploadFeedback) {
            const hideValidation = () => {
                uploadFeedback.textContent = '';
                uploadFeedback.classList.add('d-none');
                uploadInput.classList.remove('is-invalid');
            };

            const showValidation = (message) => {
                uploadFeedback.textContent = message;
                uploadFeedback.classList.remove('d-none');
                uploadInput.classList.add('is-invalid');
            };

            uploadInput.addEventListener('change', hideValidation);

            uploadForm.addEventListener('submit', (event) => {
                hideValidation();

                const file = uploadInput.files && uploadInput.files.length > 0 ? uploadInput.files[0] : null;
                if (!file) {
                    event.preventDefault();
                    showValidation('Please select a template file.');
                    return;
                }

                const lowerName = file.name.toLowerCase();
                if (!lowerName.endsWith('.txt') && !lowerName.endsWith('.csv')) {
                    event.preventDefault();
                    showValidation('Only .txt or .csv template files are supported.');
                    return;
                }

                if (file.size > 1048576) {
                    event.preventDefault();
                    showValidation('Template file is too large. Maximum size is 1 MB.');
                }
            });
        }
    </script>
}
