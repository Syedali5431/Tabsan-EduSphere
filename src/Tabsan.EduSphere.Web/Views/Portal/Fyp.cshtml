@model Tabsan.EduSphere.Web.Models.Portal.FypPageModel
@{ ViewData["Title"] = "FYP Management"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.Departments.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-action="Fyp" class="row g-2 align-items-end">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-3">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var tenant in Model.Tenants)
                                {
                                    <option value="@tenant.Id" selected="@(Model.SelectedTenantId == tenant.Id ? "selected" : null)">@tenant.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()" @(Model.SelectedTenantId.HasValue ? null : "disabled")>
                                <option value="">All Campuses</option>
                                @foreach (var campus in Model.Campuses)
                                {
                                    <option value="@campus.Id" selected="@(Model.SelectedCampusId == campus.Id ? "selected" : null)">@campus.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-4">
                        <label class="form-label">Filter by Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All / My Projects</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="row g-3">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Projects
                            <span class="badge bg-secondary ms-1">@Model.Projects.Count</span>
                        </h2>
                        @if (User.IsInRole("Student"))
                        {
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#proposeFypModal">
                                + Propose Project
                            </button>
                        }
                        else if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Faculty"))
                        {
                            @* Issue-Fix Phase 3 Stage 3.8 — Faculty can create FYP for their dept students. *@
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createFypModal">
                                + Create Project
                            </button>
                        }
                    </div>
                    @if (Model.Projects.Count == 0)
                    {
                        <p class="text-muted">No FYP projects found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr><th>Title</th><th>Student</th><th>Supervisor</th><th>Department</th><th>Status</th><th>Result</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.Projects)
                                    {
                                        var badgeCls = p.Status switch
                                        {
                                            "InProgress" or "Approved" => "bg-success",
                                            "Proposed" => "bg-warning text-dark",
                                            "Completed" or "Complete" => "bg-primary",
                                            "Rejected" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@p.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(p.Description))
                                                {
                                                    <small class="text-muted">@p.Description.Substring(0, Math.Min(80, p.Description.Length))…</small>
                                                }
                                            </td>
                                            <td>@p.StudentName</td>
                                            <td>@(p.SupervisorName ?? "–")</td>
                                            <td>@p.DepartmentName</td>
                                            <td><span class="badge @badgeCls">@p.Status</span></td>
                                            <td>@(string.IsNullOrWhiteSpace(p.FinalResult) ? "–" : p.FinalResult)</td>
                                    <td>
                                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                        {
                                            <button class="btn btn-xs btn-outline-secondary btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editFypModal"
                                                    data-projectid="@p.Id" data-title="@p.Title" data-description="@p.Description">
                                                Edit
                                            </button>
                                        }
                                        @if (p.Status == "Proposed" && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                                        {
                                            <form asp-action="ApproveFypProject" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <button type="submit" class="btn btn-xs btn-outline-success btn-sm">Approve</button>
                                            </form>
                                            <button class="btn btn-xs btn-outline-danger btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#rejectFypModal"
                                                    data-projectid="@p.Id">Reject</button>
                                        }
                                        @if ((p.Status == "Approved" || p.Status == "InProgress") && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                                        {
                                            @if (Model.Faculty.Any())
                                            {
                                                <button class="btn btn-xs btn-outline-secondary btn-sm"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#assignSupervisorModal"
                                                        data-projectid="@p.Id">Supervisor</button>
                                            }
                                            <form asp-action="CompleteFypProject" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <button type="submit" class="btn btn-xs btn-outline-primary btn-sm"
                                                        onclick="return confirm('Mark project as complete?')">Complete</button>
                                            </form>
                                        }
                                        @if ((User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Faculty")) && string.Equals(p.Status, "Completed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button class="btn btn-xs btn-outline-dark btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#enterFypResultModal"
                                                    data-projectid="@p.Id"
                                                    data-result="@p.FinalResult">
                                                Enter Result
                                            </button>
                                        }
                                        @if (User.IsInRole("Student") && p.Status == "InProgress")
                                        {
                                            @if (!p.IsCompletionRequested)
                                            {
                                                <form asp-action="RequestFypCompletion" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@p.Id" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <button type="submit" class="btn btn-xs btn-outline-primary btn-sm"
                                                            onclick="return confirm('Request completion review from assigned faculty?')">
                                                        Request Completion
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark">
                                                    Awaiting Approval (@p.CompletionApprovalCount/@p.RequiredApprovalCount)
                                                </span>
                                            }
                                        }
                                        @if (User.IsInRole("Faculty") && p.Status == "InProgress" && p.IsCompletionRequested)
                                        {
                                            <form asp-action="ApproveFypCompletion" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <button type="submit" class="btn btn-xs btn-outline-success btn-sm">
                                                    Approve Completion
                                                </button>
                                            </form>
                                            <span class="badge bg-light text-dark border">
                                                @p.CompletionApprovalCount/@p.RequiredApprovalCount approvals
                                            </span>
                                        }
                                    </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Upcoming Meetings</h2>
                    @if (Model.UpcomingMeetings.Count == 0)
                    {
                        <p class="text-muted small">No upcoming meetings.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var m in Model.UpcomingMeetings)
                            {
                                <li class="list-group-item px-0">
                                    <div class="fw-semibold small">@m.Title</div>
                                    <div class="text-muted small">@m.ScheduledAt.ToString("dd MMM yyyy, HH:mm")</div>
                                    @if (!string.IsNullOrWhiteSpace(m.Location))
                                    {
                                        <div class="text-muted small">📍 @m.Location</div>
                                    }
                                    <div class="text-muted small">@m.ProjectTitle</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Propose FYP Project Modal ──────────────────────────────────────────── *@
<div class="modal fade" id="proposeFypModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="ProposeFypProject" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Propose FYP Project</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Department <span class="text-danger">*</span></label>
                        <select name="departmentId" class="form-select" required>
                            <option value="">Select department…</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input name="title" class="form-control" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea name="description" class="form-control" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit Proposal</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* Issue-Fix Phase 3 Stage 3.8 — Faculty can also create FYP records for their department students. *@
@if ((User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Faculty")) && Model.Students.Any())
{
    <div class="modal fade" id="createFypModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="CreateFypProject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create FYP Project</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Student <span class="text-danger">*</span></label>
                            <select name="studentProfileId" class="form-select" required>
                                <option value="">Select student…</option>
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id">@s.FullName (@s.RegistrationNumber)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Department <span class="text-danger">*</span></label>
                            <select name="departmentId" class="form-select" required>
                                <option value="">Select department…</option>
                                @foreach (var d in Model.Departments)
                                {
                                    <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input name="title" class="form-control" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea name="description" class="form-control" rows="4" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Project</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="modal fade" id="editFypModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="UpdateFypProject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit_fypId" name="id" />
                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit FYP Project</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input id="edit_fypTitle" name="title" class="form-control" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea id="edit_fypDescription" name="description" class="form-control" rows="4" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@* ── Reject FYP Project Modal ────────────────────────────────────────────── *@
<div class="modal fade" id="rejectFypModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="RejectFypProject" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="reject_projectId" name="id" />
            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reject Project</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Reason / Remarks <span class="text-danger">*</span></label>
                        <textarea name="remarks" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* ── Assign Supervisor Modal ─────────────────────────────────────────────── *@
@if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
{
    <div class="modal fade" id="assignSupervisorModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="AssignFypSupervisor" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="assign_projectId" name="id" />
                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Assign Supervisor</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Supervisor (Faculty) <span class="text-danger">*</span></label>
                            <select name="supervisorUserId" class="form-select" required>
                                <option value="">Select faculty…</option>
                                @foreach (var f in Model.Faculty)
                                {
                                    <option value="@f.Id">@f.DisplayName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Assign</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

<div class="modal fade" id="enterFypResultModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="EnterFypResult" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="enter_resultProjectId" name="id" />
            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Enter FYP Result</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Result <span class="text-danger">*</span></label>
                    <input id="enter_resultValue" name="result" class="form-control" required maxlength="200" placeholder="e.g. A, Pass, Distinction" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Result</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('rejectFypModal')?.addEventListener('show.bs.modal', function(e) {
    document.getElementById('reject_projectId').value = e.relatedTarget.dataset.projectid;
});
document.getElementById('assignSupervisorModal')?.addEventListener('show.bs.modal', function(e) {
    document.getElementById('assign_projectId').value = e.relatedTarget.dataset.projectid;
});
document.getElementById('editFypModal')?.addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('edit_fypId').value = btn.dataset.projectid;
    document.getElementById('edit_fypTitle').value = btn.dataset.title || '';
    document.getElementById('edit_fypDescription').value = btn.dataset.description || '';
});
document.getElementById('enterFypResultModal')?.addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('enter_resultProjectId').value = btn.dataset.projectid;
    document.getElementById('enter_resultValue').value = btn.dataset.result || '';
});
</script>
}
