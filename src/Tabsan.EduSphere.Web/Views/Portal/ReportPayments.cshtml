@model Tabsan.EduSphere.Web.Models.Portal.ReportPaymentsPageModel
@{
    ViewData["Title"] = "Payment Summary Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentYear = DateTime.Today.Year;
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ReportCenter" asp-controller="Portal" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h2 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Payment Summary Report</h2>
            <small class="text-muted">Finance-focused payment visibility with export-ready filters</small>
        </div>
    </div>

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning"><i class="bi bi-wifi-off me-2"></i>Not connected to API.</div>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger">@Model.Message</div>
        }

        <form method="get" class="card shadow-sm border-0 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Year</label>
                        <select name="year" class="form-select form-select-sm">
                            <option value="">All</option>
                            @for (var year = currentYear - 3; year <= currentYear + 1; year++)
                            {
                                <option value="@year" selected="@(Model.Year == year)">@year</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Month</label>
                        <select name="month" class="form-select form-select-sm">
                            <option value="">All</option>
                            @for (var month = 1; month <= 12; month++)
                            {
                                <option value="@month" selected="@(Model.Month == month)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Institute</label>
                        <select name="institutionType" class="form-select form-select-sm">
                            @if (!Model.InstitutionType.HasValue && Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="" selected>All Institutes</option>
                            }
                            else if (Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="">All Institutes</option>
                            }
                            @foreach (var institution in Model.AvailableInstitutionTypes)
                            {
                                <option value="@institution.Value" selected="@(Model.InstitutionType == institution.Value)">@institution.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Department</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">@Model.PeriodFilterLabel</label>
                        <select name="semesterId" class="form-select form-select-sm">
                            <option value="">@Model.PeriodFilterPlaceholder</option>
                            @foreach (var semester in Model.Semesters)
                            {
                                <option value="@semester.Id" selected="@(Model.SemesterId == semester.Id)">@semester.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Course</label>
                        <select name="courseId" class="form-select form-select-sm">
                            <option value="">All Courses</option>
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id" selected="@(Model.CourseId == course.Id)">@course.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Level</label>
                        <select name="levelNumber" class="form-select form-select-sm">
                            <option value="">All</option>
                            @for (var level = 1; level <= 12; level++)
                            {
                                <option value="@level" selected="@(Model.LevelNumber == level)">@level</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-funnel me-1"></i>Apply</button>
                    </div>
                </div>
            </div>
        </form>

        @if (Model.Report is not null)
        {
            var report = Model.Report;
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Total Receipts</div><div class="fs-4 fw-semibold">@report.TotalReceipts</div></div></div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Total Amount</div><div class="fs-4 fw-semibold">@report.TotalAmount.ToString("N2")</div></div></div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Paid</div><div class="fs-4 fw-semibold text-success">@report.TotalPaid.ToString("N2")</div></div></div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Pending</div><div class="fs-4 fw-semibold text-warning">@report.TotalPending.ToString("N2")</div></div></div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small">Generated @report.GeneratedAt.ToString("dd MMM yyyy, HH:mm")</span>
                <div class="btn-group btn-group-sm">
                    <a class="btn btn-success" href="@Url.Action("ExportPaymentSummary", "Portal", new { year = Model.Year, month = Model.Month, semesterId = Model.SemesterId, departmentId = Model.DepartmentId, courseId = Model.CourseId, levelNumber = Model.LevelNumber, institutionType = Model.InstitutionType })">Excel</a>
                    <a class="btn btn-outline-secondary" href="@Url.Action("ExportPaymentSummaryCsv", "Portal", new { year = Model.Year, month = Model.Month, semesterId = Model.SemesterId, departmentId = Model.DepartmentId, courseId = Model.CourseId, levelNumber = Model.LevelNumber, institutionType = Model.InstitutionType })">CSV</a>
                    <a class="btn btn-outline-secondary" href="@Url.Action("ExportPaymentSummaryPdf", "Portal", new { year = Model.Year, month = Model.Month, semesterId = Model.SemesterId, departmentId = Model.DepartmentId, courseId = Model.CourseId, levelNumber = Model.LevelNumber, institutionType = Model.InstitutionType })">PDF</a>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Student</th>
                                    <th>Department</th>
                                    <th>Course</th>
                                    <th>Semester</th>
                                    <th>Level</th>
                                    <th class="text-end">Amount</th>
                                    <th>Status</th>
                                    <th>Due</th>
                                    <th>Paid</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in report.Rows)
                                {
                                    var badgeClass = row.Status switch
                                    {
                                        "Paid" => "bg-success",
                                        "Submitted" => "bg-info text-dark",
                                        "Pending" => "bg-warning text-dark",
                                        "Cancelled" => "bg-secondary",
                                        _ => "bg-secondary"
                                    };
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@row.StudentName</div>
                                            <small class="text-muted">@row.RegistrationNumber</small>
                                        </td>
                                        <td>@row.DepartmentName</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.CourseCode) ? "-" : $"{row.CourseCode} - {row.CourseTitle}")</td>
                                        <td>@(row.SemesterName ?? "-")</td>
                                        <td>@row.LevelLabel</td>
                                        <td class="text-end fw-semibold">@row.Amount.ToString("N2")</td>
                                        <td><span class="badge @badgeClass">@row.Status</span></td>
                                        <td>@row.DueDate.ToString("dd MMM yyyy")</td>
                                        <td>@(row.PaidDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else if (Model.Year.HasValue || Model.Month.HasValue || Model.SemesterId.HasValue || Model.DepartmentId.HasValue || Model.CourseId.HasValue || Model.LevelNumber.HasValue)
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No payment receipts matched the selected filters.</div>
        }
    }
</div>