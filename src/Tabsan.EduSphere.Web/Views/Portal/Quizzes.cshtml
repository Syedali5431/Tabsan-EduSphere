@model Tabsan.EduSphere.Web.Models.Portal.QuizzesPageModel
@{ ViewData["Title"] = "Quizzes"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.CourseOfferings.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-action="Quizzes" class="row g-2 align-items-end">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-3">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id)">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id)">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <div class="col-md-3">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id)">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    }

                    @if (User.IsInRole("Student") && Model.SemesterOptions.Count > 0)
                    {
                        <div class="col-md-4">
                            <label class="form-label">Select Semester</label>
                            <select name="semesterName" class="form-select" onchange="this.form.submit()">
                                <option value="">All Semesters</option>
                                @foreach (var s in Model.SemesterOptions)
                                {
                                    <option value="@s.Name" selected="@(string.Equals(Model.SelectedSemesterName, s.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@s.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-5">
                        <label class="form-label">Select Course Offering</label>
                        <select name="offeringId" class="form-select" onchange="this.form.submit()">
                            <option value="">Select offering…</option>
                            @foreach (var o in Model.CourseOfferings)
                            {
                                <option value="@o.Id" selected="@(Model.SelectedOfferingId == o.Id ? "selected" : null)">@o.Name</option>
                            }
                        </select>
                    </div>
                    @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                    {
                        <div class="col-md-2">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="includeInactive" name="includeInactive" value="true" checked="@(Model.IncludeInactive ? "checked" : null)" onchange="this.form.submit()" />
                                <label class="form-check-label" for="includeInactive">Include Inactive</label>
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>
    }

    @if (Model.Quizzes.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Available Quizzes
                        <span class="badge bg-secondary ms-1">@Model.Quizzes.Count</span>
                    </h2>
                    @if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                    {
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createQuizModal">
                            + Create Quiz
                        </button>
                    }
                </div>
                <div class="row g-3">
                    @foreach (var q in Model.Quizzes)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="card border shadow-none h-100">
                                <div class="card-body">
                                    <h6 class="fw-semibold">@q.Title</h6>
                                    @if (!string.IsNullOrWhiteSpace(q.Description))
                                    {
                                        <p class="small text-muted mb-2">@q.Description</p>
                                    }
                                    <div class="small">
                                        <span class="me-2">❓ @q.QuestionCount questions</span>
                                        @if (q.TimeLimitMinutes.HasValue)
                                        {
                                            <span class="me-2">⏱ @q.TimeLimitMinutes min</span>
                                        }
                                        @if (q.MaxAttempts > 0)
                                        {
                                            <span>🔁 @q.MaxAttempts attempts</span>
                                        }
                                    </div>
                                    @if (q.AvailableFrom.HasValue && q.AvailableFrom > DateTime.Now)
                                    {
                                        <span class="badge bg-info text-dark mt-2">Upcoming</span>
                                    }
                                    else if (q.AvailableTo.HasValue && q.AvailableTo < DateTime.Now)
                                    {
                                        <span class="badge bg-secondary mt-2">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge @(!q.IsActive ? "bg-danger" : q.IsPublished ? "bg-success" : "bg-warning text-dark") mt-2">
                                            @(!q.IsActive ? "Inactive" : q.IsPublished ? "Published" : "Draft")
                                        </span>
                                    }
                                    @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                    {
                                        <div class="mt-2 d-flex gap-1 flex-wrap">
                                            @if (!q.IsPublished)
                                            {
                                                <button type="button" class="btn btn-xs btn-outline-secondary btn-sm"
                                                        data-bs-toggle="modal" data-bs-target="#editQuizModal"
                                                        data-id="@q.Id" data-title="@q.Title" data-instructions="@q.Description"
                                                        data-timelimit="@(q.TimeLimitMinutes?.ToString() ?? string.Empty)" data-maxattempts="@q.MaxAttempts">
                                                    Edit
                                                </button>
                                                <form asp-action="PublishQuiz" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@q.Id" />
                                                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="includeInactive" value="@(Model.IncludeInactive ? "true" : "false")" />
                                                    <button type="submit" class="btn btn-xs btn-outline-success btn-sm">Publish</button>
                                                </form>
                                            }

                                            <form asp-action="SetQuizActive" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@q.Id" />
                                                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <input type="hidden" name="includeInactive" value="@(Model.IncludeInactive ? "true" : "false")" />
                                                <input type="hidden" name="activate" value="@(!q.IsActive ? "true" : "false")" />
                                                <button type="submit" class="btn btn-xs @(q.IsActive ? "btn-outline-warning" : "btn-outline-success") btn-sm">
                                                    @(q.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </form>

                                            <form asp-action="DeleteQuiz" method="post" class="d-inline"
                                                  onsubmit="return confirm('Delete this quiz?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@q.Id" />
                                                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <input type="hidden" name="includeInactive" value="@(Model.IncludeInactive ? "true" : "false")" />
                                                <button type="submit" class="btn btn-xs btn-outline-danger btn-sm">Delete</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.MyAttempts.Count > 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">My Attempts</h2>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Quiz</th><th>Started</th><th>Submitted</th><th>Score</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.MyAttempts)
                            {
                                <tr>
                                    <td>@a.QuizTitle</td>
                                    <td>@a.StartedAt.ToString("dd MMM HH:mm")</td>
                                    <td>@(a.SubmittedAt?.ToString("dd MMM HH:mm") ?? "–")</td>
                                    <td>@(a.TotalScore.HasValue ? $"{a.TotalScore}/{a.MaxScore}" : "–")</td>
                                    <td><span class="badge bg-secondary">@a.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.Quizzes.Count == 0 && Model.MyAttempts.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <div class="fs-1 mb-2">📝</div>
                <p>Select a course offering to view quizzes.</p>
                @if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                {
                    <button class="btn btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#createQuizModal">
                        + Create First Quiz
                    </button>
                }
            </div>
        </div>
    }
}

@* ── Create Quiz Modal ───────────────────────────────────────────────────── *@
@if (Model.SelectedOfferingId.HasValue)
{
    <div class="modal fade" id="createQuizModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="CreateQuiz" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <input type="hidden" name="includeInactive" value="@(Model.IncludeInactive ? "true" : "false")" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create Quiz</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input name="title" class="form-control" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Instructions</label>
                            <textarea name="instructions" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="row g-2">
                            <div class="col">
                                <label class="form-label">Time Limit (minutes)</label>
                                <input name="timeLimitMinutes" type="number" min="1" class="form-control" placeholder="Unlimited" />
                            </div>
                            <div class="col">
                                <label class="form-label">Max Attempts <span class="text-danger">*</span></label>
                                <input name="maxAttempts" type="number" min="1" value="1" class="form-control" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}
