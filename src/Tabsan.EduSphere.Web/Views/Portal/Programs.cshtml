@model Tabsan.EduSphere.Web.Models.Portal.ProgramsPageModel
@{
    ViewData["Title"] = "Programs";
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    var canManagePrograms = User.IsInRole("SuperAdmin") || User.IsInRole("Admin");
    var isSuperAdmin = Model.Identity?.IsSuperAdmin == true;
    var departmentInstitutionMap = Model.Departments.ToDictionary(d => d.Id, d => d.InstitutionType);

    var selectedInstitutionType = Model.SelectedDepartmentId.HasValue && departmentInstitutionMap.TryGetValue(Model.SelectedDepartmentId.Value, out var selectedType)
        ? selectedType
        : (int?)null;

    var levelHeaderLabel = selectedInstitutionType switch
    {
        1 or 2 => "Classes",
        0 => "Semesters",
        _ => "Levels"
    };

    var createCountLabel = selectedInstitutionType switch
    {
        2 => "Total Classes (1-10)",
        1 => "Total Classes (11-12)",
        0 => "Total Semesters",
        _ => "Total Levels"
    };

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="Programs" class="row g-2 align-items-end">
                @if (isSuperAdmin)
                {
                    <div class="col-md-4">
                        <label class="form-label">Tenant</label>
                        <select name="tenantId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Tenants</option>
                            @foreach (var t in Model.Tenants)
                            {
                                <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name (@t.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Campus</label>
                        <select name="campusId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Campuses</option>
                            @foreach (var c in Model.Campuses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                            }
                        </select>
                    </div>
                }
                else if (User.IsInRole("Admin"))
                {
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <div class="col-md-4">
                        <label class="form-label">Campus</label>
                        <select name="campusId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Campuses</option>
                            @foreach (var c in Model.Campuses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                            }
                        </select>
                    </div>
                }
                else
                {
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                }
                <div class="col-md-4">
                    <label class="form-label">Filter by Department</label>
                    <select name="departmentId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Departments</option>
                        @foreach (var d in Model.Departments)
                        {
                            <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    @if (canManagePrograms)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h2 class="h5 mb-3">Create Program</h2>
                <form method="post" asp-action="CreateProgram" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    <input type="hidden" name="filterDepartmentId" value="@Model.SelectedDepartmentId" />
                    <div class="col-md-3">
                        <label class="form-label">Code</label>
                        <input type="text" name="code" class="form-control" maxlength="32" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" class="form-control" maxlength="128" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select name="departmentId" id="programDepartmentSelect" class="form-select" required>
                            <option value="">Select Department</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" data-institution-type="@d.InstitutionType">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" id="programTotalLevelsLabel">@createCountLabel</label>
                        <input type="number" name="totalSemesters" id="programTotalLevelsInput" class="form-control" min="1" max="20" value="8" required />
                    </div>
                    <div class="col-md-1 d-grid">
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Program List <span class="badge bg-secondary ms-2">@Model.Programs.Count</span></h2>

            @if (Model.Programs.Count == 0)
            {
                <p class="text-muted mb-0">No programs found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th class="text-center">@levelHeaderLabel</th>
                                <th>Status</th>
                                <th style="width: 340px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Programs)
                            {
                                var rowInstitutionType = departmentInstitutionMap.TryGetValue(p.DepartmentId, out var rowType)
                                    ? rowType
                                    : (int?)null;

                                var rowLevelUnit = rowInstitutionType switch
                                {
                                    1 or 2 => "class",
                                    0 => "semester",
                                    _ => "level"
                                };

                                <tr>
                                    <td><code>@p.Code</code></td>
                                    <td>@p.Name</td>
                                    <td>@p.DepartmentName</td>
                                    <td class="text-center">@p.TotalSemesters @rowLevelUnit@(p.TotalSemesters == 1 ? "" : "s")</td>
                                    <td>
                                        <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">@(p.IsActive ? "Active" : "Inactive")</span>
                                    </td>
                                    <td>
                                        @if (canManagePrograms)
                                        {
                                            <div class="d-flex gap-2">
                                                <form method="post" asp-action="UpdateProgram" class="d-flex gap-2 flex-grow-1">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@p.Id" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="filterDepartmentId" value="@Model.SelectedDepartmentId" />
                                                    <input type="text" name="newName" class="form-control form-control-sm" value="@p.Name" required maxlength="128" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary" @(p.IsActive ? null : "disabled")>Rename</button>
                                                </form>
                                                @if (User.IsInRole("SuperAdmin"))
                                                {
                                                    <form method="post" asp-action="SetProgramActive" onsubmit="return confirm('@(p.IsActive ? "Deactivate" : "Activate") this program?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@p.Id" />
                                                        <input type="hidden" name="activate" value="@(!p.IsActive)" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="filterDepartmentId" value="@Model.SelectedDepartmentId" />
                                                        <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-outline-danger" : "btn-outline-success")">@(p.IsActive ? "Deactivate" : "Activate")</button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<script>
(function () {
    var departmentSelect = document.getElementById('programDepartmentSelect');
    var totalLabel = document.getElementById('programTotalLevelsLabel');
    var totalInput = document.getElementById('programTotalLevelsInput');

    if (!departmentSelect || !totalLabel || !totalInput) {
        return;
    }

    function applyInstitutionDefaults() {
        var selectedOption = departmentSelect.options[departmentSelect.selectedIndex];
        var rawType = selectedOption ? selectedOption.getAttribute('data-institution-type') : null;
        var institutionType = rawType === null ? NaN : parseInt(rawType, 10);

        if (institutionType === 2) {
            totalLabel.textContent = 'Total Classes (1-10)';
            totalInput.value = '10';
            totalInput.min = '1';
            totalInput.max = '10';
            return;
        }

        if (institutionType === 1) {
            totalLabel.textContent = 'Total Classes (11-12)';
            totalInput.value = '2';
            totalInput.min = '1';
            totalInput.max = '2';
            return;
        }

        if (institutionType === 0) {
            totalLabel.textContent = 'Total Semesters';
            totalInput.value = '8';
            totalInput.min = '1';
            totalInput.max = '20';
            return;
        }

        totalLabel.textContent = 'Total Levels';
        totalInput.min = '1';
        totalInput.max = '20';
    }

    departmentSelect.addEventListener('change', applyInstitutionDefaults);
    applyInstitutionDefaults();
})();
</script>
