@model Tabsan.EduSphere.Web.Models.Portal.ModuleSettingsPageModel
@{
    ViewData["Title"] = "Module Settings";
    var tempMsg = TempData["Message"] as string ?? Model.Message;
    var allRoles = new[] { "Admin", "Faculty", "Student" };
    var moduleOrder = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
    {
        ["authentication"] = 10,
        ["departments"] = 20,
        ["sis"] = 30,
        ["courses"] = 40,
        ["assignments"] = 50,
        ["quizzes"] = 60,
        ["attendance"] = 70,
        ["results"] = 80,
        ["fyp"] = 90,
        ["notifications"] = 100,
        ["reports"] = 110,
        ["themes"] = 120,
        ["ai_chat"] = 130,
        ["advanced_audit"] = 140,
    };
    var orderedModules = Model.Modules
        .OrderBy(m => moduleOrder.TryGetValue(m.Key ?? string.Empty, out var order) ? order : int.MaxValue)
        .ThenBy(m => m.Name)
        .ToList();
}

<div class="row g-4">

    @if (!Model.IsConnected)
    {
        <div class="col-12">
            <div class="alert alert-warning d-flex align-items-center gap-2">
                <i class="bi bi-plug-fill"></i>
                Not connected to the API. Configure the connection on the Dashboard.
            </div>
        </div>
    }

    @* Final-Touches Phase 5 Stage 5.2 — contextual success/danger alert feedback *@
    @if (!string.IsNullOrWhiteSpace(tempMsg))
    {
        var alertClass = tempMsg!.StartsWith("Error") ? "alert-danger" : "alert-success";
        var alertIcon  = tempMsg.StartsWith("Error") ? "bi-x-circle-fill" : "bi-check-circle-fill";
        <div class="col-12">
            <div class="alert @alertClass alert-dismissible fade show" role="alert">
                <i class="bi @alertIcon me-2"></i>@tempMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-puzzle-fill text-primary"></i>
                <strong>Feature Modules</strong>
                <span class="badge bg-secondary ms-auto">@orderedModules.Count</span>
            </div>
            <div class="card-body p-0">
                @if (orderedModules.Count == 0)
                {
                    <p class="text-muted p-3 mb-0">No modules registered.</p>
                }
                else
                {
                    <div class="accordion accordion-flush" id="modulesAccordion">
                        @foreach (var mod in orderedModules)
                        {
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed py-2" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#mod-@mod.Id"
                                            aria-expanded="false">
                                        <span class="me-2">
                                            @if (mod.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </span>
                                        <strong>@mod.Name</strong>
                                        <code class="ms-2 text-muted small">@mod.Key</code>
                                        @if (mod.IsMandatory)
                                        {
                                            <span class="badge bg-primary ms-2">Mandatory</span>
                                        }
                                    </button>
                                </h2>
                                <div id="mod-@mod.Id" class="accordion-collapse collapse">
                                    <div class="accordion-body row g-3">

                                        @* Toggle active (disabled for mandatory modules) *@
                                        <div class="col-auto">
                                            <form asp-action="ToggleModule" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="key"      value="@mod.Key" />
                                                <input type="hidden" name="activate" value="@(!mod.IsActive)" />
                                                <button type="submit"
                                                        class="btn btn-sm @(mod.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        @(Model.IsConnected && !mod.IsMandatory ? "" : "disabled")
                                                        title="@(mod.IsMandatory ? "Mandatory modules cannot be deactivated" : "")">
                                                    @(mod.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </form>
                                        </div>

                                        @* Role assignment *@
                                        <div class="col-12">
                                            <form asp-action="UpdateModuleRoles" method="post" class="d-flex align-items-center gap-3 flex-wrap">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="key" value="@mod.Key" />
                                                <span class="fw-semibold small">Role Access:</span>
                                                @foreach (var role in allRoles)
                                                {
                                                    var fieldName = $"{role.ToLower()}Allowed";
                                                    var isChecked = mod.AssignedRoles.Contains(role);
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input" type="checkbox"
                                                               name="@fieldName" value="true"
                                                               id="mod-@mod.Id-@role"
                                                               @(isChecked ? "checked" : "")
                                                               @(Model.IsConnected ? "" : "disabled") />
                                                        <label class="form-check-label" for="mod-@mod.Id-@role">@role</label>
                                                    </div>
                                                }
                                                <button type="submit" class="btn btn-sm btn-outline-primary"
                                                        @(Model.IsConnected ? "" : "disabled")>
                                                    <i class="bi bi-floppy me-1"></i> Save Roles
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

</div>
