@model Tabsan.EduSphere.Web.Models.Portal.ResultCalculationSettingsPageModel
@{ ViewData["Title"] = "Result Calculation"; }

@if (!string.IsNullOrWhiteSpace(TempData["Message"]?.ToString()))
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-danger">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="ResultCalculation" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Institute</label>
                    <select id="selectedInstitutionType" name="selectedInstitutionType" class="form-select" onchange="this.form.submit()">
                        <option value="0" selected="@(Model.SelectedInstitutionType == 0 ? "selected" : null)">University</option>
                        <option value="1" selected="@(Model.SelectedInstitutionType == 1 ? "selected" : null)">School</option>
                        <option value="2" selected="@(Model.SelectedInstitutionType == 2 ? "selected" : null)">College</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <div class="text-muted small mt-4">Result calculation settings shown below are scoped to the selected institute only.</div>
                </div>
            </form>
        </div>
    </div>

    @* Final-Touches Phase 19 Stage 19.3 — Course type and course filter *@
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Course Type</label>
                    <select id="courseTypeFilter" class="form-select" onchange="loadCoursesForType()">
                        <option value="">All Courses</option>
                        <option value="true">Semester-Based</option>
                        <option value="false">Non-Semester-Based</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Course</label>
                    <select id="courseFilter" class="form-select">
                        <option value="">All (no filter)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" id="courseSearch" class="form-control" placeholder="Search course…" oninput="filterCourseDropdown()">
                </div>
            </div>
        </div>
    </div>
    <form asp-action="SaveResultCalculation" method="post" class="d-grid gap-4" id="resultCalculationForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SelectedInstitutionType" value="@Model.SelectedInstitutionType" />

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h2 class="h5 mb-1">Section 1: GPA and Score</h2>
                        <p class="text-muted mb-0">Add one or more GPA-to-score threshold rows.</p>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="addGpaRow()">Add Row</button>
                </div>

                <div id="gpaRows" class="d-grid gap-2">
                    @for (var i = 0; i < Model.GpaRules.Count; i++)
                    {
                        <div class="row g-2 gpa-row align-items-end">
                            <div class="col-md-5">
                                <label class="form-label">GPA</label>
                                <input name="GpaRules[@i].GradePoint" class="form-control" type="number" step="0.01" value="@Model.GpaRules[i].GradePoint" />
                                <input name="GpaRules[@i].Id" type="hidden" value="@Model.GpaRules[i].Id" />
                                <input name="GpaRules[@i].DisplayOrder" type="hidden" value="@(i + 1)" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">Score</label>
                                <input name="GpaRules[@i].MinimumScore" class="form-control" type="number" step="0.01" value="@Model.GpaRules[i].MinimumScore" />
                            </div>
                            <div class="col-md-2 text-end">
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">X</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h2 class="h5 mb-1">Section 2: Subject Score Calculation</h2>
                        <p class="text-muted mb-0">Define the assessment parts that combine into the current subject GPA.</p>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="addComponentRow()">Add Row</button>
                </div>

                <div id="componentRows" class="d-grid gap-2">
                    @for (var i = 0; i < Model.ComponentRules.Count; i++)
                    {
                        <div class="row g-2 component-row align-items-end">
                            <div class="col-md-5">
                                <label class="form-label">Component</label>
                                <input name="ComponentRules[@i].Name" class="form-control" value="@Model.ComponentRules[i].Name" />
                                <input name="ComponentRules[@i].Id" type="hidden" value="@Model.ComponentRules[i].Id" />
                                <input name="ComponentRules[@i].DisplayOrder" type="hidden" value="@(i + 1)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Weightage</label>
                                <input name="ComponentRules[@i].Weightage" class="form-control component-weight" type="number" step="0.01" value="@Model.ComponentRules[i].Weightage" />
                            </div>
                            <div class="col-md-2">
                                <div class="form-check mt-4 pt-2">
                                    <input class="form-check-input" name="ComponentRules[@i].IsActive" type="checkbox" value="true" @(Model.ComponentRules[i].IsActive ? "checked" : null) />
                                    <label class="form-check-label">Active</label>
                                </div>
                                <input type="hidden" name="ComponentRules[@i].IsActive" value="false" />
                            </div>
                            <div class="col-md-2 text-end">
                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">X</button>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3 text-muted small">Active component total: <span id="componentTotal">0</span> / 100</div>
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </form>

    <template id="gpaRowTemplate">
        <div class="row g-2 gpa-row align-items-end">
            <div class="col-md-5">
                <label class="form-label">GPA</label>
                <input name="GpaRules[__index__].GradePoint" class="form-control" type="number" step="0.01" />
                <input name="GpaRules[__index__].Id" type="hidden" />
                <input name="GpaRules[__index__].DisplayOrder" type="hidden" value="__display__" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Score</label>
                <input name="GpaRules[__index__].MinimumScore" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-2 text-end">
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">X</button>
            </div>
        </div>
    </template>

    <template id="componentRowTemplate">
        <div class="row g-2 component-row align-items-end">
            <div class="col-md-5">
                <label class="form-label">Component</label>
                <input name="ComponentRules[__index__].Name" class="form-control" />
                <input name="ComponentRules[__index__].Id" type="hidden" />
                <input name="ComponentRules[__index__].DisplayOrder" type="hidden" value="__display__" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Weightage</label>
                <input name="ComponentRules[__index__].Weightage" class="form-control component-weight" type="number" step="0.01" value="0" />
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4 pt-2">
                    <input class="form-check-input" name="ComponentRules[__index__].IsActive" type="checkbox" value="true" checked />
                    <label class="form-check-label">Active</label>
                </div>
                <input type="hidden" name="ComponentRules[__index__].IsActive" value="false" />
            </div>
            <div class="col-md-2 text-end">
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeRow(this)">X</button>
            </div>
        </div>
    </template>

    <script>
        function removeRow(button) {
            button.closest('.row').remove();
            updateComponentTotal();
        }

        function addGpaRow() {
            appendRow('gpaRows', 'gpaRowTemplate', document.querySelectorAll('#gpaRows .gpa-row').length);
        }

        function addComponentRow() {
            appendRow('componentRows', 'componentRowTemplate', document.querySelectorAll('#componentRows .component-row').length);
            updateComponentTotal();
        }

        function appendRow(containerId, templateId, index) {
            var html = document.getElementById(templateId).innerHTML
                .replaceAll('__index__', index)
                .replaceAll('__display__', index + 1);
            document.getElementById(containerId).insertAdjacentHTML('beforeend', html);
        }

        function normalizeRows(containerSelector, rowSelector, prefix) {
            document.querySelectorAll(containerSelector + ' ' + rowSelector).forEach(function (row, index) {
                row.querySelectorAll('[name]').forEach(function (input) {
                    input.name = input.name.replace(new RegExp(prefix + '\\[[0-9]+\\]', 'g'), prefix + '[' + index + ']');
                });

                var orderInput = row.querySelector('input[name$=".DisplayOrder"]');
                if (orderInput) {
                    orderInput.value = index + 1;
                }
            });
        }

        function updateComponentTotal() {
            var total = 0;
            document.querySelectorAll('#componentRows .component-row').forEach(function (row) {
                var checkbox = row.querySelector('input[type="checkbox"]');
                var input = row.querySelector('.component-weight');
                if (checkbox && checkbox.checked && input) {
                    total += parseFloat(input.value || '0');
                }
            });
            document.getElementById('componentTotal').textContent = total.toFixed(2).replace(/\.00$/, '');
        }

        document.addEventListener('input', function (event) {
            if (event.target.classList.contains('component-weight')) {
                updateComponentTotal();
            }
        });

        document.addEventListener('change', function (event) {
            if (event.target.matches('#componentRows input[type="checkbox"]')) {
                updateComponentTotal();
            }
        });

        document.getElementById('resultCalculationForm').addEventListener('submit', function () {
            normalizeRows('#gpaRows', '.gpa-row', 'GpaRules');
            normalizeRows('#componentRows', '.component-row', 'ComponentRules');
        });

        updateComponentTotal();

        // Final-Touches Phase 19 Stage 19.3 — course type filter JS
        var _allCourses = [];
        async function loadCoursesForType() {
            var type = document.getElementById('courseTypeFilter').value;
            var url = '/api/v1/course' + (type !== '' ? '?hasSemesters=' + type : '');
            try {
                var r = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (r.ok) {
                    _allCourses = await r.json();
                    populateCourseDropdown(_allCourses);
                }
            } catch(e) { console.warn('Could not load courses', e); }
        }
        function populateCourseDropdown(courses) {
            var sel = document.getElementById('courseFilter');
            sel.innerHTML = '<option value="">All (no filter)</option>';
            courses.forEach(function(c) {
                var opt = document.createElement('option');
                opt.value = c.id;
                opt.textContent = c.code + ' — ' + c.title;
                sel.appendChild(opt);
            });
        }
        function filterCourseDropdown() {
            var term = document.getElementById('courseSearch').value.toLowerCase();
            var filtered = _allCourses.filter(function(c) {
                return c.code.toLowerCase().includes(term) || c.title.toLowerCase().includes(term);
            });
            populateCourseDropdown(filtered);
        }
    </script>
}