@model Tabsan.EduSphere.Web.Models.Portal.DepartmentsPageModel
@{ ViewData["Title"] = "Departments"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var alertCls = Model.Message.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @alertCls alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.Identity?.IsSuperAdmin == true)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form asp-action="Departments" method="get" class="row g-2 align-items-end"
                      data-cascade-filter data-filter-role="@(User.IsInRole("SuperAdmin") ? "SuperAdmin" : User.IsInRole("Admin") ? "Admin" : User.IsInRole("Faculty") ? "Faculty" : "Student")">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-12 col-md-4">
                            <label class="form-label">Tenant</label>
                            <select class="form-select" name="tenantId" onchange="this.form.submit()">
                                <option value="">All tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name (@t.Code)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Campus</label>
                            <select class="form-select" name="campusId" onchange="this.form.submit()">
                                <option value="">All campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                                }
                            </select>
                        </div>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <div class="col-12 col-md-4">
                            <label class="form-label">Campus</label>
                            <select class="form-select" name="campusId" onchange="this.form.submit()">
                                <option value="">All campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    }
                    <div class="col-12 col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Apply</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Departments
                <span class="badge bg-secondary ms-2">@Model.Departments.Count</span>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-sm btn-primary float-end" data-bs-toggle="modal" data-bs-target="#createDepartmentModal">
                        <i class="fas fa-plus"></i> Add Department
                    </button>
                }
            </h2>

            @if (Model.Departments.Count == 0)
            {
                <p class="text-muted">No departments found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Institution</th>
                                <th>Status</th>
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                {
                                    <th></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Departments)
                            {
                                <tr>
                                    <td><code>@d.Code</code></td>
                                    <td>@d.Name</td>
                                    <td>
                                        @switch (d.InstitutionType)
                                        {
                                            case 1:
                                                <span class="badge bg-info">School</span>
                                                break;
                                            case 2:
                                                <span class="badge bg-warning text-dark">College</span>
                                                break;
                                            default:
                                                <span class="badge bg-primary">University</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(d.IsActive ? "bg-success" : "bg-secondary")">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                    {
                                        <td class="text-end">
                                            <button type="button" class="btn btn-xs btn-outline-secondary btn-sm me-1"
                                                    data-bs-toggle="modal" data-bs-target="#editDeptModal"
                                                    data-id="@d.Id" data-name="@d.Name" data-institution-type="@d.InstitutionType">
                                                Edit
                                            </button>
                                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                            {
                                                <form asp-action="SetDepartmentActive" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@d.Id" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="activate" value="@(!d.IsActive)" />
                                                    @if (d.IsActive)
                                                    {
                                                        <button type="submit" class="btn btn-xs btn-outline-danger btn-sm"
                                                                onclick="return confirm('Deactivate @d.Name?')">Deactivate</button>
                                                    }
                                                    else
                                                    {
                                                        <button type="submit" class="btn btn-xs btn-outline-success btn-sm"
                                                                onclick="return confirm('Activate @d.Name?')">Activate</button>
                                                    }
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (User.IsInRole("SuperAdmin"))
    {
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h2 class="h5 mb-3">Admin Department Assignments</h2>
                <div class="mb-3">
                    <a asp-action="AdminUsers" class="btn btn-sm btn-outline-primary">Open Admin User Management</a>
                </div>

                @if (Model.AdminUsers.Count == 0)
                {
                    <p class="text-muted mb-0">No active Admin users found.</p>
                }
                else
                {
                    <form asp-action="Departments" method="get" class="row g-2 align-items-end mb-3"
                          data-cascade-filter data-filter-role="@(User.IsInRole("SuperAdmin") ? "SuperAdmin" : User.IsInRole("Admin") ? "Admin" : User.IsInRole("Faculty") ? "Faculty" : "Student")">
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                        <div class="col-md-6">
                            <label class="form-label">Admin User</label>
                            <select class="form-select" name="selectedAdminUserId" onchange="this.form.submit()">
                                @foreach (var admin in Model.AdminUsers)
                                {
                                    var selected = Model.SelectedAdminUserId == admin.Id;
                                    <option value="@admin.Id" selected="@selected">
                                        @admin.UserName (@(string.IsNullOrWhiteSpace(admin.Email) ? "No email" : admin.Email))
                                    </option>
                                }
                            </select>
                        </div>
                    </form>

                    <form asp-action="UpdateAdminDepartmentAssignments" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="adminUserId" value="@Model.SelectedAdminUserId" />

                        <div class="d-flex justify-content-end gap-2 mb-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAllDeptAssignments(true)">Select All</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAllDeptAssignments(false)">Clear</button>
                        </div>

                        <div class="row g-2">
                            @foreach (var dept in Model.Departments.Where(d => d.IsActive))
                            {
                                var isChecked = Model.AssignedDepartmentIds.Contains(dept.Id);
                                <div class="col-md-4 col-sm-6">
                                    <div class="form-check border rounded p-2">
                                        <input class="form-check-input" type="checkbox" name="departmentIds" value="@dept.Id" id="dept_@dept.Id" checked="@isChecked" />
                                        <label class="form-check-label" for="dept_@dept.Id">
                                            <strong>@dept.Code</strong> - @dept.Name
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">Save Assignments</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    }
}

@* ── Create Department Modal ───────────────────────────────────────────────── *@
<div class="modal fade" id="createDepartmentModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateDepartment" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Department Code <span class="text-danger">*</span></label>
                        <input type="text" name="code" class="form-control" required maxlength="20" placeholder="e.g. CS">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" required maxlength="200" placeholder="e.g. Computer Science">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Institution Type <span class="text-danger">*</span></label>
                        <select class="form-select" name="institutionType" required>
                            <option value="0">University</option>
                            <option value="1">School</option>
                            <option value="2">College</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* ── Edit Department Modal ─────────────────────────────────────────────────── *@
<div class="modal fade" id="editDeptModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="UpdateDepartment" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="edit_deptId" name="id" />
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">New Name <span class="text-danger">*</span></label>
                        <input type="text" id="edit_deptName" name="newName" class="form-control" required maxlength="200">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Institution Type</label>
                        <select id="edit_institutionType" class="form-select" name="institutionType">
                            <option value="0">University</option>
                            <option value="1">School</option>
                            <option value="2">College</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('editDeptModal')?.addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('edit_deptId').value   = btn.dataset.id;
    document.getElementById('edit_deptName').value = btn.dataset.name;
    document.getElementById('edit_institutionType').value = btn.dataset.institutionType || '0';
});

function toggleAllDeptAssignments(checked) {
    document.querySelectorAll('input[name="departmentIds"]').forEach(function (cb) {
        cb.checked = checked;
    });
}
</script>
}
