@model Tabsan.EduSphere.Web.Models.Portal.ViewQuizzesPageModel
@{ ViewData["Title"] = "View Quizzes"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">My Quizzes</h2>

            @if (Model.Quizzes.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    No quizzes found.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sr.</th>
                                <th>Quiz Name</th>
                                <th>Last Date</th>
                                <th>Submit Date</th>
                                <th>Status</th>
                                <th>Marks</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var quiz in Model.Quizzes)
                        {
                            var statusClass = quiz.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase)
                                ? "bg-success"
                                : quiz.Status.Equals("Submitted", StringComparison.OrdinalIgnoreCase)
                                    ? "bg-warning text-dark"
                                    : "bg-secondary";

                            <tr>
                                <td>@quiz.SrNo</td>
                                <td>@quiz.QuizName</td>
                                <td>@(quiz.LastDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                <td>@(quiz.SubmitDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <span class="badge @statusClass">@quiz.Status</span>
                                        @if (quiz.CanSubmit)
                                        {
                                            <form asp-action="SubmitStudentQuiz" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="quizId" value="@quiz.QuizId" />
                                                <input type="file" name="submissionFile" class="form-control form-control-sm"
                                                       accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.ppt,.pptx" />
                                                <button type="submit" class="btn btn-sm btn-primary">Submit</button>
                                                <small class="text-muted">Upload is optional. You can submit without a file.</small>
                                            </form>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (quiz.Marks.HasValue)
                                    {
                                        if (quiz.MaxScore > 0)
                                        {
                                            @($"{quiz.Marks.Value:0.##}/{quiz.MaxScore}")
                                        }
                                        else
                                        {
                                            @quiz.Marks.Value.ToString("0.##")
                                        }
                                    }
                                    else
                                    {
                                        @("-")
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
