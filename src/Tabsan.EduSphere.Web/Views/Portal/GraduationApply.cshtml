@* Final-Touches Phase 18 Stage 18.1 — student graduation apply page *@
@model GraduationApplyPageModel
@{
    ViewBag.Title = "Graduation Application";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="page-header mb-4">
        <h2><i class="bi bi-mortarboard me-2"></i>Graduation Application</h2>
    </div>

    <div class="alert alert-info">
        You can apply only if you are an active university student in your final semester and your FYP is completed.
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @* Show existing applications *@
    @if (Model.Applications.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header"><h5 class="mb-0">My Applications</h5></div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Program</th>
                            <th>Status</th>
                            <th>Submitted</th>
                            <th>Certificate</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            <tr>
                                <td>@app.ProgramName</td>
                                <td>
                                    <span class="badge @(app.Status == "Approved" ? "bg-success" : app.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                        @app.Status
                                    </span>
                                </td>
                                <td>@app.SubmittedAt?.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (app.HasCertificate)
                                    {
                                        <a href="@Url.Action("GraduationCertificateDownload", "Portal", new { id = app.Id })" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-download me-1"></i>Certificate
                                        </a>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    <a href="@Url.Action("GraduationApplicationDetail", "Portal", new { id = app.Id })" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : null)"
                       href="@Url.Action("GraduationApply", "Portal", new { page = Model.Page - 1 })">
                        Previous
                    </a>
                    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
                    <a class="btn btn-sm btn-outline-secondary @(Model.Page >= Model.TotalPages ? "disabled" : null)"
                       href="@Url.Action("GraduationApply", "Portal", new { page = Model.Page + 1 })">
                        Next
                    </a>
                </div>
            }
        </div>
    }

    @* Submit new application *@
    @if (Model.CanSubmitNew)
    {
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">Submit New Application</h5></div>
            <div class="card-body">
                <form method="post" asp-action="GraduationSubmit" asp-controller="Portal">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Personal Note <span class="text-muted">(optional)</span></label>
                        <textarea name="studentNote" class="form-control" rows="3" placeholder="Any notes for reviewers..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send me-1"></i>Submit Application</button>
                </form>
            </div>
        </div>
    }
    else if (!Model.Applications.Any())
    {
        <div class="alert alert-info">No graduation applications yet. Submit your first application above when eligible.</div>
    }
</div>
