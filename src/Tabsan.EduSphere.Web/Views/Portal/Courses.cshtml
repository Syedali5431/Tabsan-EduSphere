@model Tabsan.EduSphere.Web.Models.Portal.CoursesPageModel
@{
    ViewData["Title"] = "Courses & Offerings";
    var periodLabel = string.IsNullOrWhiteSpace(Model.OfferingPeriodLabel) ? "Semester" : Model.OfferingPeriodLabel;
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var cls = Model.Message.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    var canManageScope = Model.Identity?.IsSuperAdmin == true || Model.Identity?.IsAdmin == true;

    if (canManageScope)
    {
        <section class="page-section-card card border-0 shadow-sm mb-3">
            <div class="card-body">
                <div class="section-head mb-3">
                    <div>
                        <span class="section-kicker">Scope selection</span>
                        <h2 class="h5 mb-1">Tenant, campus and department</h2>
                        <p class="text-muted mb-0">Use scope filters for both viewing and creating courses or offerings.</p>
                    </div>
                </div>
                <form method="get" asp-action="Courses" class="row g-2 align-items-end filter-toolbar">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-4">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var tenant in Model.Tenants)
                                {
                                    if (Model.SelectedTenantId == tenant.Id)
                                    {
                                        <option value="@tenant.Id" selected>@tenant.Code - @tenant.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@tenant.Id">@tenant.Code - @tenant.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var campus in Model.Campuses)
                                {
                                    if (Model.SelectedCampusId == campus.Id)
                                    {
                                        <option value="@campus.Id" selected>@campus.Code - @campus.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@campus.Id">@campus.Code - @campus.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <div class="col-md-4">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var campus in Model.Campuses)
                                {
                                    <option value="@campus.Id" selected="@(Model.SelectedCampusId == campus.Id ? "selected" : null)">@campus.Code - @campus.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    }
                    <div class="col-md-4">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                if (Model.SelectedDepartmentId == d.Id)
                                {
                                    <option value="@d.Id" selected>@d.Name</option>
                                }
                                else
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary">Apply Scope</button>
                    </div>
                </form>
            </div>
        </section>
    }

    <section class="page-section-card card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="section-head mb-3">
                <div>
                    <span class="section-kicker">Course operations</span>
                    <h2 class="h5 mb-1">Courses and active offerings</h2>
                    <p class="text-muted mb-0">Manage curriculum inventory and @periodLabel.ToLowerInvariant() offerings with institution-aware scoping.</p>
                </div>
            </div>
            <form method="get" asp-action="Courses" class="row g-2 align-items-end filter-toolbar">
                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                <div class="col-md-4">
                    <label class="form-label">Filter by Department</label>
                    <select name="departmentId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Departments</option>
                        @foreach (var d in Model.Departments)
                        {
                            if (Model.SelectedDepartmentId == d.Id)
                            {
                                <option value="@d.Id" selected>@d.Name</option>
                            }
                            else
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        }
                    </select>
                </div>
            </form>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-12 col-xl-6">
            <div class="page-section-card card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="section-head mb-3">
                        <h2 class="h5 mb-0">Courses <span class="badge bg-secondary ms-1">@Model.Courses.Count</span></h2>
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                        {
                            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createCourseModal">
                                Add Course
                            </button>
                        }
                    </div>
                    @if (Model.Courses.Count == 0)
                    {
                        <div class="empty-state-card">
                            <h3>No courses found</h3>
                            <p class="text-muted mb-0">Create your first course to begin publishing @periodLabel.ToLowerInvariant() offerings.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Code</th><th>Title</th><th>Dept</th><th>Cr.</th><th>Type</th>
                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin")) { <th></th> }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in Model.Courses)
                                    {
                                        <tr>
                                            <td><code>@c.Code</code></td>
                                            <td>@c.Title</td>
                                            <td>@c.DepartmentName</td>
                                            <td class="text-center">@c.CreditHours</td>
                                            <td class="text-center">
                                                @if (c.HasSemesters)
                                                {
                                                    <span class="badge stat-pill bg-info text-dark">Semester (@c.TotalSemesters)</span>
                                                }
                                                else
                                                {
                                                    <span class="badge stat-pill bg-secondary">@(c.DurationValue) @(c.DurationUnit)</span>
                                                }
                                            </td>
                                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                            {
                                                <td>
                                                    <form asp-action="DeactivateCourse" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@c.Id" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                        <button type="submit" class="btn btn-xs btn-outline-danger btn-sm"
                                                                onclick="return confirm('Deactivate @c.Code?')">Off</button>
                                                    </form>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="page-section-card card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="section-head mb-3">
                        <h2 class="h5 mb-0">Active Offerings <span class="badge bg-secondary ms-1">@Model.Offerings.Count</span></h2>
                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                        {
                            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createOfferingModal">
                                Add Offering
                            </button>
                        }
                    </div>
                    @if (Model.Offerings.Count == 0)
                    {
                        <div class="empty-state-card">
                            <h3>No offerings found</h3>
                            <p class="text-muted mb-0">Offerings appear here once a course is assigned to faculty and @periodLabel.ToLowerInvariant().</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Course</th><th>Faculty</th><th>@periodLabel</th><th>Active</th>
                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin")) { <th></th> }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in Model.Offerings)
                                    {
                                        <tr>
                                            <td>@o.CourseCode — @o.CourseTitle</td>
                                            <td>@o.FacultyName</td>
                                            <td>@o.SemesterName</td>
                                            <td class="text-center">
                                                <span class="badge stat-pill @(o.IsActive ? "bg-success" : "bg-secondary")">
                                                    @(o.IsActive ? "Yes" : "No")
                                                </span>
                                            </td>
                                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                            {
                                                <td>
                                                    <form asp-action="DeleteOffering" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@o.Id" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                        <button type="submit" class="btn btn-xs btn-outline-danger btn-sm"
                                                                onclick="return confirm('Delete this offering?')">Del</button>
                                                    </form>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* â”€â”€ Create Course Modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
<div class="modal fade" id="createCourseModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateCourse" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="filterDepartmentId" value="@Model.SelectedDepartmentId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Course</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select">
                                <option value="">All Tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name (@t.Code)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Course Code <span class="text-danger">*</span></label>
                        <input type="text" name="code" class="form-control" required maxlength="20" placeholder="e.g. CS301">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Course Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" required maxlength="200">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department <span class="text-danger">*</span></label>
                        <select name="departmentId" class="form-select js-course-department" required>
                            <option value="">Select department…</option>
                            @foreach (var d in Model.Departments)
                            {
                                if (Model.SelectedDepartmentId == d.Id)
                                {
                                    <option value="@d.Id" data-institution-type="@d.InstitutionType" selected>@d.Name</option>
                                }
                                else
                                {
                                    <option value="@d.Id" data-institution-type="@d.InstitutionType">@d.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div id="courseCreditHoursGroup" class="mb-3">
                        <label class="form-label">Credit Hours <span class="text-danger">*</span></label>
                        <input type="number" name="creditHours" class="form-control" min="1" max="6" required value="3">
                    </div>
                    @* Final-Touches Phase 19 Stage 19.1/19.2 — semester vs duration and grading type *@
                    <div id="courseSemesterTypeGroup" class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="hasSemesters" id="hasSemesters" value="true" checked onchange="toggleCourseType()">
                            <label class="form-check-label" for="hasSemesters">This course is semester-based</label>
                        </div>
                    </div>
                    <div id="semesterFields">
                        <div class="mb-3">
                            <label class="form-label">Number of Semesters</label>
                            <input type="number" name="totalSemesters" class="form-control" min="1" max="16" value="4">
                        </div>
                    </div>
                    <div id="durationFields" style="display:none">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label">Duration</label>
                                <input type="number" name="durationValue" class="form-control" min="1" value="6">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Unit</label>
                                <select name="durationUnit" class="form-select">
                                    <option value="Weeks">Weeks</option>
                                    <option value="Months" selected>Months</option>
                                    <option value="Years">Years</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Grading Type</label>
                        <select name="gradingType" class="form-select">
                            <option value="GPA" selected>GPA</option>
                            <option value="Percentage">Percentage</option>
                            <option value="Grade">Grade</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Course</button>
                </div>
            </div>
        </form>
    </div>
</div>
<script>
function toggleCourseType() {
    var cb = document.getElementById('hasSemesters');
    document.getElementById('semesterFields').style.display = cb.checked ? '' : 'none';
    document.getElementById('durationFields').style.display = cb.checked ? 'none' : '';
}

function applyInstitutionModeToCourseForm() {
    var departmentSelect = document.querySelector('#createCourseModal .js-course-department');
    var creditHoursGroup = document.getElementById('courseCreditHoursGroup');
    var semesterTypeGroup = document.getElementById('courseSemesterTypeGroup');
    var semesterFields = document.getElementById('semesterFields');
    var durationFields = document.getElementById('durationFields');
    var hasSemesters = document.getElementById('hasSemesters');

    if (!departmentSelect || !creditHoursGroup || !semesterTypeGroup || !semesterFields || !durationFields || !hasSemesters)
        return;

    var selectedOption = departmentSelect.options[departmentSelect.selectedIndex];
    var institutionType = selectedOption ? selectedOption.getAttribute('data-institution-type') : null;
    var isSchoolOrCollege = institutionType === '1' || institutionType === '2';

    creditHoursGroup.style.display = isSchoolOrCollege ? 'none' : '';
    semesterTypeGroup.style.display = isSchoolOrCollege ? 'none' : '';

    if (isSchoolOrCollege) {
        hasSemesters.checked = false;
        semesterFields.style.display = 'none';
        durationFields.style.display = '';
    } else {
        toggleCourseType();
    }
}

document.addEventListener('DOMContentLoaded', function () {
    var filterDepartment = document.querySelector('#createCourseModal input[name="filterDepartmentId"]');
    var courseDepartment = document.querySelector('#createCourseModal .js-course-department');
    if (filterDepartment && courseDepartment) {
        courseDepartment.addEventListener('change', function () {
            filterDepartment.value = this.value || '';
            applyInstitutionModeToCourseForm();
        });
    }
    toggleCourseType();
    applyInstitutionModeToCourseForm();
});
</script>

@* â”€â”€ Create Offering Modal â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
<div class="modal fade" id="createOfferingModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateOffering" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Course Offering</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select">
                                <option value="">All Tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name (@t.Code)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Course <span class="text-danger">*</span></label>
                        <select name="courseId" class="form-select" required>
                            <option value="">Select a course…</option>
                            @foreach (var c in Model.Courses)
                            {
                                <option value="@c.Id">@c.Code — @c.Title</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@periodLabel <span class="text-danger">*</span></label>
                        <select name="semesterId" class="form-select" required>
                            <option value="">Select a @periodLabel.ToLowerInvariant()…</option>
                            @foreach (var s in Model.Semesters)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Faculty (optional)</label>
                        <select name="facultyUserId" class="form-select">
                            <option value="">— None —</option>
                            @foreach (var f in Model.Faculty)
                            {
                                <option value="@f.Id">@f.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Max Enrollment <span class="text-danger">*</span></label>
                        <input type="number" name="maxEnrollment" class="form-control" min="1" required value="30">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Offering</button>
                </div>
            </div>
        </form>
    </div>
</div>
