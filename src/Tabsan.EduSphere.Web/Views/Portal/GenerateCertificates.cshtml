@model GenerateCertificatesPageModel
@{
    ViewBag.Title = "Generate Certificates";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-award me-2"></i>Generate Certificates</h2>
        @if (Model.CanManage)
        {
            <span class="badge bg-success">Admin Manage Mode</span>
        }
        else
        {
            <span class="badge bg-secondary">View/Download Mode</span>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-info">@Model.Message</div>
    }

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning">Connect API from Dashboard first.</div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-3">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var tenant in Model.Tenants)
                                {
                                    <option value="@tenant.Id" selected="@(Model.SelectedTenantId == tenant.Id)">@tenant.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()" @(Model.SelectedTenantId.HasValue ? null : "disabled")>
                                <option value="">All Campuses</option>
                                @foreach (var campus in Model.Campuses)
                                {
                                    <option value="@campus.Id" selected="@(Model.SelectedCampusId == campus.Id)">@campus.Name</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Course</label>
                        <select name="courseId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Courses</option>
                            @foreach (var c in Model.Courses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCourseId == c.Id)">@c.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-auto">
                        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-filter me-1"></i>Apply</button>
                        <a href="@Url.Action("GenerateCertificates", "Portal")" class="btn btn-outline-secondary ms-2">Clear</a>
                    </div>
                </form>
            </div>
        </div>

        @if (!Model.Students.Any())
        {
            <div class="alert alert-info">No graduated students found for the selected scope.</div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Reg. #</th>
                                <th>Department</th>
                                <th>Program</th>
                                <th>Graduated</th>
                                <th>Degree</th>
                                <th>Transcript</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td>@student.StudentName</td>
                                    <td>@student.RegistrationNumber</td>
                                    <td>@student.DepartmentName</td>
                                    <td>@student.ProgramName</td>
                                    <td>@student.GraduatedDate?.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (Model.CanManage)
                                            {
                                                <form method="post" asp-action="GenerateDegreeCertificate" asp-controller="Portal" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="studentProfileId" value="@student.StudentProfileId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                    <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success">Generate</button>
                                                </form>
                                            }
                                            @if (student.LatestDegreeDocumentId.HasValue)
                                            {
                                                <a class="btn btn-sm btn-outline-primary"
                                                   href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestDegreeDocumentId.Value, format = "docx" })">Download</a>
                                                <a class="btn btn-sm btn-outline-secondary"
                                                   target="_blank"
                                                   href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestDegreeDocumentId.Value, format = "pdf" })">Print</a>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            @if (Model.CanManage)
                                            {
                                                <form method="post" asp-action="GenerateTranscriptCertificate" asp-controller="Portal" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="studentProfileId" value="@student.StudentProfileId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                    <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success">Generate</button>
                                                </form>
                                            }
                                            @if (student.LatestTranscriptDocumentId.HasValue)
                                            {
                                                <a class="btn btn-sm btn-outline-primary"
                                                   href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestTranscriptDocumentId.Value, format = "docx" })">Download</a>
                                                <a class="btn btn-sm btn-outline-secondary"
                                                   target="_blank"
                                                   href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestTranscriptDocumentId.Value, format = "pdf" })">Print</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>
