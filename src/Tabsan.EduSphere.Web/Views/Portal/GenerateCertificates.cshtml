@model GenerateCertificatesPageModel
@{
    ViewBag.Title = "Generate Certificates";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-award me-2"></i>Generate Certificates</h2>
        @if (Model.CanManage)
        {
            <span class="badge bg-success">Admin Manage Mode</span>
        }
        else
        {
            <span class="badge bg-secondary">View/Download Mode</span>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-info">@Model.Message</div>
    }

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning">Connect API from Dashboard first.</div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Institution</label>
                        @if (Model.CanSelectInstitution)
                        {
                            <select name="institutionType" class="form-select" onchange="resetFiltersAndSubmit(this.form)">
                                @foreach (var institution in Model.AvailableInstitutionTypes)
                                {
                                    <option value="@institution.Value" selected="@(Model.SelectedInstitutionType == institution.Value)">@institution.Label</option>
                                }
                            </select>
                        }
                        else
                        {
                            <select class="form-select" disabled>
                                <option selected>@(Model.AvailableInstitutionTypes.FirstOrDefault()?.Label ?? "University")</option>
                            </select>
                            <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                        }
                    </div>

                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <div class="col-md-4">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var tenant in Model.Tenants)
                                {
                                    <option value="@tenant.Id" selected="@(Model.SelectedTenantId == tenant.Id)">@tenant.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var campus in Model.Campuses)
                                {
                                    <option value="@campus.Id" selected="@(Model.SelectedCampusId == campus.Id)">@campus.Name</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-md-4">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Departments</option>
                            @foreach (var department in Model.Departments)
                            {
                                <option value="@department.Id" selected="@(Model.SelectedDepartmentId == department.Id)">@department.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Course</label>
                        <select name="courseId" class="form-select">
                            <option value="">All Courses</option>
                            @foreach (var course in Model.Courses)
                            {
                                <option value="@course.Id" selected="@(Model.SelectedCourseId == course.Id)">@course.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">@Model.PeriodFilterLabel</label>
                        <select name="semesterId" class="form-select">
                            <option value="">All @Model.PeriodFilterLabel</option>
                            @foreach (var period in Model.Semesters)
                            {
                                <option value="@period.Id" selected="@(Model.SelectedSemesterId == period.Id)">@period.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-auto">
                        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-filter me-1"></i>Apply</button>
                        <a href="@Url.Action("GenerateCertificates", "Portal")" class="btn btn-outline-secondary ms-2">Clear</a>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.CanManage)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <strong>Certificate Templates</strong>
                </div>
                <div class="card-body">
                    @if (Model.ShowUniversityCertificates)
                    {
                        <div class="row g-3">
                            <div class="col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <h6 class="mb-2">Degree Template (.docx)</h6>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@Url.Action("DownloadCertificateTemplate", "Portal", new { templateType = "degree", tenantId = Model.SelectedTenantId, campusId = Model.SelectedCampusId, departmentId = Model.SelectedDepartmentId, courseId = Model.SelectedCourseId, institutionType = Model.SelectedInstitutionType, semesterId = Model.SelectedSemesterId })">Download Default</a>
                                    </div>
                                    <form method="post" enctype="multipart/form-data" asp-action="UploadCertificateTemplate" asp-controller="Portal" class="d-flex flex-wrap gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="templateType" value="degree" />
                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                        <input type="file" name="file" class="form-control form-control-sm" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Import Template</button>
                                    </form>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <h6 class="mb-2">Transcript Template (.docx)</h6>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@Url.Action("DownloadCertificateTemplate", "Portal", new { templateType = "transcript", tenantId = Model.SelectedTenantId, campusId = Model.SelectedCampusId, departmentId = Model.SelectedDepartmentId, courseId = Model.SelectedCourseId, institutionType = Model.SelectedInstitutionType, semesterId = Model.SelectedSemesterId })">Download Default</a>
                                    </div>
                                    <form method="post" enctype="multipart/form-data" asp-action="UploadCertificateTemplate" asp-controller="Portal" class="d-flex flex-wrap gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="templateType" value="transcript" />
                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                        <input type="file" name="file" class="form-control form-control-sm" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Import Template</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <h6 class="mb-2">Completion Certificate Template (.docx)</h6>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@Url.Action("DownloadCertificateTemplate", "Portal", new { templateType = "completion", tenantId = Model.SelectedTenantId, campusId = Model.SelectedCampusId, departmentId = Model.SelectedDepartmentId, courseId = Model.SelectedCourseId, institutionType = Model.SelectedInstitutionType, semesterId = Model.SelectedSemesterId })">Download Default</a>
                                    </div>
                                    <form method="post" enctype="multipart/form-data" asp-action="UploadCertificateTemplate" asp-controller="Portal" class="d-flex flex-wrap gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="templateType" value="completion" />
                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                        <input type="file" name="file" class="form-control form-control-sm" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Import Template</button>
                                    </form>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <h6 class="mb-2">Report Card Template (.docx)</h6>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@Url.Action("DownloadCertificateTemplate", "Portal", new { templateType = "reportcard", tenantId = Model.SelectedTenantId, campusId = Model.SelectedCampusId, departmentId = Model.SelectedDepartmentId, courseId = Model.SelectedCourseId, institutionType = Model.SelectedInstitutionType, semesterId = Model.SelectedSemesterId })">Download Default</a>
                                    </div>
                                    <form method="post" enctype="multipart/form-data" asp-action="UploadCertificateTemplate" asp-controller="Portal" class="d-flex flex-wrap gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="templateType" value="reportcard" />
                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                        <input type="file" name="file" class="form-control form-control-sm" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Import Template</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (!Model.Students.Any())
        {
            <div class="alert alert-info">No students found for the selected scope.</div>
        }
        else
        {
            <div class="card shadow-sm">
                <div class="card-body border-bottom">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-6 col-lg-4">
                            <label for="certificateStudentSearch" class="form-label mb-1">Search Students</label>
                            <input id="certificateStudentSearch"
                                   type="search"
                                   class="form-control"
                                   placeholder="Type name, registration, department, or program" />
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table id="certificateStudentsTable" class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Reg. #</th>
                                <th>Department</th>
                                <th>Program</th>
                                <th>Graduated</th>
                                @if (Model.ShowUniversityCertificates)
                                {
                                    <th>Degree</th>
                                    <th>Transcript</th>
                                }
                                else
                                {
                                    <th>Certificates</th>
                                }
                            </tr>
                        </thead>
                        <tbody id="certificateStudentsTableBody">
                            @foreach (var student in Model.Students)
                            {
                                var additionalCertificateSearch = string.Join(" ", student.AdditionalCertificates.Select(cert =>
                                    string.IsNullOrWhiteSpace(cert.DocumentType)
                                        ? cert.Title
                                        : $"{cert.Title} {cert.DocumentType}"));
                                var rowSearch = ($"{student.StudentName} {student.RegistrationNumber} {student.DepartmentName} {student.ProgramName} {additionalCertificateSearch}").ToLowerInvariant();
                                <tr data-search="@rowSearch">
                                    <td>@student.StudentName</td>
                                    <td>@student.RegistrationNumber</td>
                                    <td>@student.DepartmentName</td>
                                    <td>@student.ProgramName</td>
                                    <td>@student.GraduatedDate?.ToString("dd MMM yyyy")</td>
                                    @if (Model.ShowUniversityCertificates)
                                    {
                                        <td>
                                            <div class="d-flex flex-wrap gap-1">
                                                @if (Model.CanManage)
                                                {
                                                    <form method="post" asp-action="GenerateDegreeCertificate" asp-controller="Portal" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="studentProfileId" value="@student.StudentProfileId" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success">Generate</button>
                                                    </form>
                                                }
                                                @if (student.LatestDegreeDocumentId.HasValue)
                                                {
                                                    <a class="btn btn-sm btn-outline-primary"
                                                       href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestDegreeDocumentId.Value, format = "docx" })">Download</a>
                                                    <a class="btn btn-sm btn-outline-secondary"
                                                       target="_blank"
                                                       href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestDegreeDocumentId.Value, format = "pdf" })">Print</a>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-1">
                                                @if (Model.CanManage)
                                                {
                                                    <form method="post" asp-action="GenerateTranscriptCertificate" asp-controller="Portal" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="studentProfileId" value="@student.StudentProfileId" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success">Generate</button>
                                                    </form>
                                                }
                                                @if (student.LatestTranscriptDocumentId.HasValue)
                                                {
                                                    <a class="btn btn-sm btn-outline-primary"
                                                       href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestTranscriptDocumentId.Value, format = "docx" })">Download</a>
                                                    <a class="btn btn-sm btn-outline-secondary"
                                                       target="_blank"
                                                       href="@Url.Action("DownloadGeneratedCertificateDocument", "Portal", new { documentId = student.LatestTranscriptDocumentId.Value, format = "pdf" })">Print</a>
                                                }
                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            <div class="d-flex flex-wrap gap-1 mb-2">
                                                @if (Model.CanUploadAdditionalCertificates)
                                                {
                                                    <form method="post" asp-action="GenerateAdditionalCertificate" asp-controller="Portal" class="d-flex flex-wrap gap-1 align-items-center">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="studentProfileId" value="@student.StudentProfileId" />
                                                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                                                        <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                                        <input type="hidden" name="institutionType" value="@Model.SelectedInstitutionType" />
                                                        <select name="documentType" class="form-select form-select-sm" style="max-width: 220px;" required>
                                                            <option value="">Select Type</option>
                                                            @foreach (var docType in Model.AvailableDocumentTypes)
                                                            {
                                                                <option value="@docType.Value">@docType.Label</option>
                                                            }
                                                        </select>
                                                        <button type="submit" class="btn btn-sm btn-outline-success">Generate</button>
                                                    </form>
                                                }
                                            </div>

                                            @if (student.AdditionalCertificates.Any())
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var cert in student.AdditionalCertificates)
                                                    {
                                                        <a class="btn btn-sm btn-outline-primary"
                                                           href="@Url.Action("DownloadStudentAdditionalCertificate", "Portal", new { documentId = cert.DocumentId })">@(string.IsNullOrWhiteSpace(cert.DocumentType) ? cert.Title : cert.Title + " (" + cert.DocumentType + ")")</a>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No generated certificates.</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

<script>
    // Reset subordinate filters when Institution changes
    function resetFiltersAndSubmit(form) {
        // Clear tenant, campus, department, course, semester selections
        var tenantSelect = form.querySelector('select[name="tenantId"]');
        var campusSelect = form.querySelector('select[name="campusId"]');
        var deptSelect = form.querySelector('select[name="departmentId"]');
        var courseSelect = form.querySelector('select[name="courseId"]');
        var semSelect = form.querySelector('select[name="semesterId"]');
        if (tenantSelect) tenantSelect.value = '';
        if (campusSelect) campusSelect.value = '';
        if (deptSelect) deptSelect.value = '';
        if (courseSelect) courseSelect.value = '';
        if (semSelect) semSelect.value = '';
        form.submit();
    }

    (function () {
        const searchInput = document.getElementById('certificateStudentSearch');
        const tableBody = document.getElementById('certificateStudentsTableBody');
        if (!searchInput || !tableBody) {
            return;
        }

        const rows = Array.from(tableBody.querySelectorAll('tr'));
        searchInput.addEventListener('input', function () {
            const term = (searchInput.value || '').trim().toLowerCase();
            rows.forEach(function (row) {
                const haystack = (row.getAttribute('data-search') || '').toLowerCase();
                row.style.display = term.length === 0 || haystack.includes(term) ? '' : 'none';
            });
        });
    })();
</script>
