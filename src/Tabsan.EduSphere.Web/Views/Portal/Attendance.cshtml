@model Tabsan.EduSphere.Web.Models.Portal.AttendancePageModel
@{ ViewData["Title"] = "Attendance"; }
@{
    var attendanceAction = ViewData["AttendanceAction"]?.ToString() ?? "Attendance";
    var periodLabel = string.IsNullOrWhiteSpace(Model.PeriodLabel) ? "Semester" : Model.PeriodLabel;
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (Model.MessageDetails.Count > 0)
{
    <div class="alert alert-warning">
        <strong>Import details</strong>
        <ul class="mb-0 mt-2">
            @foreach (var detail in Model.MessageDetails)
            {
                <li>@detail</li>
            }
        </ul>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="@attendanceAction" class="row g-2 align-items-end">
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <div class="col-md-3">
                            <label class="form-label">Tenant</label>
                            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Tenants</option>
                                @foreach (var t in Model.Tenants)
                                {
                                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Campus</label>
                            <select name="campusId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Campuses</option>
                                @foreach (var c in Model.Campuses)
                                {
                                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Course/Subject</label>
                        <select name="courseId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Courses</option>
                            @foreach (var c in Model.Courses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCourseId == c.Id ? "selected" : null)">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@periodLabel</label>
                        <select name="semesterName" class="form-select" onchange="this.form.submit()">
                            <option value="">All @periodLabel</option>
                            @foreach (var s in Model.SemesterOptions)
                            {
                                <option value="@s.Name" selected="@(string.Equals(Model.SelectedSemesterName, s.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Select Course Offering</label>
                        <select name="offeringId" class="form-select" onchange="this.form.submit()">
                            <option value="">All / My Attendance</option>
                            @foreach (var o in Model.CourseOfferings)
                            {
                                <option value="@o.Id" selected="@(Model.SelectedOfferingId == o.Id ? "selected" : null)">@o.Name</option>
                            }
                        </select>
                    </div>
                    @if (Model.SelectedOfferingId.HasValue)
                    {
                        <div class="col-md-4">
                            <label class="form-label">Student (Optional)</label>
                            <select name="studentId" class="form-select" onchange="this.form.submit()">
                                <option value="">All Students</option>
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.Id" selected="@(Model.SelectedStudentId == s.Id ? "selected" : null)">@s.Name</option>
                                }
                            </select>
                        </div>
                    }
            </form>
        </div>
    </div>

    @if (!User.IsInRole("Student"))
    {
        <div class="d-flex justify-content-end mb-3">
            <a asp-action="ReportLowAttendance" asp-route-threshold="75" class="btn btn-outline-danger btn-sm">
                View Low Attendance (&lt;75%)
            </a>
        </div>
    }

    @if (Model.Summary.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h2 class="h5 mb-3">Attendance Summary</h2>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Reg. No.</th>
                                <th>Course</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Summary)
                            {
                                var pct = s.AttendancePercentage;
                                var cls = pct >= 75 ? "text-success" : pct >= 50 ? "text-warning" : "text-danger";
                                <tr>
                                    <td>@s.StudentName</td>
                                    <td><code>@s.RegistrationNumber</code></td>
                                    <td>@s.CourseName</td>
                                    <td>@s.TotalClasses</td>
                                    <td>@s.PresentCount</td>
                                    <td class="@cls fw-semibold">@pct.ToString("0.0")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.LowAttendance.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h2 class="h5 mb-3 text-danger">Low Attendance (&lt;75%)</h2>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Reg. No.</th>
                                <th>Course</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.LowAttendance)
                            {
                                <tr class="table-warning">
                                    <td>@s.StudentName</td>
                                    <td><code>@s.RegistrationNumber</code></td>
                                    <td>@s.CourseName</td>
                                    <td>@s.TotalClasses</td>
                                    <td>@s.PresentCount</td>
                                    <td class="text-danger fw-semibold">@s.AttendancePercentage.ToString("0.0")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.Records.Count > 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Attendance Records
                    <span class="badge bg-secondary ms-1">@Model.Records.Count</span>
                </h2>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Student</th><th>Reg. No.</th><th>Date</th><th>Status</th>@if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")) { <th></th> }</tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Records)
                            {
                                var badgeCls = r.Status switch
                                {
                                    "Present" => "bg-success",
                                    "Absent"  => "bg-danger",
                                    "Late"    => "bg-warning text-dark",
                                    _         => "bg-secondary"
                                };
                                <tr>
                                    <td>@r.StudentName</td>
                                    <td><code>@r.RegistrationNumber</code></td>
                                    <td>@r.Date.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge @badgeCls">@r.Status</span>
                                        @if (r.IsCorrected) { <span class="badge bg-info ms-1">Corrected</span> }
                                    </td>
                                    @if (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                    {
                                        <td class="text-end">
                                            <button type="button" class="btn btn-xs btn-outline-secondary btn-sm"
                                                    data-bs-toggle="modal" data-bs-target="#correctAttendanceModal"
                                                    data-studentid="@r.StudentProfileId" data-date="@r.Date.ToString("yyyy-MM-dd")" data-status="@r.Status">
                                                Correct
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.Records.Count == 0 && Model.Summary.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <div class="fs-1 mb-2">📋</div>
                <p>Select a course offering to view attendance records.</p>
            </div>
        </div>
    }

    @* ── Mark Attendance Form (Faculty/Admin, when offering selected and roster available) *@
    @if (Model.SelectedOfferingId.HasValue && Model.Roster.Count > 0 && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
    {
        var writeActionsDisabled = string.Equals(attendanceAction, "EnterAttendance", StringComparison.OrdinalIgnoreCase)
            && !Model.CanSaveAttendance;

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-light">
                <strong>Mark Attendance</strong>
            </div>
            <div class="card-body">
                @if (writeActionsDisabled)
                {
                    <div class="alert alert-warning py-2" role="alert">
                        @Model.SaveAttendanceDisabledReason
                    </div>
                }

                @if (string.Equals(attendanceAction, "EnterAttendance", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a class="btn btn-outline-secondary btn-sm"
                           asp-action="DownloadAttendanceCsvTemplate"
                           asp-route-offeringId="@Model.SelectedOfferingId"
                           asp-route-tenantId="@Model.SelectedTenantId"
                           asp-route-campusId="@Model.SelectedCampusId"
                           asp-route-departmentId="@Model.SelectedDepartmentId"
                           asp-route-courseId="@Model.SelectedCourseId"
                           asp-route-studentId="@Model.SelectedStudentId"
                           asp-route-semesterName="@Model.SelectedSemesterName"
                           asp-route-entryPoint="@attendanceAction">
                            Get Template
                        </a>

                        @if (!string.IsNullOrWhiteSpace(Model.ImportReportToken))
                        {
                            <a class="btn btn-outline-success btn-sm"
                               asp-action="DownloadAttendanceImportReport"
                               asp-route-reportToken="@Model.ImportReportToken"
                               asp-route-offeringId="@Model.SelectedOfferingId"
                               asp-route-tenantId="@Model.SelectedTenantId"
                               asp-route-campusId="@Model.SelectedCampusId"
                               asp-route-departmentId="@Model.SelectedDepartmentId"
                               asp-route-courseId="@Model.SelectedCourseId"
                               asp-route-studentId="@Model.SelectedStudentId"
                               asp-route-semesterName="@Model.SelectedSemesterName"
                               asp-route-entryPoint="@attendanceAction">
                                Download Last Import Report
                            </a>
                        }

                        <div class="w-100">
                            <small class="text-muted">Import reports are one-time download links and expire after 2 hours.</small>
                        </div>

                        <form asp-action="ImportAttendanceCsv" method="post" enctype="multipart/form-data" class="d-flex flex-wrap align-items-center gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                            <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                            <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                            <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                            <input type="hidden" name="entryPoint" value="@attendanceAction" />
                            <input type="hidden" name="strictMode" value="false" />
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input" type="checkbox" id="strictMode" name="strictMode" value="true" checked disabled="@writeActionsDisabled" />
                                <label class="form-check-label" for="strictMode">Strict mode</label>
                            </div>
                            <input type="file" name="csvFile" accept=".csv,text/csv" class="form-control form-control-sm" style="max-width: 280px;" required disabled="@writeActionsDisabled" />
                            <button type="submit" class="btn btn-outline-primary btn-sm" disabled="@writeActionsDisabled">Import Attendance</button>
                        </form>
                    </div>
                }

                <form asp-action="BulkMarkAttendance" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                    <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                    <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                    <input type="hidden" name="entryPoint" value="@attendanceAction" />
                    <div class="table-responsive">
                        <table class="table table-sm mb-3">
                            <thead class="table-light">
                                <tr><th>Student ID</th><th>Student Name</th><th>Date</th><th>Present</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.Roster)
                                {
                                    <tr>
                                        <td><code>@s.RegistrationNumber</code></td>
                                        <td>@s.StudentName</td>
                                        <td>
                                            <input type="hidden" name="studentIds" value="@s.Id" />
                                            <input type="date" name="dates" class="form-control form-control-sm" style="min-width: 170px;"
                                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" required disabled="@writeActionsDisabled" />
                                        </td>
                                        <td>
                                            <input type="hidden" name="statuses" id="status_@s.Id" value="Present" />
                                            <div class="form-check mb-0">
                                                <input type="checkbox"
                                                       class="form-check-input attendance-present-checkbox"
                                                       id="present_@s.Id"
                                                       data-status-target="status_@s.Id"
                                                       checked
                                                       disabled="@writeActionsDisabled" />
                                                <label class="form-check-label" for="present_@s.Id">Present</label>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <button type="submit" class="btn btn-primary" disabled="@writeActionsDisabled">Save Attendance</button>
                </form>
            </div>
        </div>
    }

    @if (string.Equals(attendanceAction, "EnterAttendance", StringComparison.OrdinalIgnoreCase)
        && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        && (!Model.SelectedOfferingId.HasValue || Model.Roster.Count == 0))
    {
        var writeActionsDisabled = !Model.SelectedOfferingId.HasValue || !Model.CanSaveAttendance;

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-light">
                <strong>Attendance Entry Table</strong>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-action="DownloadAttendanceCsvTemplate"
                       asp-route-offeringId="@Model.SelectedOfferingId"
                       asp-route-tenantId="@Model.SelectedTenantId"
                       asp-route-campusId="@Model.SelectedCampusId"
                       asp-route-departmentId="@Model.SelectedDepartmentId"
                       asp-route-courseId="@Model.SelectedCourseId"
                       asp-route-studentId="@Model.SelectedStudentId"
                       asp-route-semesterName="@Model.SelectedSemesterName"
                       asp-route-entryPoint="@attendanceAction">
                        Get Template
                    </a>

                    <form asp-action="ImportAttendanceCsv" method="post" enctype="multipart/form-data" class="d-flex flex-wrap align-items-center gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                        <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                        <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                        <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                        <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                        <input type="hidden" name="entryPoint" value="@attendanceAction" />
                        <input type="hidden" name="strictMode" value="false" />
                        <div class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="checkbox" id="strictModeFallback" name="strictMode" value="true" checked disabled="@writeActionsDisabled" />
                            <label class="form-check-label" for="strictModeFallback">Strict mode</label>
                        </div>
                        <input type="file" name="csvFile" accept=".csv,text/csv" class="form-control form-control-sm" style="max-width: 280px;" required disabled="@writeActionsDisabled" />
                        <button type="submit" class="btn btn-outline-primary btn-sm" disabled="@writeActionsDisabled">Import Attendance</button>
                    </form>
                </div>

                <div class="alert alert-warning py-2" role="alert">
                    @Model.SaveAttendanceDisabledReason
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-3">
                        <thead class="table-light">
                            <tr><th>Student ID</th><th>Student Name</th><th>Date</th><th>Present</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">-</td>
                                <td class="text-muted">Select required filters and offering</td>
                                <td><input type="date" class="form-control form-control-sm" disabled /></td>
                                <td><input type="checkbox" class="form-check-input" disabled /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-primary" disabled>Save Attendance</button>
            </div>
        </div>
    }

    @if (Model.SelectedOfferingId.HasValue && (User.IsInRole("Faculty") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
    {
        <div class="modal fade" id="correctAttendanceModal" tabindex="-1">
            <div class="modal-dialog">
                <form asp-action="CorrectAttendance" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="correctAttendance_studentProfileId" name="studentProfileId" />
                    <input type="hidden" name="offeringId" value="@Model.SelectedOfferingId" />
                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                    <input type="hidden" name="courseId" value="@Model.SelectedCourseId" />
                    <input type="hidden" name="studentId" value="@Model.SelectedStudentId" />
                    <input type="hidden" name="semesterName" value="@Model.SelectedSemesterName" />
                    <input type="hidden" name="entryPoint" value="@attendanceAction" />
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Correct Attendance</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Date <span class="text-danger">*</span></label>
                                <input id="correctAttendance_date" name="date" type="date" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">New Status <span class="text-danger">*</span></label>
                                <select id="correctAttendance_status" name="newStatus" class="form-select" required>
                                    <option value="Present">Present</option>
                                    <option value="Absent">Absent</option>
                                    <option value="Late">Late</option>
                                    <option value="Excused">Excused</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Remarks</label>
                                <textarea name="remarks" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Correction</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
}

@section Scripts {
<script>
document.getElementById('correctAttendanceModal')?.addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('correctAttendance_studentProfileId').value = btn.dataset.studentid;
    document.getElementById('correctAttendance_date').value = btn.dataset.date;
    document.getElementById('correctAttendance_status').value = btn.dataset.status;
});

document.querySelectorAll('.attendance-present-checkbox').forEach(function(checkbox) {
    checkbox.addEventListener('change', function() {
        var targetId = checkbox.getAttribute('data-status-target');
        if (!targetId) return;

        var statusInput = document.getElementById(targetId);
        if (statusInput) {
            statusInput.value = checkbox.checked ? 'Present' : 'Absent';
        }
    });
});
</script>
}
