@model Tabsan.EduSphere.Web.Models.Portal.ReportTranscriptPageModel
@{
    ViewData["Title"] = "Student Transcript";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ReportCenter" asp-controller="Portal" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h2 class="mb-0"><i class="bi bi-journal-text me-2"></i>Student Transcript</h2>
            <small class="text-muted">Full academic record for a selected student</small>
        </div>
    </div>

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning"><i class="bi bi-wifi-off me-2"></i>Not connected to API.</div>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger">@Model.Message</div>
        }

        <form method="get" class="card shadow-sm border-0 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-8">
                        <label class="form-label small mb-1">Student</label>
                        <select name="studentProfileId" class="form-select form-select-sm">
                            <option value="">Select a student…</option>
                            @foreach (var s in Model.Students)
                            {
                                <option value="@s.Id" selected="@(Model.StudentProfileId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search me-1"></i>View Transcript</button>
                    </div>
                    @if (Model.Report is not null)
                    {
                        <div class="col-md-1">
                                     <a href="@Url.Action("ExportStudentTranscript", "Portal", new { studentProfileId = Model.StudentProfileId })"
                                         class="btn btn-success btn-sm w-100" title="Export Excel"><i class="bi bi-file-earmark-excel me-1"></i><span>Excel</span></a>
                        </div>
                        <div class="col-md-1">
                                     <a href="@Url.Action("ExportStudentTranscriptCsv", "Portal", new { studentProfileId = Model.StudentProfileId })"
                                         class="btn btn-outline-success btn-sm w-100" title="Export CSV"><i class="bi bi-filetype-csv me-1"></i><span>CSV</span></a>
                        </div>
                        <div class="col-md-1">
                                     <a href="@Url.Action("ExportStudentTranscriptPdf", "Portal", new { studentProfileId = Model.StudentProfileId })"
                                         class="btn btn-outline-danger btn-sm w-100" title="Export PDF"><i class="bi bi-filetype-pdf me-1"></i><span>PDF</span></a>
                        </div>
                    }
                </div>
            </div>
        </form>

        @if (Model.Report is not null)
        {
            var r = Model.Report;
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Name:</strong> @r.StudentName</p>
                            <p class="mb-1"><strong>Reg. No.:</strong> @r.RegistrationNumber</p>
                            <p class="mb-0"><strong>Program:</strong> @r.ProgramName</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Department:</strong> @r.DepartmentName</p>
                            <p class="mb-1"><strong>CGPA:</strong> @r.Cgpa.ToString("F2")</p>
                            <p class="mb-0 text-muted small">Generated: @r.GeneratedAt.ToString("dd MMM yyyy, HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Course Code</th>
                                    <th>Course Title</th>
                                    <th>Semester</th>
                                    <th>Component</th>
                                    <th class="text-center">Marks</th>
                                    <th class="text-center">Max</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">GP</th>
                                    <th>Published</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in r.Rows)
                                {
                                    <tr>
                                        <td>@row.CourseCode</td>
                                        <td>@row.CourseTitle</td>
                                        <td>@row.SemesterName</td>
                                        <td>@row.ResultType</td>
                                        <td class="text-center">@row.MarksObtained</td>
                                        <td class="text-center">@row.MaxMarks</td>
                                        <td class="text-center">@row.Percentage.ToString("F1")%</td>
                                        <td class="text-center">@(row.GradePoint.HasValue ? row.GradePoint.Value.ToString("F2") : "-")</td>
                                        <td>@(row.PublishedAt.HasValue ? row.PublishedAt.Value.ToString("dd MMM yyyy") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else if (Model.StudentProfileId.HasValue)
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No transcript data found for the selected student.</div>
        }
    }
</div>
