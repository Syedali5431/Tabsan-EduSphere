@model Tabsan.EduSphere.Web.Models.Portal.ReportResultsPageModel
@{
    ViewData["Title"] = "Result Summary Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ReportCenter" asp-controller="Portal" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h2 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>Result Summary</h2>
            <small class="text-muted">Marks and result breakdown per student per course</small>
        </div>
    </div>

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning"><i class="bi bi-wifi-off me-2"></i>Not connected to API.</div>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger">@Model.Message</div>
        }

        <form method="get" class="card shadow-sm border-0 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small mb-1">@Model.PeriodFilterLabel</label>
                        <select name="semesterId" class="form-select form-select-sm">
                            <option value="">@Model.PeriodFilterPlaceholder</option>
                            @foreach (var s in Model.Semesters)
                            {
                                <option value="@s.Id" selected="@(Model.SemesterId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Institute</label>
                        <select name="institutionType" class="form-select form-select-sm">
                            @if (!Model.InstitutionType.HasValue && Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="" selected>All Institutes</option>
                            }
                            else if (Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="">All Institutes</option>
                            }
                            @foreach (var institution in Model.AvailableInstitutionTypes)
                            {
                                <option value="@institution.Value" selected="@(Model.InstitutionType == institution.Value)">@institution.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Department</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small mb-1">Course Offering</label>
                        <select name="offeringId" class="form-select form-select-sm">
                            <option value="">All Offerings</option>
                            @foreach (var o in Model.Offerings)
                            {
                                <option value="@o.Id" selected="@(Model.OfferingId == o.Id)">@o.CourseCode — @o.CourseTitle</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
                    </div>
                    @if (Model.Report is not null)
                    {
                        <div class="col-md-1">
                            <a href="@Url.Action("ExportResultSummary", "Portal", new { semesterId = Model.SemesterId, departmentId = Model.DepartmentId, offeringId = Model.OfferingId, studentId = Model.StudentId, institutionType = Model.InstitutionType })"
                               class="btn btn-success btn-sm w-100" title="Export Excel"><i class="bi bi-file-earmark-excel me-1"></i><span>Excel</span></a>
                        </div>
                        <div class="col-md-1">
                            <a href="@Url.Action("ExportResultSummaryCsv", "Portal", new { semesterId = Model.SemesterId, departmentId = Model.DepartmentId, offeringId = Model.OfferingId, studentId = Model.StudentId, institutionType = Model.InstitutionType })"
                               class="btn btn-outline-success btn-sm w-100" title="Export CSV"><i class="bi bi-filetype-csv me-1"></i><span>CSV</span></a>
                        </div>
                        <div class="col-md-1">
                            <a href="@Url.Action("ExportResultSummaryPdf", "Portal", new { semesterId = Model.SemesterId, departmentId = Model.DepartmentId, offeringId = Model.OfferingId, studentId = Model.StudentId, institutionType = Model.InstitutionType })"
                               class="btn btn-outline-danger btn-sm w-100" title="Export PDF"><i class="bi bi-filetype-pdf me-1"></i><span>PDF</span></a>
                        </div>
                    }
                </div>
            </div>
        </form>

        @if (Model.Report is not null)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small">@Model.Report.TotalRecords record(s) &mdash; generated @Model.Report.GeneratedAt.ToString("dd MMM yyyy, HH:mm")</span>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Reg. No.</th>
                                    <th>Student</th>
                                    <th>Course</th>
                                    <th>Title</th>
                                    <th>Type</th>
                                    <th class="text-center">Marks</th>
                                    <th class="text-center">Max</th>
                                    <th class="text-center">%</th>
                                    <th>Published</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.Report.Rows)
                                {
                                    <tr>
                                        <td>@r.RegistrationNumber</td>
                                        <td>@r.StudentName</td>
                                        <td>@r.CourseCode</td>
                                        <td>@r.CourseTitle</td>
                                        <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@r.ResultType</span></td>
                                        <td class="text-center">@r.MarksObtained.ToString("F1")</td>
                                        <td class="text-center">@r.MaxMarks.ToString("F1")</td>
                                        <td class="text-center">@r.Percentage.ToString("F1")%</td>
                                        <td>@(r.PublishedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary"><i class="bi bi-info-circle me-2"></i>Select filters above and click Filter to generate the report.</div>
        }
    }
</div>
