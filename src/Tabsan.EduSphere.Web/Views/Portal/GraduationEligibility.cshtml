@* Final-Touches Phase 17 Stage 17.2 — Graduation eligibility list view (Admin/SuperAdmin) *@
@model EligibilityPageModel
@{
    ViewData["Title"] = "Graduation Eligibility";
}

<h2 class="mb-4"><i class="bi bi-check2-circle me-2"></i>Graduation Eligibility</h2>

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-info">@msg</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="badge bg-success me-2">@Model.Items.Count(i => i.IsEligible) Eligible</span>
        <span class="badge bg-danger">@Model.Items.Count(i => !i.IsEligible) Not Eligible</span>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">No students found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered align-middle" id="eligibilityTable">
            <thead class="table-light">
                <tr>
                    <th>Registration No.</th>
                    <th>Student Name</th>
                    <th class="text-center">Credits Earned</th>
                    <th class="text-center">CGPA</th>
                    <th class="text-center">Unmet Requirements</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items.OrderBy(i => i.RegistrationNumber))
                {
                    <tr>
                        <td><code>@item.RegistrationNumber</code></td>
                        <td>@item.StudentName</td>
                        <td class="text-center">@item.TotalCreditsEarned</td>
                        <td class="text-center">@item.Cgpa.ToString("F2")</td>
                        <td class="text-center">
                            @if (item.UnmetCount == 0)
                            {
                                <span class="text-success">None</span>
                            }
                            else
                            {
                                <span class="text-danger">@item.UnmetCount</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.IsEligible)
                            {
                                <span class="badge bg-success">Eligible</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Not Eligible</span>
                            }
                        </td>
                        <td>
                            <a asp-action="DegreeAudit"
                               asp-route-studentProfileId="@item.StudentProfileId"
                               class="btn btn-sm btn-outline-primary">View Audit</a>

                            @if (item.IsEligible)
                            {
                                <form asp-action="GraduationEligibilityGraduate"
                                      method="post"
                                      class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="studentId" value="@item.StudentProfileId" />
                                    <input type="hidden" name="departmentId" value="@Model.DepartmentId" />
                                    <input type="hidden" name="programId" value="@Model.ProgramId" />
                                    <button type="submit"
                                            class="btn btn-sm btn-success"
                                            onclick="return confirm('Graduate this eligible student now?');">
                                        Graduate
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
