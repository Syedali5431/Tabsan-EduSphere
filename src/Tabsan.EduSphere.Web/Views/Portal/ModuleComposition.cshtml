@model DashboardCompositionModel
@{
    ViewData["Title"] = "Module Composition";
}

<h2 class="mb-4">Module &amp; Dashboard Composition</h2>

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected to API.</div>
    return;
}
@if (Model.Message != null)
{
    <div class="alert alert-warning">@Model.Message</div>
}

@* ── Vocabulary ──────────────────────────────────────────────────────────── *@
<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <i class="bi bi-translate me-2"></i> Active Academic Vocabulary
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Labels used across all pages are derived from the current institution policy.
        </p>
        <div class="row row-cols-2 row-cols-md-5 g-3">
            <div class="col">
                <div class="border rounded p-3 text-center">
                    <div class="text-muted small">Period</div>
                    <div class="fw-bold">@Model.PeriodLabel</div>
                </div>
            </div>
            <div class="col">
                <div class="border rounded p-3 text-center">
                    <div class="text-muted small">Progression</div>
                    <div class="fw-bold">@Model.ProgressionLabel</div>
                </div>
            </div>
            <div class="col">
                <div class="border rounded p-3 text-center">
                    <div class="text-muted small">Grading</div>
                    <div class="fw-bold">@Model.GradingLabel</div>
                </div>
            </div>
            <div class="col">
                <div class="border rounded p-3 text-center">
                    <div class="text-muted small">Course</div>
                    <div class="fw-bold">@Model.CourseLabel</div>
                </div>
            </div>
            <div class="col">
                <div class="border rounded p-3 text-center">
                    <div class="text-muted small">Student Group</div>
                    <div class="fw-bold">@Model.StudentGroupLabel</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Dashboard Widgets ──────────────────────────────────────────────────── *@
<div class="card shadow-sm mb-4">
    <div class="card-header bg-success text-white">
        <i class="bi bi-grid me-2"></i> Your Dashboard Widgets (@Model.Widgets.Count)
    </div>
    <div class="card-body">
        @if (!Model.Widgets.Any())
        {
            <p class="text-muted">No widgets assigned for your role.</p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-3">
                @foreach (var widget in Model.Widgets.OrderBy(w => w.Order))
                {
                    <div class="col">
                        <div class="border rounded p-3 d-flex align-items-center gap-3">
                            <i class="bi @widget.Icon fs-4 text-primary"></i>
                            <div>
                                <div class="fw-semibold">@widget.Title</div>
                                <div class="text-muted small">@widget.Key</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* ── Module Registry ────────────────────────────────────────────────────── *@
<div class="card shadow-sm">
    <div class="card-header">
        <i class="bi bi-list-check me-2"></i> Module Registry (@Model.Modules.Count modules)
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Key</th>
                        <th>Name</th>
                        <th class="text-center">Active</th>
                        <th class="text-center">Accessible (your role)</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Modules.OrderBy(x => x.Key))
                    {
                        <tr class="@(m.IsAccessible ? "" : "text-muted")">
                            <td><code>@m.Key</code></td>
                            <td>@m.Name</td>
                            <td class="text-center">
                                @if (m.IsActive)
                                {
                                    <span class="badge bg-success">On</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Off</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (m.IsAccessible)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-dash-circle text-secondary"></i>
                                }
                            </td>
                            <td class="text-center">
                                @if (Model.CanManageModules)
                                {
                                    <form asp-action="ToggleCompositionModule" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="key" value="@m.Key" />
                                        <input type="hidden" name="activate" value="@(!m.IsActive)" />
                                        <button type="submit" class="btn btn-sm @(m.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                            @(m.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">SuperAdmin only</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
