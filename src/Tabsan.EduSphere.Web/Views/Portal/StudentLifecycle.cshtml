@model Tabsan.EduSphere.Web.Models.Portal.StudentLifecyclePageModel
@{ ViewData["Title"] = "Student Lifecycle"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="StudentLifecycle" class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Institution</label>
                    <select name="institutionType" class="form-select" onchange="resetStudentFiltersAndSubmit(this.form)">
                        <option value="">All</option>
                        <option value="0" selected="@(Model.SelectedInstitutionType == 0 ? "selected" : null)">University</option>
                        <option value="1" selected="@(Model.SelectedInstitutionType == 1 ? "selected" : null)">School</option>
                        <option value="2" selected="@(Model.SelectedInstitutionType == 2 ? "selected" : null)">College</option>
                    </select>
                </div>
                @if (Model.Identity?.IsSuperAdmin == true)
                {
                    <div class="col-md-2">
                        <label class="form-label">Tenant</label>
                        <select name="tenantId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Tenants</option>
                            @foreach (var t in Model.Tenants)
                            {
                                <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Campus</label>
                        <select name="campusId" class="form-select" onchange="this.form.submit()" @(Model.SelectedTenantId.HasValue ? null : "disabled")>
                            <option value="">All Campuses</option>
                            @foreach (var c in Model.Campuses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-md-2">
                    <label class="form-label">Department</label>
                    <select name="departmentId" class="form-select" onchange="this.form.submit()">
                        <option value="">Select…</option>
                        @foreach (var d in Model.Departments)
                        {
                            <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">@Model.PeriodLabel</label>
                    <select name="semester" class="form-select" onchange="this.form.submit()">
                        @for (int i = Model.MinAcademicLevel; i <= Model.MaxAcademicLevel; i++)
                        {
                            <option value="@i" selected="@(Model.SelectedSemester == i ? "selected" : null)">@i</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3" id="lifecycleTabs">
        @if (Model.ShowGraduationSection)
        {
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabGrad">
                    Graduation Candidates
                    <span class="badge bg-danger ms-1">@Model.GraduationCandidates.Count</span>
                </button>
            </li>
        }
        <li class="nav-item">
            <button class="nav-link @(Model.ShowGraduationSection ? null : "active")" data-bs-toggle="tab" data-bs-target="#tabSem">
                @Model.PeriodLabel Students
                <span class="badge bg-secondary ms-1">@Model.StudentsBySemester.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">
        @if (Model.ShowGraduationSection)
        {
            <div class="tab-pane fade show active" id="tabGrad">
                @if (Model.GraduationCandidates.Count == 0)
                {
                    <p class="text-muted">No graduation candidates in this department.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Reg. No.</th>
                                    <th>Name</th>
                                    <th>Program</th>
                                    <th>CGPA</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.GraduationCandidates)
                                {
                                    <tr>
                                        <td><code>@s.RegistrationNumber</code></td>
                                        <td>@s.FullName</td>
                                        <td>@s.ProgramName</td>
                                        <td>@(s.Cgpa.HasValue ? s.Cgpa.Value.ToString("0.00") : "–")</td>
                                        <td>
                                            <form asp-action="GraduateStudent" method="post" class="d-inline">
                                                <input type="hidden" name="studentId" value="@s.Id" />
                                                <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                <button type="submit" class="btn btn-success btn-sm"
                                                        onclick="return confirm('Graduate this student?')">
                                                    Graduate
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        <div class="tab-pane fade @(Model.ShowGraduationSection ? null : "show active")" id="tabSem">
            @if (Model.StudentsBySemester.Count == 0)
            {
                <p class="text-muted">No students in selected department / @Model.PeriodLabel.ToLowerInvariant().</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr><th>Reg. No.</th><th>Name</th><th>@Model.PeriodLabel</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.StudentsBySemester)
                            {
                                <tr>
                                    <td><code>@s.RegistrationNumber</code></td>
                                    <td>@s.FullName</td>
                                    <td>@s.SemesterNumber</td>
                                    <td>
                                        <form asp-action="PromoteStudent" method="post" class="d-inline">
                                            <input type="hidden" name="studentId" value="@s.Id" />
                                            <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                            <input type="hidden" name="semester" value="@Model.SelectedSemester" />
                                            <button type="submit" class="btn btn-outline-primary btn-sm"
                                                    onclick="return confirm('Promote this student?')">
                                                Promote
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<script>
    function resetStudentFiltersAndSubmit(form) {
        form.querySelector('select[name="tenantId"]').value = '';
        form.querySelector('select[name="campusId"]').value = '';
        form.querySelector('select[name="departmentId"]').value = '';
        form.querySelector('select[name="semester"]').value = '1';
        form.submit();
    }
</script>

