@model Tabsan.EduSphere.Web.Models.Portal.TwoFactorSettingsPageModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    var message = TempData["Message"] as string ?? Model.Message;
    var hasSetup = !string.IsNullOrWhiteSpace(Model.QrCodeDataUrl);
}

<style>
    .security-shell {
        --accent-1: #0f766e;
        --accent-2: #134e4a;
        --accent-3: #f59e0b;
        background:
            radial-gradient(circle at top left, rgba(15, 118, 110, 0.16), transparent 34%),
            radial-gradient(circle at top right, rgba(245, 158, 11, 0.12), transparent 26%),
            linear-gradient(180deg, rgba(255,255,255,0.96), rgba(248,250,252,0.96));
        border: 1px solid rgba(15, 118, 110, 0.12);
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
    }

    .security-hero {
        display: grid;
        grid-template-columns: 1.2fr .8fr;
        gap: 1rem;
        align-items: stretch;
        margin-bottom: 1.25rem;
    }

    .security-badge {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.1);
        color: #0f766e;
        font-weight: 700;
        letter-spacing: .02em;
        font-size: .8rem;
        width: fit-content;
    }

    .security-card {
        border: 0;
        border-radius: 20px;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .security-card .card-header {
        background: linear-gradient(135deg, rgba(15,118,110,.95), rgba(19,78,74,.98));
        color: #fff;
        border: 0;
    }

    .security-panel {
        background: #fff;
        border-radius: 20px;
        border: 1px solid rgba(15, 118, 110, 0.10);
        padding: 1.25rem;
        height: 100%;
    }

    .qr-frame {
        display: grid;
        place-items: center;
        min-height: 280px;
        border-radius: 18px;
        background:
            linear-gradient(135deg, rgba(15, 118, 110, 0.08), rgba(245, 158, 11, 0.08)),
            #fff;
        border: 1px dashed rgba(15, 118, 110, 0.28);
    }

    .qr-frame img {
        width: 240px;
        height: 240px;
        object-fit: contain;
        image-rendering: pixelated;
        border-radius: 14px;
        background: #fff;
        padding: .5rem;
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.10);
    }

    .code-input {
        letter-spacing: .28em;
        font-size: 1.2rem;
        text-align: center;
        font-weight: 700;
    }

    .mini-hint {
        color: #475569;
        font-size: .92rem;
    }

    .security-chip {
        color: #0f172a !important;
        background: rgba(255, 255, 255, 0.96) !important;
        border-color: rgba(15, 118, 110, 0.16) !important;
    }

    .security-code-box {
        color: #0f172a;
        background: rgba(255, 255, 255, 0.98) !important;
    }
</style>

<div class="security-shell">
    <div class="security-hero">
        <div class="security-panel">
            <div class="security-badge mb-3">
                <i class="bi bi-shield-lock-fill"></i>
                Secure account protection
            </div>
            <h2 class="h3 mb-2">Two-Factor Authentication</h2>
            <p class="text-muted mb-3">
                Use an authenticator app such as Google Authenticator or Authy to add a second login check.
                The setup flow stays additive, and the legacy login screen continues to work as before.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge rounded-pill text-bg-light border security-chip">RFC 6238 TOTP</span>
                <span class="badge rounded-pill text-bg-light border security-chip">QR + manual key</span>
                <span class="badge rounded-pill text-bg-light border security-chip">Encrypted secret at rest</span>
            </div>
        </div>

        <div class="security-panel d-flex flex-column justify-content-between">
            <div>
                <div class="text-uppercase small text-muted fw-semibold mb-2">Current session</div>
                <div class="h5 mb-1">@(Model.CurrentUserId?.ToString() ?? "Unknown")</div>
                <div class="mini-hint">Use this page to start setup, confirm the code, disable 2FA, or test the login hand-off.</div>
            </div>
            <div class="mt-3">
                <form asp-action="BeginTwoFactorSetup" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-qr-code-scan me-1"></i> Start 2FA Setup
                    </button>
                </form>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-info border-0 shadow-sm mb-4">
            <i class="bi bi-info-circle-fill me-2"></i>@message
        </div>
    }

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning border-0 shadow-sm mb-4">
            <i class="bi bi-plug-fill me-2"></i>Connect the portal to the API before using 2FA setup or verification.
        </div>
    }

    <div class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="security-card card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-uppercase opacity-75">Setup</div>
                        <div class="h5 mb-0">Scan the QR code or enter the manual key</div>
                    </div>
                    <span class="badge text-bg-light text-dark">@(hasSetup ? "Ready to verify" : "Not started")</span>
                </div>
                <div class="card-body p-4">
                    @if (hasSetup)
                    {
                        <div class="row g-4 align-items-center">
                            <div class="col-12 col-lg-6">
                                <div class="qr-frame">
                                    <img src="@Model.QrCodeDataUrl" alt="Authenticator QR code" />
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="mb-3">
                                    <div class="text-muted small text-uppercase mb-1">Issuer</div>
                                    <div class="fw-semibold">@Model.Issuer</div>
                                </div>
                                <div class="mb-3">
                                    <div class="text-muted small text-uppercase mb-1">Account</div>
                                    <div class="fw-semibold">@Model.AccountName</div>
                                </div>
                                <div class="mb-3">
                                    <div class="text-muted small text-uppercase mb-1">Manual key</div>
                                    <div class="font-monospace small p-3 bg-light border rounded-3 text-break security-code-box">@Model.ManualKey</div>
                                </div>
                                <div class="mb-0">
                                    <div class="text-muted small text-uppercase mb-1">Provisioning URI</div>
                                    <div class="font-monospace small p-3 bg-light border rounded-3 text-break security-code-box">@Model.ProvisioningUri</div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-light border">
                            <i class="bi bi-shield-check fs-3 text-success"></i>
                            <div>
                                <div class="fw-semibold mb-1">Setup has not started yet.</div>
                                <div class="mini-hint">Click <strong>Start 2FA Setup</strong> to generate a new secret, QR code, and manual key.</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5 d-flex flex-column gap-4">
            <div class="security-card card">
                <div class="card-header">
                    <div class="small text-uppercase opacity-75">Confirm setup</div>
                    <div class="h5 mb-0">Verify the first TOTP code</div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="VerifyTwoFactorSetup" method="post">
                        @Html.AntiForgeryToken()
                        <label for="setupCode" class="form-label fw-semibold">Authenticator code</label>
                        <input id="setupCode" name="code" type="text" class="form-control code-input mb-3" inputmode="numeric" autocomplete="one-time-code" maxlength="16" placeholder="123456" />
                        <button type="submit" class="btn btn-success w-100">Verify and Enable</button>
                    </form>
                    <div class="mini-hint mt-3">After a valid code is confirmed, the protected secret stays stored and 2FA becomes active.</div>
                </div>
            </div>

            <div class="security-card card">
                <div class="card-header">
                    <div class="small text-uppercase opacity-75">Disable</div>
                    <div class="h5 mb-0">Turn off 2FA with a valid code</div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="DisableTwoFactor" method="post">
                        @Html.AntiForgeryToken()
                        <label for="disableCode" class="form-label fw-semibold">Current authenticator code</label>
                        <input id="disableCode" name="code" type="text" class="form-control code-input mb-3" inputmode="numeric" autocomplete="one-time-code" maxlength="16" placeholder="123456" />
                        <button type="submit" class="btn btn-outline-danger w-100">Disable 2FA</button>
                    </form>
                </div>
            </div>

            <div class="security-card card">
                <div class="card-header">
                    <div class="small text-uppercase opacity-75">Login verify</div>
                    <div class="h5 mb-0">Test the login hand-off</div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="TestTwoFactorLogin" method="post">
                        @Html.AntiForgeryToken()
                        <label for="loginCode" class="form-label fw-semibold">Login challenge code</label>
                        <input id="loginCode" name="code" type="text" class="form-control code-input mb-3" inputmode="numeric" autocomplete="one-time-code" maxlength="16" placeholder="123456" />
                        <button type="submit" class="btn btn-primary w-100">Verify Login Challenge</button>
                    </form>
                    <div class="mini-hint mt-3">This mirrors the plug-in login hand-off endpoint used after the password step.</div>
                </div>
            </div>
        </div>
    </div>
</div>
