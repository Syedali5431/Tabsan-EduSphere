@model Tabsan.EduSphere.Web.Models.Portal.TimetableTeacherPageModel
@{
    ViewData["Title"] = "Teacher Timetable";
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">
        API connection is not configured. Please set it on <a asp-action="Dashboard">Dashboard</a>.
    </div>
}
else
{
    var canManage = Model.Identity?.IsAdmin == true || Model.Identity?.IsSuperAdmin == true;

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form asp-action="TimetableTeacher" method="get" class="row g-2 align-items-end">
                @if (Model.Identity?.IsSuperAdmin == true)
                {
                    <div class="col-12 col-md-4">
                        <label class="form-label">Tenant</label>
                        <select class="form-select" name="tenantId">
                            <option value="">All tenants</option>
                            @foreach (var t in Model.Tenants)
                            {
                                <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name (@t.Code)</option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Campus</label>
                        <select class="form-select" name="campusId">
                            <option value="">All campuses</option>
                            @foreach (var c in Model.Campuses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                            }
                        </select>
                    </div>
                }
                else if (User.IsInRole("Admin"))
                {
                    <div class="col-12 col-md-4">
                        <label class="form-label">Campus</label>
                        <select class="form-select" name="campusId">
                            <option value="">All campuses</option>
                            @foreach (var c in Model.Campuses)
                            {
                                <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name (@c.Code)</option>
                            }
                        </select>
                    </div>
                }

                @if (canManage)
                {
                    <div class="col-12 col-md-3">
                        <label class="form-label">Department</label>
                        <select class="form-select" name="departmentId">
                            <option value="">All departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label">Faculty</label>
                        <select class="form-select" name="facultyUserId">
                            <option value="">Select faculty</option>
                            @foreach (var f in Model.Faculty)
                            {
                                <option value="@f.Id" selected="@(Model.SelectedFacultyUserId == f.Id ? "selected" : null)">@f.DisplayName</option>
                            }
                        </select>
                    </div>
                }

                <div class="col-12 col-md-2">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="includeInactive" name="includeInactive" value="true" @(Model.IncludeInactive ? "checked" : null) />
                        <label class="form-check-label" for="includeInactive">Show deactivated</label>
                    </div>
                </div>

                <div class="col-12 col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Apply</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Assigned Classes</h2>

            @if (Model.Entries.Count == 0)
            {
                <p class="text-muted mb-0">No assigned timetable entries found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>SR#</th>
                                <th>Time</th>
                                <th>Degree Name</th>
                                <th>Semester</th>
                                <th>Subject</th>
                                <th>Building</th>
                                <th>Room</th>
                                <th>Title</th>
                                <th>Status</th>
                                @if (canManage)
                                {
                                    <th>Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Entries.Count; i++)
                            {
                                var e = Model.Entries[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@e.StartTime - @e.EndTime</td>
                                    <td>@e.ProgramCode</td>
                                    <td>@e.SemesterName</td>
                                    <td>@e.SubjectName</td>
                                    <td>@e.BuildingName</td>
                                    <td>@e.RoomNumber</td>
                                    <td>@e.TimetableTitle</td>
                                    <td>
                                        <span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Active" : "Deactivated")</span>
                                    </td>
                                    @if (canManage)
                                    {
                                        <td>
                                            @if (e.IsActive)
                                            {
                                                <form asp-action="DeactivateTeacherTimetable" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="timetableId" value="@e.TimetableId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                    <input type="hidden" name="facultyUserId" value="@Model.SelectedFacultyUserId" />
                                                    <input type="hidden" name="includeInactive" value="@Model.IncludeInactive" />
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Deactivate</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="ActivateTeacherTimetable" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="timetableId" value="@e.TimetableId" />
                                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                                    <input type="hidden" name="departmentId" value="@Model.SelectedDepartmentId" />
                                                    <input type="hidden" name="facultyUserId" value="@Model.SelectedFacultyUserId" />
                                                    <input type="hidden" name="includeInactive" value="@Model.IncludeInactive" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success">Activate</button>
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
