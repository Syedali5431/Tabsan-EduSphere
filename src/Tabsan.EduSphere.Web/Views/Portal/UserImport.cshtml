@model Tabsan.EduSphere.Web.Models.Portal.UserImportPageModel
@{
    ViewData["Title"] = "User Import";
}

<div class="row g-4">
    @if (!Model.IsConnected)
    {
        <div class="col-12">
            <div class="alert alert-warning mb-0">Not connected to the API. Configure connection on Dashboard first.</div>
        </div>
    }
    else
    {
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Import Users From CSV</h2>

                    @if (Model.Identity?.IsSuperAdmin == true)
                    {
                        <form method="get" asp-action="UserImport" class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" name="tenantId" onchange="this.form.submit()">
                                    <option value="">All Tenants</option>
                                    @foreach (var tenant in Model.Tenants)
                                    {
                                        if (Model.SelectedTenantId == tenant.Id)
                                        {
                                            <option value="@tenant.Id" selected>@tenant.Name (@tenant.Code)</option>
                                        }
                                        else
                                        {
                                            <option value="@tenant.Id">@tenant.Name (@tenant.Code)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Campus</label>
                                <select class="form-select" name="campusId" onchange="this.form.submit()" @(Model.SelectedTenantId.HasValue ? null : "disabled")>
                                    <option value="">All Campuses</option>
                                    @foreach (var campus in Model.Campuses)
                                    {
                                        if (Model.SelectedCampusId == campus.Id)
                                        {
                                            <option value="@campus.Id" selected>@campus.Name (@campus.Code)</option>
                                        }
                                        else
                                        {
                                            <option value="@campus.Id">@campus.Name (@campus.Code)</option>
                                        }
                                    }
                                </select>
                            </div>
                        </form>
                    }

                    <form asp-action="CreateUserImportSampleCsv" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                        <button type="submit" class="btn btn-outline-primary btn-sm">Create Sample CSV In User Import Sheets</button>
                        @if (!string.IsNullOrWhiteSpace(Model.GeneratedSampleFileName))
                        {
                            <a class="btn btn-link btn-sm" asp-action="DownloadGeneratedUserImportSample" asp-route-fileName="@Model.GeneratedSampleFileName">Download Created Sample</a>
                        }
                    </form>

                    <div class="alert alert-light border alert-dismissible fade show small mb-3" role="alert">
                        <p class="mb-2"><strong>Use one of the official templates before upload:</strong></p>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="UserImportTemplate" asp-route-fileName="faculty-admin-import-template.csv">faculty-admin-import-template.csv</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="UserImportTemplate" asp-route-fileName="students-import-template.csv">students-import-template.csv</a>
                        </div>
                        <ul class="mb-0 ps-3">
                            <li>Required columns: <strong>Username, Email, Role</strong></li>
                            <li>Optional columns: <strong>FullName, DepartmentId, InstitutionType, MobileNumber, CampusAssignments</strong></li>
                            <li>Accepted file type: <strong>.csv</strong> only</li>
                            <li>Role values: <strong>Admin</strong>, <strong>Faculty</strong>, <strong>Student</strong>, <strong>Finance</strong></li>
                            <li>If you provide <strong>DepartmentId</strong>, use valid IDs from your current database.</li>
                            <li>If you provide <strong>CampusAssignments</strong>, use pipe-separated campus GUIDs (example: <strong>guid1|guid2</strong>).</li>
                            <li>Imported accounts use Username as temporary password and must change it at first login.</li>
                        </ul>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>

                    <form asp-action="ImportUsersCsv" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                        <div class="mb-3">
                            <label class="form-label" for="csvFile">CSV File</label>
                            <input class="form-control" type="file" id="csvFile" name="csvFile" accept=".csv" required />
                        </div>
                        <button type="submit" class="btn btn-primary">Upload and Import</button>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Create Single User</h2>
                    <p class="text-muted small mb-3">Manually create one user at a time. Imported accounts use Username as temporary password and must change it at first login.</p>

                    <form asp-action="CreateSingleUser" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                        <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />

                        <div class="row g-2 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Username <span class="text-danger">*</span></label>
                                <input class="form-control" name="Username" value="@Model.SingleUserForm.Username" placeholder="e.g. john.doe" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <input class="form-control" type="email" name="Email" value="@Model.SingleUserForm.Email" placeholder="e.g. john@tabsan.local" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Full Name</label>
                                <input class="form-control" name="FullName" value="@Model.SingleUserForm.FullName" placeholder="e.g. John Doe" />
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Role <span class="text-danger">*</span></label>
                                <select class="form-select" name="Role" id="singleUserRole" required onchange="toggleRoleFields()">
                                    <option value="">— Select Role —</option>
                                    <option value="Admin" selected="@(Model.SingleUserForm.Role == "Admin")">Admin</option>
                                    <option value="Faculty" selected="@(Model.SingleUserForm.Role == "Faculty")">Faculty</option>
                                    <option value="Student" selected="@(Model.SingleUserForm.Role == "Student")">Student</option>
                                    <option value="Finance" selected="@(Model.SingleUserForm.Role == "Finance")">Finance</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Institution Type</label>
                                <select class="form-select" name="InstitutionType">
                                    <option value="">— Optional —</option>
                                    <option value="University" selected="@(Model.SingleUserForm.InstitutionType == "University")">University</option>
                                    <option value="School" selected="@(Model.SingleUserForm.InstitutionType == "School")">School</option>
                                    <option value="College" selected="@(Model.SingleUserForm.InstitutionType == "College")">College</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Mobile Number</label>
                                <input class="form-control" name="MobileNumber" value="@Model.SingleUserForm.MobileNumber" placeholder="e.g. +61412345678" />
                            </div>
                        </div>

                        <div class="row g-2 mb-3" id="facultyFields" style="display:none;">
                            <div class="col-md-6">
                                <label class="form-label">Department ID <span class="text-danger">*</span></label>
                                <input class="form-control" name="DepartmentId" placeholder="GUID from Departments page" />
                            </div>
                        </div>

                        <div class="row g-2 mb-3" id="studentFields" style="display:none;">
                            <div class="col-md-6">
                                <label class="form-label">Department ID <span class="text-danger">*</span></label>
                                <input class="form-control" name="DepartmentId" placeholder="GUID from Departments page" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Course ID <span class="text-danger">*</span></label>
                                <input class="form-control" name="CourseId" placeholder="GUID from Courses page" />
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Campus Assignments</label>
                                <input class="form-control" name="CampusAssignments" value="@Model.SingleUserForm.CampusAssignments" placeholder="Pipe-separated GUIDs: id|id2" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Address</label>
                                <input class="form-control" name="Address" value="@Model.SingleUserForm.Address" placeholder="e.g. 123 Main St, City" />
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Profile Photo</label>
                                <input class="form-control" type="file" name="ProfilePhoto" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                                <div class="form-text">JPG or PNG, max 2MB</div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success">Create User</button>
                    </form>
                </div>
            </div>

            <script>
                function toggleRoleFields() {
                    var role = document.getElementById('singleUserRole').value;
                    document.getElementById('facultyFields').style.display = (role === 'Faculty') ? '' : 'none';
                    document.getElementById('studentFields').style.display = (role === 'Student') ? '' : 'none';
                    // Toggle required attributes
                    var facultyDept = document.querySelector('#facultyFields input[name="DepartmentId"]');
                    var studentDept = document.querySelector('#studentFields input[name="DepartmentId"]');
                    var studentCourse = document.querySelector('#studentFields input[name="CourseId"]');
                    if (role === 'Faculty') { facultyDept.required = true; studentDept.required = false; if(studentCourse) studentCourse.required = false; }
                    else if (role === 'Student') { facultyDept.required = false; studentDept.required = true; if(studentCourse) studentCourse.required = true; }
                    else { facultyDept.required = false; studentDept.required = false; if(studentCourse) studentCourse.required = false; }
                }
                // Run on load to set initial state
                toggleRoleFields();
            </script>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="col-12">
                <div class="alert alert-info">@Model.Message</div>
            </div>
        }

        @if (Model.Result is not null)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Import Summary</h2>
                        <div class="row g-2 mb-3">
                            <div class="col-6 col-md-3"><div class="border rounded p-2"><strong>Total</strong><div>@Model.Result.TotalRows</div></div></div>
                            <div class="col-6 col-md-3"><div class="border rounded p-2"><strong>Imported</strong><div>@Model.Result.Imported</div></div></div>
                            <div class="col-6 col-md-3"><div class="border rounded p-2"><strong>Duplicates</strong><div>@Model.Result.Duplicates</div></div></div>
                            <div class="col-6 col-md-3"><div class="border rounded p-2"><strong>Errors</strong><div>@Model.Result.Errors</div></div></div>
                        </div>

                        @if (Model.Result.ErrorDetails.Count > 0)
                        {
                            <h3 class="h6">Row-Level Validation Errors</h3>
                            <p class="text-muted small mb-2">Fix the rows below in your CSV and re-upload the same template.</p>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 20%;">Row</th>
                                            <th>Issue</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var error in Model.Result.ErrorDetails)
                                        {
                                            var parts = error.Split(':', 2, StringSplitOptions.TrimEntries);
                                            var rowLabel = parts.Length == 2 ? parts[0] : "Validation";
                                            var message = parts.Length == 2 ? parts[1] : error;
                                            <tr>
                                                <td><span class="badge bg-warning text-dark">@rowLabel</span></td>
                                                <td>@message</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
