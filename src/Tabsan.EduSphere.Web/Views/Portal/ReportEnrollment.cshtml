@model Tabsan.EduSphere.Web.Models.Portal.ReportEnrollmentPageModel
@{
    ViewData["Title"] = "Enrollment Summary Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="ReportCenter" asp-controller="Portal" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h2 class="mb-0"><i class="bi bi-people me-2"></i>Enrollment Summary</h2>
            <small class="text-muted">Course offering enrollment counts and available seats</small>
        </div>
    </div>

    @if (!Model.IsConnected)
    {
        <div class="alert alert-warning"><i class="bi bi-wifi-off me-2"></i>Not connected to API.</div>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>@Model.Message</div>
        }

        <form method="get" class="card shadow-sm border-0 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small mb-1">Institute</label>
                        <select name="institutionType" class="form-select form-select-sm">
                            @if (!Model.InstitutionType.HasValue && Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="" selected>All Institutes</option>
                            }
                            else if (Model.AvailableInstitutionTypes.Count > 1)
                            {
                                <option value="">All Institutes</option>
                            }
                            @foreach (var institution in Model.AvailableInstitutionTypes)
                            {
                                <option value="@institution.Value" selected="@(Model.InstitutionType == institution.Value)">@institution.Label</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">Department</label>
                        <select name="departmentId" class="form-select form-select-sm">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.DepartmentId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small mb-1">@Model.PeriodFilterLabel</label>
                        <select name="semesterId" class="form-select form-select-sm">
                            <option value="">@Model.PeriodFilterPlaceholder</option>
                            @foreach (var s in Model.Semesters)
                            {
                                <option value="@s.Id" selected="@(Model.SemesterId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-funnel me-1"></i>Filter</button>
                    </div>
                    @if (Model.Report is not null)
                    {
                        <div class="col-md-1">
                            <a href="@Url.Action("ExportEnrollmentSummary", "Portal", new { semesterId = Model.SemesterId, departmentId = Model.DepartmentId, institutionType = Model.InstitutionType })"
                               class="btn btn-success btn-sm w-100" title="Export Excel"><i class="bi bi-file-earmark-excel me-1"></i><span>Excel</span></a>
                        </div>
                        <div class="col-md-1">
                            <a href="@Url.Action("ExportEnrollmentSummaryCsv", "Portal", new { semesterId = Model.SemesterId, departmentId = Model.DepartmentId, institutionType = Model.InstitutionType })"
                               class="btn btn-outline-success btn-sm w-100" title="Export CSV"><i class="bi bi-filetype-csv me-1"></i><span>CSV</span></a>
                        </div>
                        <div class="col-md-1">
                            <a href="@Url.Action("ExportEnrollmentSummaryPdf", "Portal", new { semesterId = Model.SemesterId, departmentId = Model.DepartmentId, institutionType = Model.InstitutionType })"
                               class="btn btn-outline-danger btn-sm w-100" title="Export PDF"><i class="bi bi-filetype-pdf me-1"></i><span>PDF</span></a>
                        </div>
                    }
                </div>
            </div>
        </form>

        @if (Model.Report is not null)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small">@Model.Report.TotalOfferings offering(s) &mdash; generated @Model.Report.GeneratedAt.ToString("dd MMM yyyy, HH:mm")</span>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Course Code</th>
                                    <th>Course Title</th>
                                    <th>Semester</th>
                                    <th class="text-center">Max</th>
                                    <th class="text-center">Enrolled</th>
                                    <th class="text-center">Available</th>
                                    <th class="text-center">Fill %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.Report.Rows)
                                {
                                    var fillPct = r.MaxEnrollment > 0 ? (decimal)r.EnrolledCount / r.MaxEnrollment * 100 : 0;
                                    var barClass = fillPct >= 90 ? "danger" : fillPct >= 70 ? "warning" : "success";
                                    <tr>
                                        <td>@r.CourseCode</td>
                                        <td>@r.CourseTitle</td>
                                        <td>@r.SemesterName</td>
                                        <td class="text-center">@r.MaxEnrollment</td>
                                        <td class="text-center">@r.EnrolledCount</td>
                                        <td class="text-center">@r.AvailableSeats</td>
                                        <td class="text-center">
                                            <div class="progress" style="height:18px;">
                                                <div class="progress-bar bg-@barClass" style="width:@fillPct.ToString("F0")%">@fillPct.ToString("F0")%</div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary"><i class="bi bi-info-circle me-2"></i>Select filters above and click Filter to generate the report.</div>
        }
<partial name="_ReportCascadeFilterScripts" />
    }
</div>
