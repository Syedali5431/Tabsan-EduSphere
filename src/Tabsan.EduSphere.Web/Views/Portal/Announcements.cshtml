@model Tabsan.EduSphere.Web.Models.Portal.AnnouncementsPageModel
@{
    ViewData["Title"]     = "Announcements";
    ViewData["PageTitle"] = "Course Announcements";
    ViewData["ActivePage"] = "announcements";
}

@* Final-Touches Phase 20 Stage 20.4 — course announcements page *@

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">API is not available.</div>
    return;
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.SuccessMessage <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @Model.ErrorMessage <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.OfferingId == System.Guid.Empty)
{
    <div class="alert alert-info">Select a valid course offering to view or post announcements.</div>
    return;
}

<form method="get" asp-action="Announcements" class="row g-2 align-items-end mb-4">
    @if (Model.Tenants.Count > 0)
    {
        <div class="col-md-3">
            <label class="form-label">Tenant</label>
            <select name="tenantId" class="form-select" onchange="this.form.submit()">
                <option value="">All Tenants</option>
                @foreach (var t in Model.Tenants)
                {
                    <option value="@t.Id" selected="@(Model.SelectedTenantId == t.Id ? "selected" : null)">@t.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Campus</label>
            <select name="campusId" class="form-select" onchange="this.form.submit()" @(Model.SelectedTenantId.HasValue ? null : "disabled")>
                <option value="">All Campuses</option>
                @foreach (var c in Model.Campuses)
                {
                    <option value="@c.Id" selected="@(Model.SelectedCampusId == c.Id ? "selected" : null)">@c.Name</option>
                }
            </select>
        </div>
    }
    <div class="col-md-4">
        <label class="form-label">Course Offering</label>
        @if (Model.Offerings.Any())
        {
            var hasCurrentOffering = Model.Offerings.Any(o => o.Id == Model.OfferingId);
            <select name="offeringId" class="form-select" onchange="this.form.submit()">
                @if (!hasCurrentOffering && Model.OfferingId != System.Guid.Empty)
                {
                    <option value="@Model.OfferingId" selected="selected">Current offering (@Model.OfferingId)</option>
                }
                @foreach (var o in Model.Offerings)
                {
                    <option value="@o.Id" selected="@(Model.OfferingId == o.Id ? "selected" : null)">@o.Name</option>
                }
            </select>
        }
        else
        {
            <input type="hidden" name="offeringId" value="@Model.OfferingId" />
            <input class="form-control" value="Current offering (@Model.OfferingId)" readonly />
        }
    </div>
    <div class="col-md-2">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" id="includeInactive" name="includeInactive" value="true" @(Model.IncludeInactive ? "checked" : null) onchange="this.form.submit()" />
            <label class="form-check-label" for="includeInactive">Show inactive</label>
        </div>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Apply</button>
    </div>
</form>

<div class="card mb-4">
    <div class="card-header"><strong>Post Announcement</strong></div>
    <div class="card-body">
        <form asp-action="CreateAnnouncement" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="offeringId" value="@Model.OfferingId" />
            <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
            <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
            <input type="hidden" name="includeInactive" value="@Model.IncludeInactive" />
            <div class="mb-2">
                <input name="title" class="form-control" placeholder="Announcement title..." required />
            </div>
            <div class="mb-2">
                <textarea name="body" class="form-control" rows="3" placeholder="Message..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Post</button>
        </form>
    </div>
</div>

@if (!Model.Announcements.Any())
{
    <div class="alert alert-info">No announcements for this course.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Message</th>
                    <th>Author</th>
                    <th>Posted</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Announcements)
                {
                    <tr>
                        <td class="fw-semibold">@a.Title</td>
                        <td>@a.Body</td>
                        <td>@a.AuthorName</td>
                        <td class="text-muted">@a.PostedAt.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(a.IsActive ? "bg-success" : "bg-secondary")">@(a.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td class="text-nowrap">
                            @if (Model.CanManage)
                            {
                                <form asp-action="SetAnnouncementActive" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="announcementId" value="@a.Id" />
                                    <input type="hidden" name="offeringId" value="@Model.OfferingId" />
                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                    <input type="hidden" name="includeInactive" value="@Model.IncludeInactive" />
                                    <input type="hidden" name="isActive" value="@(!a.IsActive)" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        @(a.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                <form asp-action="DeleteAnnouncement" method="post" class="d-inline" onsubmit="return confirm('Delete this announcement?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="announcementId" value="@a.Id" />
                                    <input type="hidden" name="offeringId" value="@Model.OfferingId" />
                                    <input type="hidden" name="tenantId" value="@Model.SelectedTenantId" />
                                    <input type="hidden" name="campusId" value="@Model.SelectedCampusId" />
                                    <input type="hidden" name="includeInactive" value="@Model.IncludeInactive" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
