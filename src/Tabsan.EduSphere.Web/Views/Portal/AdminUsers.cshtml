@model Tabsan.EduSphere.Web.Models.Portal.AdminUsersPageModel
@{ ViewData["Title"] = "Admin Users"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var alertCls = Model.Message.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @alertCls alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <section class="page-section-card card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="section-head mb-3">
                <div>
                    <span class="section-kicker">Administrative access</span>
                    <h2 class="h5 mb-1">Admin users</h2>
                    <p class="text-muted mb-0">Create administrators, assign departments, and keep permissions scoped cleanly.</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a asp-action="UserImport" class="btn btn-sm btn-outline-primary">Import Users</a>
                    <span class="badge bg-secondary">@Model.AdminUsers.Count total</span>
                </div>
            </div>

            @if (Model.AdminUsers.Count == 0)
            {
                <p class="text-muted mb-0">No admin users found yet.</p>
            }
            else
            {
                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Search Admin</label>
                        <input id="adminSearch" type="text" class="form-control" placeholder="Search by username or email" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Select Admin</label>
                        <form asp-action="AdminUsers" method="get">
                            <select id="adminSelect" name="selectedAdminUserId" class="form-select" onchange="this.form.submit()">
                                @foreach (var admin in Model.AdminUsers)
                                {
                                    var selected = Model.SelectedAdminUserId == admin.Id;
                                    var status = admin.IsActive ? "Active" : "Inactive";
                                    var institutionLabel = admin.InstitutionType.HasValue
                                        ? ((Tabsan.EduSphere.Domain.Enums.InstitutionType)admin.InstitutionType.Value).ToString()
                                        : "Unassigned";
                                    <option value="@admin.Id" selected="@selected" data-search="@(admin.UserName.ToLowerInvariant()) @(admin.Email?.ToLowerInvariant())">
                                        @admin.UserName (@(string.IsNullOrWhiteSpace(admin.Email) ? "No email" : admin.Email)) - @status - @institutionLabel
                                    </option>
                                }
                            </select>
                        </form>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="page-section-card card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h3 class="h6 mb-3">Create Admin User</h3>
            <form asp-action="CreateAdminUser" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Username</label>
                        <input name="username" class="form-control" required maxlength="100" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" maxlength="256" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Temporary Password</label>
                        <input type="password" name="password" class="form-control" required minlength="6" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Institution Type (optional)</label>
                        <select name="institutionType" class="form-select">
                            <option value="">Use Global Policy</option>
                            <option value="1">School</option>
                            <option value="2">College</option>
                            <option value="0">University</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
                    <label class="form-label mb-0">Initial Department Assignments</label>
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll('createDeptList', true)">Select All</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll('createDeptList', false)">Clear</button>
                    </div>
                </div>
                <div id="createDeptList" class="row g-2">
                    @foreach (var dept in Model.Departments.Where(d => d.IsActive))
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="form-check border rounded p-2 option-grid-card">
                                <input class="form-check-input" type="checkbox" name="departmentIds" value="@dept.Id" id="create_@dept.Id" />
                                <label class="form-check-label" for="create_@dept.Id"><strong>@dept.Code</strong> - @dept.Name</label>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Create Admin</button>
                </div>
            </form>
        </div>
    </section>

    @if (Model.SelectedAdminUserId.HasValue)
    {
        var selectedAdmin = Model.AdminUsers.FirstOrDefault(x => x.Id == Model.SelectedAdminUserId.Value);
        <section class="page-section-card card border-0 shadow-sm">
            <div class="card-body">
                <h3 class="h6 mb-3">Update Selected Admin</h3>
                <form asp-action="UpdateAdminUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.SelectedAdminUserId" />

                    <div class="row g-2 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" value="@selectedAdmin?.Email" maxlength="256" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Set New Password (optional)</label>
                            <input type="password" name="newPassword" class="form-control" minlength="6" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="isActive">
                                <option value="true" selected="@(selectedAdmin?.IsActive == true)">Active</option>
                                <option value="false" selected="@(selectedAdmin?.IsActive != true)">Inactive</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
                        <label class="form-label mb-0">Department Assignments</label>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll('updateDeptList', true)">Select All</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll('updateDeptList', false)">Clear</button>
                        </div>
                    </div>
                    <div id="updateDeptList" class="row g-2">
                        @foreach (var dept in Model.Departments.Where(d => d.IsActive))
                        {
                            var isChecked = Model.AssignedDepartmentIds.Contains(dept.Id);
                            <div class="col-md-4 col-sm-6">
                                <div class="form-check border rounded p-2 option-grid-card">
                                    <input class="form-check-input" type="checkbox" name="departmentIds" value="@dept.Id" id="update_@dept.Id" checked="@isChecked" />
                                    <label class="form-check-label" for="update_@dept.Id"><strong>@dept.Code</strong> - @dept.Name</label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </section>
    }
}

@section Scripts {
<script>
function toggleAll(containerId, checked) {
    var container = document.getElementById(containerId);
    if (!container) return;
    container.querySelectorAll('input[type="checkbox"]').forEach(function (cb) { cb.checked = checked; });
}

document.getElementById('adminSearch')?.addEventListener('input', function () {
    var q = (this.value || '').toLowerCase().trim();
    var sel = document.getElementById('adminSelect');
    if (!sel) return;

    Array.from(sel.options).forEach(function (opt) {
        var text = (opt.getAttribute('data-search') || opt.textContent || '').toLowerCase();
        opt.hidden = q.length > 0 && text.indexOf(q) === -1;
    });
});
</script>
}
