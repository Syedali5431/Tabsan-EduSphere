@model Tabsan.EduSphere.Web.Models.Portal.AcademicDeadlinesPageModel
@{ ViewData["Title"] = "Manage Deadlines"; }

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-warning">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="AcademicDeadlines" class="row g-2 align-items-end"
                  data-cascade-filter data-filter-role="@(User.IsInRole("SuperAdmin") ? "SuperAdmin" : User.IsInRole("Admin") ? "Admin" : User.IsInRole("Faculty") ? "Faculty" : "Student")">
                <div class="col-md-4">
                    <label class="form-label">Filter by Semester</label>
                    <select name="semesterId" class="form-select" onchange="this.form.submit()">
                        <option value="">All Semesters</option>
                        @foreach (var s in Model.Semesters)
                        {
                            <option value="@s.Id" selected="@(Model.SelectedSemesterId == s.Id ? "selected" : null)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createDeadlineModal">
                        <i class="fas fa-plus"></i> Add Deadline
                    </button>
                </div>
                <div class="col-auto">
                    <a asp-action="AcademicCalendar" asp-route-semesterId="@Model.SelectedSemesterId"
                       class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-calendar"></i> View Calendar
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">
                Deadlines
                <span class="badge bg-secondary ms-1">@Model.Deadlines.Count</span>
            </h2>
            @if (Model.Deadlines.Count == 0)
            {
                <p class="text-muted">No deadlines found. Add one using the button above.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Semester</th>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Reminder</th>
                                <th>Active</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Deadlines)
                            {
                                <tr>
                                    <td>@d.SemesterName</td>
                                    <td>@d.Title</td>
                                    <td>@d.DeadlineDate.ToString("dd MMM yyyy")</td>
                                    <td>@d.ReminderDaysBefore days before</td>
                                    <td>
                                        <span class="badge @(d.IsActive ? "bg-success" : "bg-secondary")">
                                            @(d.IsActive ? "Yes" : "No")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-xs btn-sm btn-outline-secondary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal-@d.Id">
                                            Edit
                                        </button>
                                        <form asp-action="DeleteDeadline" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@d.Id" />
                                            <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
                                            <button type="submit" class="btn btn-xs btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete deadline @d.Title?')">Del</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* ── Create Modal ──────────────────────────────────────────────────────────────── *@
<div class="modal fade" id="createDeadlineModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateDeadline" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="semesterId" value="@Model.SelectedSemesterId" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Deadline</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Semester <span class="text-danger">*</span></label>
                        <select name="form.SemesterId" class="form-select" required>
                            <option value="">Select semester…</option>
                            @foreach (var s in Model.Semesters)
                            {
                                <option value="@s.Id" selected="@(Model.SelectedSemesterId == s.Id ? "selected" : null)">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" name="form.Title" class="form-control" required maxlength="200"
                               placeholder="e.g. Census Date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="form.Description" class="form-control" rows="2" maxlength="1000"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Deadline Date <span class="text-danger">*</span></label>
                        <input type="date" name="form.DeadlineDate" class="form-control" required
                               value="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reminder Days Before <span class="text-danger">*</span></label>
                        <input type="number" name="form.ReminderDaysBefore" class="form-control" min="0" max="30" required value="3" />
                        <div class="form-text">Send reminder notification this many days before the deadline. 0 = day-of reminder only.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* ── Edit Modals (one per deadline) ────────────────────────────────────────────── *@
@if (Model.IsConnected)
{
    @foreach (var d in Model.Deadlines)
    {
        <div class="modal fade" id="editModal-@d.Id" tabindex="-1">
            <div class="modal-dialog">
                <form asp-action="EditDeadline" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@d.Id" />
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Edit Deadline</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Semester</label>
                                <select name="form.SemesterId" class="form-select" required>
                                    @foreach (var s in Model.Semesters)
                                    {
                                        <option value="@s.Id" selected="@(d.SemesterId == s.Id ? "selected" : null)">@s.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" name="form.Title" class="form-control" required maxlength="200" value="@d.Title" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea name="form.Description" class="form-control" rows="2" maxlength="1000">@d.Description</textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Deadline Date <span class="text-danger">*</span></label>
                                <input type="date" name="form.DeadlineDate" class="form-control" required
                                       value="@d.DeadlineDate.ToString("yyyy-MM-dd")" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Reminder Days Before</label>
                                <input type="number" name="form.ReminderDaysBefore" class="form-control" min="0" max="30" value="@d.ReminderDaysBefore" />
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" name="form.IsActive" value="true"
                                       id="isActive-@d.Id" checked="@(d.IsActive ? "checked" : null)" />
                                <label class="form-check-label" for="isActive-@d.Id">Active</label>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
}
