@* Final-Touches Phase 16 Stage 16.1 — Gradebook grid view for Faculty *@
@model Tabsan.EduSphere.Web.Models.Portal.GradebookPageModel
@{ ViewData["Title"] = "Gradebook"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}
@if (TempData["Message"] is string td) { <div class="alert alert-info">@td</div> }

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="Gradebook" class="row g-2 align-items-end"
                  data-cascade-filter data-filter-role="@(User.IsInRole("SuperAdmin") ? "SuperAdmin" : User.IsInRole("Admin") ? "Admin" : User.IsInRole("Faculty") ? "Faculty" : "Student")">
                <div class="col-md-5">
                    <label class="form-label">Course Offering</label>
                    <select name="offeringId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Select Offering --</option>
                        @foreach (var o in Model.Offerings)
                        {
                            <option value="@o.Id" selected="@(Model.SelectedOffering == o.Id ? "selected" : null)">@o.Name</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Grid is not null)
    {
        var grid = Model.Grid;
        var components = grid.Columns.Select(c => c.ComponentName).ToList();
        var isUniversity = grid.UsesGpa;

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Gradebook Grid</h6>
                <div class="d-flex gap-2">
                    @if (components.Count > 0)
                    {
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">Download CSV Template</button>
                            <ul class="dropdown-menu">
                                @foreach (var comp in components)
                                {
                                    <li><a class="dropdown-item" asp-action="GradebookCsvTemplate" asp-route-offeringId="@grid.CourseOfferingId" asp-route-component="@comp">@comp</a></li>
                                }
                            </ul>
                        </div>
                    }
                    <form method="post" asp-action="GradebookPublishAll" asp-route-offeringId="@grid.CourseOfferingId">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Publish all results?')">Publish All</button>
                    </form>
                </div>
            </div>
            <div class="card-body p-0 table-responsive">
                <table class="table table-bordered table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Reg #</th>
                            <th>Student</th>
                            @foreach (var col in grid.Columns)
                            {
                                <th>@col.ComponentName<br/><small class="text-muted">(@col.Weightage%)</small></th>
                            }
                            @if (isUniversity)
                            {
                                <th>GPA</th>
                                <th>CGPA</th>
                            }
                            else
                            {
                                <th>Percentage</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in grid.Rows)
                        {
                            <tr>
                                <td>@row.RegistrationNumber</td>
                                <td>@row.StudentName</td>
                                @foreach (var comp in components)
                                {
                                    var cell = row.Cells.FirstOrDefault(c => c.ComponentName == comp);
                                    <td>
                                        <input type="number" step="0.01" min="0"
                                               class="form-control form-control-sm gradebook-cell"
                                               data-offering="@grid.CourseOfferingId"
                                               data-student="@row.StudentProfileId"
                                               data-component="@comp"
                                               data-max="@(cell?.MaxMarks ?? 100)"
                                               value="@(cell?.MarksObtained?.ToString("0.##"))"
                                               @(cell?.IsPublished == true ? "disabled" : "") />
                                        @if (cell?.IsPublished == true)
                                        { <span class="badge bg-success ms-1">Published</span> }
                                    </td>
                                }
                                @if (isUniversity)
                                {
                                    <td><strong>@(row.Gpa?.ToString("0.##") ?? "-")</strong></td>
                                    <td><strong>@(row.Cgpa?.ToString("0.##") ?? "-")</strong></td>
                                }
                                else
                                {
                                    <td><strong>@(row.PercentageTotal?.ToString("0.##") ?? "-")%</strong></td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Bulk CSV Upload *@
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header"><h6 class="mb-0">Bulk Grade Upload (CSV)</h6></div>
            <div class="card-body">
                <form method="post" asp-action="GradebookBulkUpload" enctype="multipart/form-data" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="offeringId" value="@grid.CourseOfferingId" />
                    <div class="col-md-3">
                        <label class="form-label">Component</label>
                        <select name="componentName" class="form-select">
                            @foreach (var comp in components)
                            { <option value="@comp">@comp</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">CSV File</label>
                        <input type="file" name="file" accept=".csv" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Preview</button>
                    </div>
                </form>

                @if (TempData["BulkPreview"] is string previewJson)
                {
                    var preview = System.Text.Json.JsonSerializer.Deserialize<Tabsan.EduSphere.Web.Models.Portal.BulkGradePreviewWebModel>(
                        previewJson, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (preview is not null)
                    {
                        <div class="mt-3">
                            <p>Total: <strong>@preview.TotalRows</strong> | Valid: <strong class="text-success">@preview.ValidRows</strong> | Errors: <strong class="text-danger">@preview.ErrorRows</strong></p>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead class="table-light"><tr><th>Reg #</th><th>Student</th><th>Marks</th><th>Max</th><th>Error</th></tr></thead>
                                    <tbody>
                                        @foreach (var r in preview.Rows)
                                        {
                                            <tr class="@(r.ValidationError is not null ? "table-danger" : "")">
                                                <td>@r.RegistrationNumber</td>
                                                <td>@r.StudentName</td>
                                                <td>@r.MarksObtained</td>
                                                <td>@r.MaxMarks</td>
                                                <td>@r.ValidationError</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (preview.ValidRows > 0)
                            {
                                <form method="post" asp-action="GradebookBulkConfirm">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="offeringId" value="@TempData["BulkOffering"]" />
                                    <input type="hidden" name="previewJson" value="@previewJson" />
                                    <button type="submit" class="btn btn-success">Confirm &amp; Apply @preview.ValidRows valid row(s)</button>
                                </form>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
}

@section Scripts {
    <script>
    // Final-Touches Phase 16 Stage 16.1 — auto-save on blur via fetch
    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function showGradebookSaveError(message) {
        var main = document.getElementById('main-content');
        if (!main) return;

        var host = document.getElementById('gradebook-save-alert-host');
        if (!host) {
            host = document.createElement('div');
            host.id = 'gradebook-save-alert-host';
            host.className = 'mb-3';
            main.prepend(host);
        }

        host.innerHTML = '<div class="alert alert-danger alert-dismissible fade show" role="alert">'
            + escapeHtml(message)
            + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>'
            + '</div>';
    }

    document.querySelectorAll('.gradebook-cell').forEach(inp => {
        inp.addEventListener('blur', function () {
            const val = parseFloat(this.value);
            if (isNaN(val)) return;
            const max = parseFloat(this.dataset.max) || 100;
            const body = new URLSearchParams({
                offeringId:       this.dataset.offering,
                studentProfileId: this.dataset.student,
                componentName:    this.dataset.component,
                marksObtained:    val,
                maxMarks:         max,
                __RequestVerificationToken: document.querySelector('[name="__RequestVerificationToken"]')?.value ?? ''
            });
            fetch('@Url.Action("GradebookUpsertEntry")', { method: 'POST', body })
                .then(r => r.json())
                .then(j => {
                    if (!j.success) {
                        showGradebookSaveError('Save failed: ' + (j.error || 'Unknown error.'));
                    }
                })
                .catch(() => {
                    showGradebookSaveError('Save failed: network or server error.');
                });
        });
    });
    </script>
}
