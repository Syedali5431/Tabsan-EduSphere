{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EduApi": {
    "BaseUrl": "http://localhost:5181"
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere Web",
    "AppVersion": "1.0.0",
    "WebBaseUrl": ""
  },
  "Deployment": {
    "Mode": "SingleInstance",
    "CustomerCode": "",
    "CustomerName": "",
    "CustomerDomain": "",
    "Database": {
      "Name": "",
      "ConnectionString": ""
    },
    "Scaling": {
      "Enabled": true,
      "MinReplicas": 1,
      "MaxReplicas": 1
    }
  },
  "ScaleOut": {
    "SharedDataProtectionKeyRingPath": ""
  },
  "InfrastructureTuning": {
    "AutoScaling": {
      "Enabled": true,
      "MinReplicas": 2,
      "MaxReplicas": 8
    },
    "HostLimits": {
      "ThreadPoolMinWorkerThreads": 128,
      "ThreadPoolMinCompletionPortThreads": 128,
      "MaxConcurrentConnections": 10000,
      "MaxConcurrentUpgradedConnections": 5000
    },
    "NetworkStack": {
      "KeepAliveTimeoutSeconds": 120,
      "RequestHeadersTimeoutSeconds": 20,
      "Http2KeepAlivePingDelaySeconds": 30,
      "Http2KeepAlivePingTimeoutSeconds": 10,
      "Http2MaxStreamsPerConnection": 200,
      "OutboundMaxConnectionsPerServer": 256,
      "OutboundConnectTimeoutSeconds": 10
    }
  },
  "StaticAssetCaching": {
    "Enabled": true,
    "MaxAgeSeconds": 86400
  },
  "ReverseProxy": {
    "Enabled": false,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": []
  }
}
