{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_PRODUCTION_CONNECTION_STRING_OR_SET_VIA_ENV_VAR;Min Pool Size=50;Max Pool Size=800;Connect Timeout=30"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_PRODUCTION_SECRET_KEY_MIN_32_CHARS_OR_SET_VIA_ENV_VAR",
    "Issuer": "https://yourdomain.com",
    "Audience": "tabsan-edusphere-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AuthSecurity": {
    "Mfa": {
      "Enabled": false,
      "RequireForPasswordLogin": false,
      "RequireForPrivilegedRolesOnly": true,
      "PrivilegedRoles": [ "SuperAdmin", "Admin" ],
      "TotpIssuer": "Tabsan EduSphere",
      "TotpDigits": 6,
      "TotpStepSeconds": 30,
      "TotpAllowedDriftWindows": 1,
      "RecoveryCodeCount": 8
    },
    "Sso": {
      "Enabled": false,
      "Provider": "",
      "LoginUrl": ""
    },
    "SessionRisk": {
      "Enabled": true,
      "BlockHighRiskLogin": true,
      "AuditMediumRiskLogin": true
    }
  },
  "License": {
    "PublicKeyPem": ""
  },
  "Email": {
    "SmtpHost": "smtp-relay.brevo.com",
    "SmtpPort": 587,
    "Username": "REPLACE_WITH_SMTP_USERNAME_OR_SET_VIA_ENV_VAR",
    "Password": "REPLACE_WITH_SMTP_PASSWORD_OR_SET_VIA_ENV_VAR",
    "FromAddress": "noreply@yourdomain.com",
    "FromName": "Tabsan EduSphere",
    "EnableSsl": true
  },
  "NotificationEmail": {
    "Enabled": true,
    "SubjectPrefix": "[Tabsan EduSphere]",
    "PortalUrl": "https://yourdomain.com/Portal/Notifications"
  },
  "NotificationSms": {
    "Enabled": false,
    "PortalUrl": "https://yourdomain.com/Portal/Notifications"
  },
  "AppSettings": {
    "ApiBaseUrl": "https://yourdomain.com/api",
    "WebBaseUrl": "https://yourdomain.com",
    "EnableSwagger": false,
    "EnableDetailedErrors": false,
    "CorsOrigins": [ "https://yourdomain.com", "https://www.yourdomain.com" ]
  },
  "ScaleOut": {
    "InstanceId": "REPLACE_WITH_NODE_ID_OR_SET_VIA_ENV_VAR",
    "ExposeInstanceHeader": true,
    "RedisConnectionString": "REPLACE_WITH_REDIS_CONNECTION_STRING_OR_SET_VIA_ENV_VAR",
    "RedisInstanceName": "Tabsan.EduSphere:"
  },
  "Deployment": {
    "Mode": "MultiInstance",
    "CustomerCode": "",
    "CustomerName": "",
    "CustomerDomain": "",
    "Database": {
      "Name": "",
      "ConnectionString": ""
    },
    "Scaling": {
      "Enabled": true,
      "MinReplicas": 2,
      "MaxReplicas": 4
    },
    "TenantIsolation": {
      "Enabled": true,
      "Mode": "Isolated",
      "TenantCode": "",
      "TenantName": "",
      "TenantDomain": "",
      "TenantDatabaseName": "",
      "ConfigPath": "",
      "IsolationStrategy": "FileOverlay"
    }
  },
  "ReverseProxy": {
    "Enabled": true,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": [ "127.0.0.1" ]
  },
  "InfrastructureTuning": {
    "AutoScaling": {
      "Enabled": true,
      "MinReplicas": 3,
      "MaxReplicas": 20,
      "TargetCpuUtilizationPercent": 65,
      "TargetMemoryUtilizationPercent": 75,
      "ScaleOutCooldownSeconds": 45,
      "ScaleInCooldownSeconds": 180
    },
    "HostLimits": {
      "ThreadPoolMinWorkerThreads": 256,
      "ThreadPoolMinCompletionPortThreads": 256,
      "MaxConcurrentConnections": 40000,
      "MaxConcurrentUpgradedConnections": 20000
    },
    "NetworkStack": {
      "KeepAliveTimeoutSeconds": 120,
      "RequestHeadersTimeoutSeconds": 15,
      "Http2KeepAlivePingDelaySeconds": 20,
      "Http2KeepAlivePingTimeoutSeconds": 10,
      "Http2MaxStreamsPerConnection": 300,
      "OutboundMaxConnectionsPerServer": 1024,
      "OutboundConnectTimeoutSeconds": 8
    },
    "Monitoring": {
      "LatencySampleLimit": 4096,
      "CpuThresholdPercent": 80,
      "MemoryThresholdPercent": 80,
      "ErrorRateThresholdPercent": 3.0,
      "NetworkProbeUrl": "https://yourdomain.com"
    }
  },
  "QueuePlatform": {
    "Provider": "InMemory",
    "RabbitMq": {
      "Enabled": false,
      "ConnectionString": "REPLACE_WITH_RABBITMQ_CONNECTION_STRING_OR_SET_VIA_ENV_VAR",
      "AccountSecurityEmailQueueName": "tabsan.account-security.email",
      "PollDelayMilliseconds": 400
    }
  },
  "BackgroundJobReliability": {
    "MaxRetryAttempts": 4,
    "BaseDelayMilliseconds": 300,
    "AlertConsecutiveFailureThreshold": 3
  },
  "IntegrationGateway": {
    "Enabled": true,
    "MaxDeadLetters": 500,
    "Channels": {
      "payment": {
        "MaxRetries": 3,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 300,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "email": {
        "MaxRetries": 3,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 250,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "sms": {
        "MaxRetries": 3,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "push": {
        "MaxRetries": 2,
        "TimeoutSeconds": 10,
        "BaseDelayMilliseconds": 150,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "lms-external-api": {
        "MaxRetries": 3,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 4,
        "CircuitBreakerOpenSeconds": 45
      }
    }
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads",
    "BlobRootPath": "blob-storage",
    "PublicBaseUrl": "",
    "KeyPrefix": "prod",
    "SignedUrlSecret": "REPLACE_WITH_MEDIA_SIGNING_SECRET_OR_SET_VIA_ENV_VAR"
  }
}
