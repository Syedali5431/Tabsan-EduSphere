{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=Tabsan-EduSphere;Trusted_Connection=True;MultipleActiveResultSets=true;Min Pool Size=20;Max Pool Size=500;Connect Timeout=30"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_KEY_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "https://localhost:7001",
    "Audience": "tabsan-edusphere-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AuthSecurity": {
    "Mfa": {
      "Enabled": false,
      "RequireForPasswordLogin": false,
      "RequireForPrivilegedRolesOnly": true,
      "PrivilegedRoles": [ "SuperAdmin", "Admin" ],
      "TotpIssuer": "Tabsan EduSphere",
      "TotpDigits": 6,
      "TotpStepSeconds": 30,
      "TotpAllowedDriftWindows": 1,
      "RecoveryCodeCount": 8
    },
    "Sso": {
      "Enabled": false,
      "Provider": "",
      "LoginUrl": ""
    },
    "SessionRisk": {
      "Enabled": true,
      "BlockHighRiskLogin": true,
      "AuditMediumRiskLogin": true
    }
  },
  "License": {
    "PublicKeyPem": ""
  },
  "Email": {
    "SmtpHost": "smtp-relay.brevo.com",
    "SmtpPort": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@tabsan-edusphere.com",
    "FromName": "Tabsan EduSphere",
    "EnableSsl": true
  },
  "NotificationEmail": {
    "Enabled": false,
    "SubjectPrefix": "[Tabsan EduSphere]",
    "PortalUrl": "https://localhost:5063/Portal/Notifications"
  },
  "NotificationSms": {
    "Enabled": false,
    "PortalUrl": "https://localhost:5063/Portal/Notifications"
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere",
    "AppVersion": "1.0.0",
    "ApiBaseUrl": "",
    "WebBaseUrl": "",
    "EnableSwagger": false,
    "EnableDetailedErrors": false,
    "CorsOrigins": []
  },
  "Deployment": {
    "Mode": "SingleInstance",
    "CustomerCode": "",
    "CustomerName": "",
    "CustomerDomain": "",
    "Database": {
      "Name": "",
      "ConnectionString": ""
    },
    "Scaling": {
      "Enabled": true,
      "MinReplicas": 1,
      "MaxReplicas": 1
    },
    "TenantIsolation": {
      "Enabled": false,
      "Mode": "Shared",
      "TenantCode": "",
      "TenantName": "",
      "TenantDomain": "",
      "TenantDatabaseName": "",
      "ConfigPath": "",
      "IsolationStrategy": "SharedConfig"
    }
  },
  "ScaleOut": {
    "InstanceId": "",
    "ExposeInstanceHeader": true,
    "RedisConnectionString": "",
    "RedisInstanceName": "Tabsan.EduSphere:"
  },
  "ReverseProxy": {
    "Enabled": false,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": []
  },
  "InfrastructureTuning": {
    "AutoScaling": {
      "Enabled": true,
      "MinReplicas": 2,
      "MaxReplicas": 8,
      "TargetCpuUtilizationPercent": 70,
      "TargetMemoryUtilizationPercent": 75,
      "ScaleOutCooldownSeconds": 60,
      "ScaleInCooldownSeconds": 180
    },
    "HostLimits": {
      "ThreadPoolMinWorkerThreads": 192,
      "ThreadPoolMinCompletionPortThreads": 192,
      "MaxConcurrentConnections": 12000,
      "MaxConcurrentUpgradedConnections": 6000
    },
    "NetworkStack": {
      "KeepAliveTimeoutSeconds": 120,
      "RequestHeadersTimeoutSeconds": 20,
      "Http2KeepAlivePingDelaySeconds": 30,
      "Http2KeepAlivePingTimeoutSeconds": 10,
      "Http2MaxStreamsPerConnection": 200,
      "OutboundMaxConnectionsPerServer": 512,
      "OutboundConnectTimeoutSeconds": 10
    },
    "Monitoring": {
      "LatencySampleLimit": 4096,
      "CpuThresholdPercent": 85,
      "MemoryThresholdPercent": 85,
      "ErrorRateThresholdPercent": 5.0,
      "NetworkProbeUrl": "http://localhost:5181"
    }
  },
  "QueuePlatform": {
    "Provider": "InMemory",
    "RabbitMq": {
      "Enabled": false,
      "ConnectionString": "",
      "AccountSecurityEmailQueueName": "tabsan.account-security.email",
      "PollDelayMilliseconds": 400
    }
  },
  "BackgroundJobReliability": {
    "MaxRetryAttempts": 3,
    "BaseDelayMilliseconds": 250,
    "AlertConsecutiveFailureThreshold": 3
  },
  "IntegrationGateway": {
    "Enabled": true,
    "MaxDeadLetters": 200,
    "Channels": {
      "payment": {
        "MaxRetries": 2,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 300,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "email": {
        "MaxRetries": 2,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 250,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "sms": {
        "MaxRetries": 2,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "push": {
        "MaxRetries": 1,
        "TimeoutSeconds": 10,
        "BaseDelayMilliseconds": 150,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "lms-external-api": {
        "MaxRetries": 2,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 4,
        "CircuitBreakerOpenSeconds": 45
      }
    }
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads",
    "BlobRootPath": "blob-storage",
    "PublicBaseUrl": "",
    "KeyPrefix": "",
    "SignedUrlSecret": ""
  }
}
